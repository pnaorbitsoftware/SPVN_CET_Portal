<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-student') %>
  <main class="ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-20 bg-white border-b px-8 py-4"><h1 class="text-xl font-bold">My Results</h1></header>
    <div class="p-8">
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-xs sm:text-sm">
            <thead class="bg-gray-50 text-xs text-gray-500 uppercase tracking-wider">
              <tr><th class="px-6 py-3 text-left">Test</th><th class="px-6 py-3 text-left">Score</th><th class="px-6 py-3 text-left">%</th><th class="px-6 py-3 text-left">Rank</th><th class="px-6 py-3 text-left">Date</th><th class="px-6 py-3 text-left">Action</th></tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
              <% results.forEach(r => { const pct=((r.score/r.totalMarks)*100).toFixed(1) %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 font-medium max-w-xs truncate"><%= r.test?.title %></td>
                <td class="px-6 py-4 font-bold"><%= r.score %>/<%= r.totalMarks %></td>
                <td class="px-6 py-4 font-semibold <%= pct>=60?'text-green-600':pct>=40?'text-yellow-600':'text-red-500' %>"><%= pct %>%</td>
                <td class="px-6 py-4 text-gray-600">#<%= r.rank||'—' %></td>
                <td class="px-6 py-4 text-xs text-gray-400"><%= r.submittedAt?new Date(r.submittedAt).toLocaleDateString('en-IN'):'—' %></td>
                <td class="px-6 py-4 flex gap-2">
                  <a href="/results/<%= r.id %>" class="text-indigo-600 hover:underline text-xs font-medium">View</a>
                  <a href="/results/<%= r.id %>/pdf" class="text-red-500 hover:underline text-xs font-medium">PDF</a>
                </td>
              </tr>
              <% }) %>
              <% if (!results.length) { %><tr><td colspan="6" class="px-6 py-12 text-center text-gray-400">No results yet.</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>
</body></html>
