<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-student') %>
  <main class="lg:ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-10 bg-white/90 backdrop-blur border-b border-slate-200 px-5 lg:px-8 py-4 flex items-center gap-4">
      <button onclick="openSidebar()" class="lg:hidden text-slate-500 hover:text-slate-800">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <div class="flex-1 min-w-0">
        <h1 class="text-lg font-bold text-slate-900 leading-tight">Dashboard</h1>
        <p class="text-xs text-slate-400">Welcome, <span class="font-semibold text-slate-600"><%= currentUser.name %></span> &middot; Roll: <span class="font-mono"><%= currentUser.rollNo %></span></p>
      </div>
      <% if (notifications && notifications.length > 0) { %>
      <a href="/student/notifications" class="relative">
        <div class="w-9 h-9 bg-slate-100 rounded-full flex items-center justify-center">
          <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        </div>
        <span class="absolute -top-1 -right-1 w-5 h-5 bg-rose-500 rounded-full text-white text-[10px] flex items-center justify-center font-bold"><%= notifications.length %></span>
      </a>
      <% } %>
    </header>

    <div class="p-5 lg:p-8">
      <%- include('../partials/flash') %>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-4 mb-8">
        <% [
          {label:'Pending Tests', value: stats.pending,    icon:'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', c:'amber'},
          {label:'Completed',    value: stats.completed,  icon:'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', c:'emerald'},
          {label:'Avg Score',    value: stats.avgScore+'%',icon:'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', c:'navy'},
        ].forEach(s => { %>
        <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-4 lg:p-6">
          <div class="w-9 h-9 rounded-xl bg-<%= s.c === 'navy' ? 'navy-50 text-navy-600' : s.c+'-50 text-'+s.c+'-600' %> flex items-center justify-center mb-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="<%= s.icon %>"/></svg>
          </div>
          <p class="text-2xl lg:text-3xl font-bold text-slate-900"><%= s.value %></p>
          <p class="text-xs text-slate-500 mt-1 font-medium"><%= s.label %></p>
        </div>
        <% }) %>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Pending Tests -->
        <div class="bg-white rounded-2xl border border-slate-100 shadow-card overflow-hidden">
          <div class="flex items-center justify-between px-6 py-4 border-b border-slate-50">
            <h3 class="font-semibold text-slate-900 text-sm">Pending Tests</h3>
            <a href="/student/tests" class="text-xs text-navy-600 hover:text-navy-800 font-medium flex items-center gap-1">
              View all <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <% if (pendingTests.length === 0) { %>
          <div class="py-12 text-center">
            <svg class="w-10 h-10 text-emerald-200 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-sm text-slate-400 font-medium">All caught up!</p>
            <p class="text-xs text-slate-400">No pending tests right now.</p>
          </div>
          <% } else { %>
          <ul class="divide-y divide-slate-50">
            <% pendingTests.slice(0,5).forEach(test => { %>
            <li class="flex items-center gap-4 px-6 py-4 hover:bg-slate-50 transition-colors">
              <div class="w-10 h-10 bg-navy-100 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-medium text-slate-900 text-sm truncate"><%= test.title %></p>
                <p class="text-xs text-slate-400 mt-0.5"><%= test.duration %> mins &middot; <%= test.totalMarks %> marks</p>
              </div>
              <a href="/exam/<%= test.id %>/instructions"
                class="shrink-0 bg-navy-950 text-white text-xs font-semibold px-3.5 py-2 rounded-lg hover:bg-navy-900 transition-colors flex items-center gap-1.5">
                Start
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
            </li>
            <% }) %>
          </ul>
          <% } %>
        </div>

        <!-- Recent Results -->
        <div class="bg-white rounded-2xl border border-slate-100 shadow-card overflow-hidden">
          <div class="flex items-center justify-between px-6 py-4 border-b border-slate-50">
            <h3 class="font-semibold text-slate-900 text-sm">Recent Results</h3>
            <a href="/student/results" class="text-xs text-navy-600 hover:text-navy-800 font-medium flex items-center gap-1">
              View all <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <% if (completedResults.length === 0) { %>
          <div class="py-12 text-center">
            <svg class="w-10 h-10 text-slate-200 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            <p class="text-sm text-slate-400">No completed tests yet.</p>
          </div>
          <% } else { %>
          <ul class="divide-y divide-slate-50">
            <% completedResults.forEach(r => {
              const pct = r.totalMarks > 0 ? ((r.score/r.totalMarks)*100).toFixed(1) : 0;
              const clr = pct>=60?'emerald':pct>=40?'amber':'rose';
            %>
            <li class="flex items-center gap-4 px-6 py-4 hover:bg-slate-50 transition-colors">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-bold text-sm shrink-0 bg-<%= clr %>-500">
                <%= Math.round(pct) %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-medium text-slate-900 text-sm truncate"><%= r.test?.title %></p>
                <p class="text-xs text-slate-400"><%= r.score %>/<%= r.totalMarks %> marks</p>
              </div>
              <a href="/results/<%= r.id %>" class="text-xs text-navy-600 hover:underline shrink-0 font-medium">View</a>
            </li>
            <% }) %>
          </ul>
          <% } %>
        </div>
      </div>

      <!-- Notifications -->
      <% if (notifications && notifications.length > 0) { %>
      <div class="mt-6 bg-white rounded-2xl border border-slate-100 shadow-card overflow-hidden">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-50">
          <h3 class="font-semibold text-slate-900 text-sm">Notifications</h3>
          <a href="/student/notifications" class="text-xs text-navy-600 hover:text-navy-800 font-medium">Mark all read</a>
        </div>
        <ul class="divide-y divide-slate-50">
          <% notifications.forEach(n => {
            const nclr = n.type==='exam'?'navy':n.type==='success'?'emerald':n.type==='warning'?'amber':'slate';
            const nicon = n.type==='exam'?'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2':n.type==='success'?'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z':'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z';
          %>
          <li class="flex items-start gap-3.5 px-6 py-4">
            <div class="w-8 h-8 rounded-full bg-<%= nclr %>-100 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-<%= nclr %>-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="<%= nicon %>"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-slate-900"><%= n.title %></p>
              <p class="text-xs text-slate-500 mt-0.5"><%= n.message %></p>
            </div>
          </li>
          <% }) %>
        </ul>
      </div>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
