<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-student') %>
  <main class="ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-20 bg-white border-b border-gray-200 px-8 py-4">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-xl font-bold text-gray-900">Student Dashboard</h1>
          <p class="text-sm text-gray-500">Welcome, <%= currentUser.name %> · Roll No: <span class="font-mono font-semibold"><%= currentUser.rollNo %></span></p>
        </div>
        <% if (notifications.length > 0) { %>
        <a href="/student/notifications" class="relative">
          <div class="w-10 h-10 bg-indigo-100 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          </div>
          <span class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 rounded-full text-white text-xs flex items-center justify-center font-bold"><%= notifications.length %></span>
        </a>
        <% } %>
      </div>
    </header>

    <div class="p-8">
      <%- include('../partials/flash') %>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-6 mb-8">
        <div class="card-hover bg-white rounded-2xl p-6 border border-gray-100 shadow-sm">
          <div class="text-3xl mb-3">⏳</div>
          <p class="text-3xl font-bold text-gray-900"><%= stats.pending %></p>
          <p class="text-sm text-gray-500 mt-1">Pending Tests</p>
        </div>
        <div class="card-hover bg-white rounded-2xl p-6 border border-gray-100 shadow-sm">
          <div class="text-3xl mb-3">✅</div>
          <p class="text-3xl font-bold text-gray-900"><%= stats.completed %></p>
          <p class="text-sm text-gray-500 mt-1">Completed</p>
        </div>
        <div class="card-hover bg-white rounded-2xl p-6 border border-gray-100 shadow-sm">
          <div class="text-3xl mb-3">📊</div>
          <p class="text-3xl font-bold text-gray-900"><%= stats.avgScore %>%</p>
          <p class="text-sm text-gray-500 mt-1">Avg Score</p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Pending Tests -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="flex items-center justify-between px-6 py-4 border-b border-gray-50">
            <h3 class="font-semibold text-gray-900">📋 Pending Tests</h3>
            <a href="/student/tests" class="text-sm text-indigo-600 hover:underline">View all</a>
          </div>
          <% if (pendingTests.length === 0) { %>
          <div class="px-6 py-10 text-center text-gray-400">
            <p class="text-4xl mb-3">🎉</p>
            <p>All tests completed! Great job.</p>
          </div>
          <% } else { %>
          <div class="divide-y divide-gray-50">
            <% pendingTests.slice(0,5).forEach(test => { %>
            <div class="flex items-center gap-4 px-6 py-4 hover:bg-gray-50 transition-colors">
              <div class="w-10 h-10 bg-indigo-100 rounded-xl flex items-center justify-center text-xl flex-shrink-0">📝</div>
              <div class="flex-1 min-w-0">
                <p class="font-medium text-gray-900 text-sm truncate"><%= test.title %></p>
                <p class="text-xs text-gray-500">⏱ <%= test.duration %> mins · 📊 <%= test.totalMarks %> marks</p>
              </div>
              <a href="/exam/<%= test.id %>/instructions"
                class="flex-shrink-0 bg-indigo-600 text-white text-xs font-semibold px-4 py-2 rounded-lg hover:bg-indigo-700 transition-colors">
                Start →
              </a>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>

        <!-- Recent Results -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="flex items-center justify-between px-6 py-4 border-b border-gray-50">
            <h3 class="font-semibold text-gray-900">📈 Recent Results</h3>
            <a href="/student/results" class="text-sm text-indigo-600 hover:underline">View all</a>
          </div>
          <% if (completedResults.length === 0) { %>
          <div class="px-6 py-10 text-center text-gray-400">
            <p>No completed tests yet.</p>
          </div>
          <% } else { %>
          <div class="divide-y divide-gray-50">
            <% completedResults.forEach(r => { %>
            <% const pct = r.totalMarks > 0 ? ((r.score/r.totalMarks)*100).toFixed(1) : 0 %>
            <div class="flex items-center gap-4 px-6 py-4 hover:bg-gray-50 transition-colors">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-bold text-sm flex-shrink-0
                <%= pct >= 60 ? 'bg-green-500' : pct >= 40 ? 'bg-yellow-500' : 'bg-red-500' %>">
                <%= Math.round(pct) %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-medium text-gray-900 text-sm truncate"><%= r.test?.title %></p>
                <p class="text-xs text-gray-500"><%= r.score %>/<%= r.totalMarks %> marks</p>
              </div>
              <a href="/results/<%= r.id %>" class="text-sm text-indigo-600 hover:underline flex-shrink-0">View</a>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Notifications -->
      <% if (notifications.length > 0) { %>
      <div class="mt-6 bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="flex items-center justify-between px-6 py-4 border-b">
          <h3 class="font-semibold text-gray-900">🔔 New Notifications</h3>
          <a href="/student/notifications" class="text-sm text-indigo-600 hover:underline">Mark all read</a>
        </div>
        <div class="divide-y divide-gray-50">
          <% notifications.forEach(n => { %>
          <div class="flex items-start gap-4 px-6 py-4">
            <div class="w-8 h-8 rounded-full bg-<%= n.type==='exam'?'indigo':n.type==='success'?'green':n.type==='warning'?'yellow':'blue' %>-100 flex items-center justify-center flex-shrink-0">
              <span class="text-sm"><%= n.type==='exam'?'📝':n.type==='success'?'✅':n.type==='warning'?'⚠️':'ℹ️' %></span>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900"><%= n.title %></p>
              <p class="text-xs text-gray-500 mt-0.5"><%= n.message %></p>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
