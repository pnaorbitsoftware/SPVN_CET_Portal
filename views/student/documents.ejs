<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-student') %>
  <main class="lg:ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-10 bg-white/90 backdrop-blur border-b border-slate-200 px-5 lg:px-8 py-4 flex items-center gap-4">
      <button onclick="openSidebar()" class="lg:hidden text-slate-500 hover:text-slate-800"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg></button>
      <div class="flex-1"><h1 class="text-lg font-bold text-slate-900">My Documents</h1><p class="text-xs text-slate-400">Upload certificates, ID proofs, and other documents</p></div>
    </header>
    <div class="p-5 lg:p-8">
      <%- include('../partials/flash') %>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-1">
          <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-6">
            <h3 class="font-semibold text-slate-900 text-sm mb-4">Upload Document</h3>
            <form action="/student/documents" method="POST" enctype="multipart/form-data" class="space-y-4">
              <label class="block border-2 border-dashed border-slate-200 hover:border-navy-300 rounded-xl p-8 text-center cursor-pointer transition-colors group">
                <svg class="w-10 h-10 text-slate-300 group-hover:text-navy-400 mx-auto mb-3 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
                <p class="text-sm font-medium text-slate-600">Choose file to upload</p>
                <p class="text-xs text-slate-400 mt-1">PDF, JPG, PNG (max 5MB)</p>
                <input type="file" name="document" required accept=".pdf,.jpg,.jpeg,.png" class="sr-only"/>
              </label>
              <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Description</label>
                <input type="text" name="description" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm" placeholder="e.g. Birth Certificate"/>
              </div>
              <button type="submit" class="w-full bg-navy-950 text-white font-semibold py-3 rounded-xl hover:bg-navy-900 transition-colors">Upload</button>
            </form>
          </div>
        </div>
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl border border-slate-100 shadow-card overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-50"><h3 class="font-semibold text-slate-900 text-sm">Uploaded Documents (<%= docs.length %>)</h3></div>
            <% if (docs.length === 0) { %>
            <div class="py-16 text-center">
              <svg class="w-12 h-12 text-slate-200 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              <p class="text-sm text-slate-400">No documents uploaded yet.</p>
            </div>
            <% } else { %>
            <ul class="divide-y divide-slate-50">
              <% docs.forEach(doc => { %>
              <li class="flex items-center gap-4 px-6 py-4 hover:bg-slate-50 transition-colors">
                <div class="w-10 h-10 bg-navy-100 rounded-xl flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="font-medium text-slate-900 text-sm truncate"><%= doc.originalName %></p>
                  <p class="text-xs text-slate-400"><%= doc.description || doc.fileType %> &middot; <%= doc.fileSize ? Math.round(doc.fileSize/1024) + ' KB' : '' %> &middot; <%= new Date(doc.createdAt).toLocaleDateString('en-IN') %></p>
                </div>
                <a href="<%= doc.filePath %>" target="_blank" class="text-xs text-navy-600 hover:text-navy-800 font-semibold shrink-0 flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                  Download
                </a>
              </li>
              <% }) %>
            </ul>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
</body>
</html>
