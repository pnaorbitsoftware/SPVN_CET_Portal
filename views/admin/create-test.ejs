<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-admin') %>
  <main class="lg:ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-10 bg-white/90 backdrop-blur border-b border-slate-200 px-5 lg:px-8 py-4">
      <div class="flex items-center gap-3">
        <a href="/admin/tests" class="text-slate-400 hover:text-slate-600">←</a>
        <h1 class="text-lg font-bold text-slate-900">Create New Test</h1>
      </div>
    </header>
    <div class="p-5 lg:p-8 max-w-4xl mx-auto">
      <%- include('../partials/flash') %>
      <form action="/admin/tests" method="POST" enctype="multipart/form-data" class="space-y-6">

        <!-- Basic Info -->
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <h3 class="font-bold text-slate-900 mb-4">📝 Test Details</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="md:col-span-2"><label class="block text-sm font-semibold mb-1.5">Title *</label>
              <input type="text" name="title" required class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500" placeholder="e.g. CET Mock Test 1 — Physics"/></div>
            <div class="md:col-span-2"><label class="block text-sm font-semibold mb-1.5">Description</label>
              <textarea name="description" rows="2" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500"></textarea></div>
            <div><label class="block text-sm font-semibold mb-1.5">Course</label>
              <select name="course" id="courseSelect" onchange="loadSubjects(this.value)" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500">
                <option value="">Select Course</option>
                <% COURSES.forEach(c => { %><option value="<%= c %>" <%= filterCourse===c?'selected':'' %>><%= c %></option><% }) %>
              </select></div>
            <div><label class="block text-sm font-semibold mb-1.5">Subject</label>
              <select name="subject" id="subjectSelect" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500">
                <option value="">Select Subject</option>
                <% SUBJECTS.forEach(s => { %><option value="<%= s %>" <%= filterSubject===s?'selected':'' %>><%= s %></option><% }) %>
              </select></div>
            <div><label class="block text-sm font-semibold mb-1.5">Duration (minutes) *</label>
              <input type="number" name="duration" value="180" min="5" required class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500"/></div>
            <div><label class="block text-sm font-semibold mb-1.5">Negative Marking</label>
              <input type="number" name="negativeMarking" value="0.25" step="0.25" min="0" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500"/></div>
            <div><label class="block text-sm font-semibold mb-1.5">Start Time</label>
              <input type="datetime-local" name="startTime" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm"/></div>
            <div><label class="block text-sm font-semibold mb-1.5">End Time</label>
              <input type="datetime-local" name="endTime" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm"/></div>
            <div class="md:col-span-2"><label class="block text-sm font-semibold mb-1.5">Instructions</label>
              <textarea name="instructions" rows="2" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm" placeholder="Instructions for students..."></textarea></div>
          </div>
          <div class="flex flex-wrap gap-5 mt-4">
            <label class="flex items-center gap-2 cursor-pointer text-sm"><input type="checkbox" name="shuffleQuestions" value="on" checked class="rounded"/> Shuffle Questions</label>
            <label class="flex items-center gap-2 cursor-pointer text-sm"><input type="checkbox" name="shuffleOptions" value="on" class="rounded"/> Shuffle Options</label>
          </div>
        </div>

        <!-- Anti-Cheat & Proctoring Settings -->
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <h3 class="font-bold text-slate-900 mb-1 flex items-center gap-2">🔒 Anti-Cheat & Proctoring</h3>
          <p class="text-xs text-slate-500 mb-4">Control exam security behaviour. Violations are always logged regardless of these settings.</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <!-- Auto-submit on violation -->
            <div class="border border-slate-200 rounded-xl p-4">
              <div class="flex items-center justify-between mb-3">
                <div>
                  <p class="text-sm font-semibold text-slate-800">Auto-Submit on Violation</p>
                  <p class="text-xs text-slate-500 mt-0.5">Exam is force-submitted when limits are exceeded</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                  <input type="checkbox" name="autoSubmitOnViolation" value="on" id="autoSubmitToggle" onchange="toggleAutoSubmit(this.checked)" class="sr-only peer">
                  <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-red-600"></div>
                </label>
              </div>
              <div id="violationLimits" class="space-y-3 hidden">
                <div>
                  <label class="text-xs font-semibold text-slate-600 block mb-1">Max Tab Switches allowed <span class="text-red-500">*</span></label>
                  <div class="flex items-center gap-2">
                    <input type="range" name="maxTabSwitches" id="tabRange" min="1" max="10" value="3" oninput="document.getElementById('tabVal').textContent=this.value" class="flex-1 accent-red-600"/>
                    <span id="tabVal" class="text-sm font-bold text-red-600 w-6 text-center">3</span>
                  </div>
                  <p class="text-xs text-slate-400 mt-0.5">Exam auto-submits after this many tab switches</p>
                </div>
                <div>
                  <label class="text-xs font-semibold text-slate-600 block mb-1">Max Focus Losses allowed</label>
                  <div class="flex items-center gap-2">
                    <input type="range" name="maxFocusLosses" id="focusRange" min="1" max="15" value="5" oninput="document.getElementById('focusVal').textContent=this.value" class="flex-1 accent-orange-500"/>
                    <span id="focusVal" class="text-sm font-bold text-orange-600 w-6 text-center">5</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Block copy/paste & fullscreen -->
            <div class="border border-slate-200 rounded-xl p-4 space-y-3">
              <p class="text-sm font-semibold text-slate-800 mb-2">Exam Restrictions</p>
              <label class="flex items-center justify-between cursor-pointer">
                <div>
                  <p class="text-sm text-slate-700">Block Copy / Paste</p>
                  <p class="text-xs text-slate-400">Prevents Ctrl+C, Ctrl+V, right-click</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                  <input type="checkbox" name="blockCopyPaste" value="on" checked class="sr-only peer">
                  <div class="w-11 h-6 bg-slate-200 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-slate-800"></div>
                </label>
              </label>
              <label class="flex items-center justify-between cursor-pointer">
                <div>
                  <p class="text-sm text-slate-700">Require Fullscreen</p>
                  <p class="text-xs text-slate-400">Force fullscreen; exit counts as violation</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                  <input type="checkbox" name="requireFullscreen" value="on" class="sr-only peer">
                  <div class="w-11 h-6 bg-slate-200 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-slate-800"></div>
                </label>
              </label>
            </div>
          </div>
          <div class="mt-4 bg-amber-50 border border-amber-200 rounded-xl p-3 text-xs text-amber-700 flex items-start gap-2">
            <span class="text-base">⚠</span>
            <span>All violations (tab switches, focus losses, fullscreen exits) are always <strong>logged and visible</strong> to admin in the result page regardless of these settings.</span>
          </div>
        </div>

        <!-- Assign Groups -->
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <h3 class="font-bold text-slate-900 mb-4">👥 Assign to Groups</h3>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
            <% if (!groups.length) { %><p class="text-sm text-slate-400 col-span-3">No groups yet. Create groups first.</p><% } %>
            <% groups.forEach(g => { %>
            <label class="flex items-center gap-2 p-3 border border-slate-200 rounded-xl cursor-pointer hover:bg-slate-50 transition-colors">
              <input type="checkbox" name="groupIds" value="<%= g.id %>" class="rounded"/>
              <span class="text-sm font-medium text-slate-700"><%= g.name %></span>
            </label>
            <% }) %>
          </div>
        </div>

        <!-- Select Questions -->
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-bold text-slate-900">❓ Select Questions</h3>
            <span id="selCount" class="text-sm font-semibold text-green-700 bg-green-50 px-3 py-1 rounded-full">0 selected</span>
          </div>

          <!-- Subject → Topic → Subtopic cascade -->
          <div class="bg-slate-50 rounded-xl p-3 border border-slate-200 mb-3">
            <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2.5">Filter by</p>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-2.5">
              <!-- Subject -->
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1">Subject</label>
                <select id="ctSubject" onchange="onCtSubjectChange(this.value)"
                  class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-slate-900 transition-all">
                  <option value="">All Subjects</option>
                  <% SUBJECTS.forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %>
                </select>
              </div>
              <!-- Topic (AJAX) -->
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1">Topic</label>
                <select id="ctTopic" onchange="onCtTopicChange(this.value)"
                  class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-slate-900 transition-all">
                  <option value="">All Topics</option>
                </select>
              </div>
              <!-- Subtopic (AJAX) -->
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1">Subtopic</label>
                <select id="ctSubtopic" onchange="applyCtFilters()"
                  class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-slate-900 transition-all">
                  <option value="">All Subtopics</option>
                </select>
              </div>
            </div>

            <!-- Active breadcrumb + reset -->
            <div class="flex items-center justify-between mt-2.5" id="ctBreadcrumb" style="display:none!important">
              <div class="flex items-center gap-1.5 flex-wrap" id="ctBreadcrumbInner"></div>
              <button type="button" onclick="resetCtFilters()" class="text-xs text-slate-400 hover:text-slate-700 font-medium shrink-0 transition-colors">Clear filters</button>
            </div>
          </div>

          <!-- Difficulty quick filter chips + Sort -->
          <div class="flex flex-wrap gap-1.5 mb-3 items-center">
            <button type="button" onclick="filterDiff('')"  class="diff-chip active text-xs px-3 py-1 rounded-full font-semibold bg-slate-900 text-white transition-all">All</button>
            <button type="button" onclick="filterDiff('Easy')"   class="diff-chip text-xs px-3 py-1 rounded-full font-semibold bg-green-100 text-green-700 hover:bg-green-200 transition-all">Easy</button>
            <button type="button" onclick="filterDiff('Medium')" class="diff-chip text-xs px-3 py-1 rounded-full font-semibold bg-yellow-100 text-yellow-700 hover:bg-yellow-200 transition-all">Medium</button>
            <button type="button" onclick="filterDiff('Hard')"   class="diff-chip text-xs px-3 py-1 rounded-full font-semibold bg-red-100 text-red-700 hover:bg-red-200 transition-all">Hard</button>
            <div class="ml-auto flex items-center gap-2">
              <select id="ctSort" onchange="applyCtSort()" class="border border-slate-200 rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:ring-2 focus:ring-slate-900 transition-all">
                <option value="subject">Sort: Subject → Topic</option>
                <option value="difficulty">Sort: Difficulty</option>
                <option value="newest">Sort: Newest</option>
              </select>
              <input type="text" placeholder="Search questions..." id="ctSearch" onkeyup="applyCtFilters()"
                class="border border-slate-200 rounded-lg px-3 py-1.5 text-xs focus:outline-none focus:ring-2 focus:ring-slate-900 w-40 transition-all"/>
            </div>
          </div>

          <!-- Questions list -->
          <div class="border border-slate-200 rounded-xl overflow-hidden max-h-96 overflow-y-auto" id="ctQuestionList">
            <% if (!questions.length) { %>
            <p class="p-6 text-sm text-slate-400 text-center">No questions in bank. <a href="/admin/questions" class="text-navy-600 hover:underline">Add questions first →</a></p>
            <% } %>
            <% let lastSubj='', lastTopic=''; %>
            <% questions.forEach((q,i) => { %>
            <% if (q.subject !== lastSubj) { lastSubj=q.subject; lastTopic=''; %>
            <div class="q-group-header px-4 py-2 bg-blue-50 border-b border-blue-100 sticky top-0 z-[1]"
                 data-subj="<%= q.subject %>" data-topic="" data-subtopic="">
              <span class="text-xs font-bold text-blue-700 uppercase tracking-wider">📚 <%= q.subject %></span>
            </div>
            <% } %>
            <% if (q.topic && q.topic !== lastTopic) { lastTopic=q.topic; %>
            <div class="q-group-header px-5 py-1.5 bg-purple-50 border-b border-purple-100"
                 data-subj="<%= q.subject %>" data-topic="<%= q.topic %>" data-subtopic="">
              <span class="text-xs font-semibold text-purple-600">📌 <%= q.topic %></span>
              <% if (q.subtopic) { %><span class="text-purple-400 mx-1">›</span><span class="text-xs text-purple-500"><%= q.subtopic %></span><% } %>
            </div>
            <% } %>
            <label class="q-item flex items-start gap-3 p-4 border-b border-slate-100 cursor-pointer hover:bg-slate-50 transition-colors"
              data-subj="<%= q.subject %>"
              data-topic="<%= q.topic || '' %>"
              data-subtopic="<%= q.subtopic || '' %>"
              data-diff="<%= q.difficulty %>"
              data-text="<%= q.question.toLowerCase() %>" data-idx="<%= i %>">
              <input type="checkbox" name="questionIds" value="<%= q.id %>" onchange="updCount()" class="mt-0.5 rounded shrink-0"/>
              <div class="flex-1 min-w-0">
                <p class="text-sm text-slate-800 leading-snug"><%= q.question.length>120?q.question.substring(0,120)+'...':q.question %></p>
                <div class="flex flex-wrap gap-1.5 mt-1.5 items-center">
                  <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded font-medium"><%= q.subject %></span>
                  <% if (q.topic) { %><span class="text-slate-300 text-xs">›</span><span class="text-xs bg-purple-100 text-purple-700 px-2 py-0.5 rounded"><%= q.topic %></span><% } %>
                  <% if (q.subtopic) { %><span class="text-slate-300 text-xs">›</span><span class="text-xs bg-orange-100 text-orange-600 px-2 py-0.5 rounded"><%= q.subtopic %></span><% } %>
                  <span class="text-xs <%= q.difficulty==='Easy'?'bg-green-100 text-green-700':q.difficulty==='Hard'?'bg-red-100 text-red-700':'bg-yellow-100 text-yellow-700' %> px-2 py-0.5 rounded"><%= q.difficulty %></span>
                  <span class="text-xs text-slate-400 ml-auto"><%= q.marks %> mk</span>
                </div>
              </div>
            </label>
            <% }) %>
          </div>

          <!-- Select all / deselect visible -->
          <div class="flex items-center justify-between mt-3 text-xs text-slate-500">
            <button type="button" onclick="selectAllVisible()" class="hover:text-slate-900 font-medium transition-colors">✅ Select all visible</button>
            <button type="button" onclick="deselectAll()" class="hover:text-red-600 font-medium transition-colors">✕ Deselect all</button>
          </div>
        </div>

        <div class="flex gap-4">
          <button type="submit" class="flex-1 bg-navy-950 text-white font-bold py-4 rounded-xl hover:bg-navy-800 transition-colors text-base shadow-lg">Create Test</button>
          <a href="/admin/tests" class="px-8 py-4 border-2 border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50">Cancel</a>
        </div>
      </form>
    </div>
  </main>
</div>
<script>
// ── Counter ───────────────────────────────────────────────────────────────
function updCount() {
  const n = document.querySelectorAll('input[name="questionIds"]:checked').length;
  document.getElementById('selCount').textContent = n + ' selected';
}

// ── Current filter state ──────────────────────────────────────────────────
const ctState = { subject:'', topic:'', subtopic:'', diff:'', search:'' };

// ── Apply all filters ─────────────────────────────────────────────────────
function applyCtFilters() {
  ctState.subject  = document.getElementById('ctSubject').value;
  ctState.topic    = document.getElementById('ctTopic').value;
  ctState.subtopic = document.getElementById('ctSubtopic').value;
  ctState.diff     = document.querySelector('.diff-chip.active')?.dataset.diff || '';
  ctState.search   = (document.getElementById('ctSearch').value || '').toLowerCase();

  // Filter question rows
  document.querySelectorAll('.q-item').forEach(row => {
    const matchSubj    = !ctState.subject  || row.dataset.subj     === ctState.subject;
    const matchTopic   = !ctState.topic    || row.dataset.topic    === ctState.topic;
    const matchSub     = !ctState.subtopic || row.dataset.subtopic === ctState.subtopic;
    const matchDiff    = !ctState.diff     || row.dataset.diff     === ctState.diff;
    const matchSearch  = !ctState.search   || row.dataset.text.includes(ctState.search);
    row.style.display  = (matchSubj && matchTopic && matchSub && matchDiff && matchSearch) ? '' : 'none';
  });

  // Show/hide group headers — only show if they have at least one visible q-item
  document.querySelectorAll('.q-group-header').forEach(header => {
    if (!header.dataset.topic) {
      // Subject header — show if any q-item below with same subject is visible
      const subj = header.dataset.subj;
      const hasVisible = [...document.querySelectorAll('.q-item')]
        .some(r => r.dataset.subj === subj && r.style.display !== 'none');
      header.style.display = hasVisible ? '' : 'none';
    } else {
      // Topic header
      const subj  = header.dataset.subj;
      const topic = header.dataset.topic;
      const hasVisible = [...document.querySelectorAll('.q-item')]
        .some(r => r.dataset.subj === subj && r.dataset.topic === topic && r.style.display !== 'none');
      header.style.display = hasVisible ? '' : 'none';
    }
  });

  updateBreadcrumb();
}

// ── Subject change ────────────────────────────────────────────────────────
async function onCtSubjectChange(subject) {
  const tSel  = document.getElementById('ctTopic');
  const stSel = document.getElementById('ctSubtopic');
  tSel.innerHTML  = '<option value="">All Topics</option>';
  stSel.innerHTML = '<option value="">All Subtopics</option>';
  if (subject) {
    const topics = await fetchTopics(subject);
    topics.forEach(t => tSel.innerHTML += `<option value="${t.name}">${t.name}</option>`);
  }
  applyCtFilters();
}

// ── Topic change ──────────────────────────────────────────────────────────
async function onCtTopicChange(topic) {
  const stSel = document.getElementById('ctSubtopic');
  const subj  = document.getElementById('ctSubject').value;
  stSel.innerHTML = '<option value="">All Subtopics</option>';
  if (topic) {
    const subs = await fetchSubtopics(subj, topic);
    subs.forEach(s => stSel.innerHTML += `<option value="${s}">${s}</option>`);
  }
  applyCtFilters();
}

// ── Difficulty chip filter ────────────────────────────────────────────────
function filterDiff(diff) {
  document.querySelectorAll('.diff-chip').forEach(b => {
    b.classList.remove('active','bg-slate-900','text-white');
    if (!b.dataset.diff) b.dataset.diff = b.textContent.trim() === 'All' ? '' : b.textContent.trim();
  });
  event.target.classList.add('active','bg-slate-900','text-white');
  ctState.diff = diff;
  applyCtFilters();
}

// ── Reset all filters ─────────────────────────────────────────────────────
function resetCtFilters() {
  document.getElementById('ctSubject').value  = '';
  document.getElementById('ctTopic').innerHTML   = '<option value="">All Topics</option>';
  document.getElementById('ctSubtopic').innerHTML = '<option value="">All Subtopics</option>';
  document.getElementById('ctSearch').value   = '';
  document.querySelectorAll('.diff-chip').forEach(b => b.classList.remove('active','bg-slate-900','text-white'));
  document.querySelector('.diff-chip').classList.add('active','bg-slate-900','text-white');
  Object.keys(ctState).forEach(k => ctState[k] = '');
  document.querySelectorAll('.q-item,.q-group-header').forEach(r => r.style.display = '');
  updateBreadcrumb();
}

// ── Breadcrumb display ────────────────────────────────────────────────────
function updateBreadcrumb() {
  const crumb = document.getElementById('ctBreadcrumb');
  const inner = document.getElementById('ctBreadcrumbInner');
  const parts = [];
  if (ctState.subject)  parts.push(`<span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full text-xs font-semibold">${ctState.subject}</span>`);
  if (ctState.topic)    parts.push(`<span class="text-slate-400 text-xs">›</span><span class="bg-purple-100 text-purple-700 px-2 py-0.5 rounded-full text-xs font-semibold">${ctState.topic}</span>`);
  if (ctState.subtopic) parts.push(`<span class="text-slate-400 text-xs">›</span><span class="bg-orange-100 text-orange-600 px-2 py-0.5 rounded-full text-xs font-semibold">${ctState.subtopic}</span>`);
  inner.innerHTML = parts.join('');
  crumb.style.display = parts.length ? 'flex' : 'none';
}

// ── Select / Deselect helpers ─────────────────────────────────────────────
function selectAllVisible() {
  document.querySelectorAll('.q-item').forEach(row => {
    if (row.style.display !== 'none') row.querySelector('input[type="checkbox"]').checked = true;
  });
  updCount();
}

function deselectAll() {
  document.querySelectorAll('input[name="questionIds"]').forEach(cb => cb.checked = false);
  updCount();
}

// ── AJAX topic/subtopic fetchers ──────────────────────────────────────────
async function fetchTopics(subject) {
  try {
    const r = await fetch(`/admin/ajax/topics?subject=${encodeURIComponent(subject)}`);
    return await r.json();
  } catch { return []; }
}

async function fetchSubtopics(subject, topic) {
  try {
    const r = await fetch(`/admin/ajax/subtopics?subject=${encodeURIComponent(subject)}&topic=${encodeURIComponent(topic)}`);
    return await r.json();
  } catch { return []; }
}

// ── Test detail page: load subjects on course select ──────────────────────
function loadSubjects(course) {
  if (!course) return;
  fetch(`/admin/ajax/subjects/${course}`).then(r => r.json()).then(subjects => {
    const sel = document.getElementById('subjectSelect');
    sel.innerHTML = '<option value="">Select Subject</option>' + subjects.map(s => `<option value="${s}">${s}</option>`).join('');
  }).catch(() => {});
}

// ── Sort questions in the list ────────────────────────────────────────────
function applyCtSort() {
  const sort = document.getElementById('ctSort').value;
  const list = document.getElementById('ctQuestionList');

  // Collect all q-items with their checked state
  const items = [...list.querySelectorAll('.q-item')].map(el => ({
    el,
    subj: el.dataset.subj || '',
    topic: el.dataset.topic || '',
    subtopic: el.dataset.subtopic || '',
    diff: el.dataset.diff || '',
    idx: parseInt(el.dataset.idx || '0'),
  }));

  const diffOrder = { Easy: 0, Medium: 1, Hard: 2 };

  items.sort((a, b) => {
    if (sort === 'difficulty') {
      const d = (diffOrder[a.diff] ?? 9) - (diffOrder[b.diff] ?? 9);
      if (d !== 0) return d;
      return a.subj.localeCompare(b.subj) || a.topic.localeCompare(b.topic);
    } else if (sort === 'newest') {
      return b.idx - a.idx; // higher idx = newer
    } else {
      // subject → topic → subtopic
      return a.subj.localeCompare(b.subj) || a.topic.localeCompare(b.topic) || a.subtopic.localeCompare(b.subtopic);
    }
  });

  // Remove all existing headers + items; re-append sorted items with fresh headers
  list.querySelectorAll('.q-item, .q-group-header').forEach(el => el.remove());

  let lastSubj = null, lastTopic = null;
  items.forEach(({ el, subj, topic, subtopic, diff }) => {
    if (sort === 'subject') {
      if (subj !== lastSubj) {
        lastSubj = subj; lastTopic = null;
        const sh = document.createElement('div');
        sh.className = 'q-group-header px-4 py-2 bg-blue-50 border-b border-blue-100 sticky top-0 z-[1]';
        sh.dataset.subj = subj; sh.dataset.topic = ''; sh.dataset.subtopic = '';
        sh.innerHTML = '<span class="text-xs font-bold text-blue-700 uppercase tracking-wider">📚 ' + (subj || 'No Subject') + '</span>';
        list.appendChild(sh);
      }
      if (topic && topic !== lastTopic) {
        lastTopic = topic;
        const th = document.createElement('div');
        th.className = 'q-group-header px-5 py-1.5 bg-purple-50 border-b border-purple-100';
        th.dataset.subj = subj; th.dataset.topic = topic; th.dataset.subtopic = '';
        th.innerHTML = '<span class="text-xs font-semibold text-purple-600">📌 ' + topic + '</span>' +
          (subtopic ? '<span class="text-purple-400 mx-1">›</span><span class="text-xs text-purple-500">' + subtopic + '</span>' : '');
        list.appendChild(th);
      }
    } else if (sort === 'difficulty') {
      if (diff !== lastSubj) { // reuse lastSubj for diff grouping
        lastSubj = diff;
        const dh = document.createElement('div');
        const colors = { Easy: 'bg-green-50 border-green-100 text-green-700', Medium: 'bg-yellow-50 border-yellow-100 text-yellow-700', Hard: 'bg-red-50 border-red-100 text-red-700' };
        const cls = colors[diff] || 'bg-slate-50 border-slate-100 text-slate-600';
        dh.className = 'q-group-header px-4 py-2 border-b sticky top-0 z-[1] ' + cls;
        dh.dataset.subj = ''; dh.dataset.topic = ''; dh.dataset.subtopic = '';
        dh.innerHTML = '<span class="text-xs font-bold uppercase tracking-wider">' + (diff || 'No Difficulty') + '</span>';
        list.appendChild(dh);
      }
    }
    list.appendChild(el);
  });

  // Re-apply current filters so visibility is correct
  applyCtFilters();
}

// Set data-diff on diff chips on load
document.querySelectorAll('.diff-chip').forEach(b => {
  const t = b.textContent.trim();
  b.dataset.diff = t === 'All' ? '' : t;
});
</script>

<script>
function toggleAutoSubmit(checked) {
  const limits = document.getElementById('violationLimits');
  if (checked) limits.classList.remove('hidden');
  else limits.classList.add('hidden');
}
</script>
</body></html>
