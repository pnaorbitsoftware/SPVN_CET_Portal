<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-admin') %>
  <main class="lg:ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-10 bg-white/90 backdrop-blur border-b border-slate-200 px-5 lg:px-8 py-4 flex items-center gap-4">
      <button onclick="openSidebar()" class="lg:hidden text-slate-500 hover:text-slate-800">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <div>
        <h1 class="text-lg font-bold text-slate-900">Subjects</h1>
        <p class="text-xs text-slate-400"><%= subjects.length %> subjects configured</p>
      </div>
    </header>

    <div class="p-5 lg:p-8">
      <%- include('../partials/flash') %>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Add Subject -->
        <div class="lg:col-span-1 space-y-4">
          <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-6">
            <h3 class="font-semibold text-slate-900 text-sm mb-4">Add New Subject</h3>
            <form action="/admin/subjects" method="POST" class="space-y-3">
              <input type="text" name="name" required placeholder="e.g. Computer Science"
                class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm"/>
              <button type="submit" class="w-full bg-navy-950 hover:bg-navy-900 text-white font-semibold py-2.5 rounded-xl text-sm transition-colors flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                Add Subject
              </button>
            </form>
          </div>

          <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
            <div class="flex items-start gap-2.5">
              <svg class="w-4 h-4 text-amber-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              <div>
                <p class="text-xs font-semibold text-amber-800 mb-0.5">Note</p>
                <p class="text-xs text-amber-700 leading-relaxed">Subjects with existing questions cannot be deleted. Remove questions first.</p>
              </div>
            </div>
          </div>

          <!-- Stats mini cards -->
          <div class="grid grid-cols-2 gap-3">
            <% subjects.slice(0,4).forEach(subject => { %>
            <a href="/admin/questions?subject=<%= encodeURIComponent(subject) %>"
              class="bg-white rounded-xl border border-slate-100 shadow-card p-3.5 hover:border-navy-200 transition-colors">
              <p class="text-xs font-semibold text-slate-600 truncate mb-1"><%= subject %></p>
              <p class="text-xl font-bold text-navy-700"><%= subjectStats[subject] || 0 %></p>
              <p class="text-[10px] text-slate-400">questions</p>
            </a>
            <% }) %>
          </div>
        </div>

        <!-- Subject list -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl border border-slate-100 shadow-card overflow-hidden">
            <div class="flex items-center justify-between px-6 py-4 border-b border-slate-50">
              <h3 class="font-semibold text-slate-900 text-sm">All Subjects (<%= subjects.length %>)</h3>
              <a href="/admin/questions" class="text-xs text-navy-600 hover:text-navy-800 font-medium flex items-center gap-1">
                Question Bank <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
            <% if (subjects.length === 0) { %>
            <div class="py-16 text-center">
              <svg class="w-12 h-12 text-slate-200 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
              <p class="text-sm text-slate-400">No subjects yet. Add your first subject.</p>
            </div>
            <% } else { %>
            <ul class="divide-y divide-slate-50">
              <% subjects.forEach(subject => { %>
              <li class="flex items-center gap-4 px-6 py-4 hover:bg-slate-50 transition-colors">
                <div class="w-9 h-9 rounded-xl bg-navy-100 flex items-center justify-center text-navy-700 font-bold text-sm shrink-0">
                  <%= subject.charAt(0) %>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="font-medium text-slate-900 text-sm"><%= subject %></p>
                  <p class="text-xs text-slate-400"><%= subjectStats[subject] || 0 %> question(s)</p>
                </div>
                <div class="flex items-center gap-3 shrink-0">
                  <a href="/admin/questions?subject=<%= encodeURIComponent(subject) %>" class="text-xs text-navy-600 hover:text-navy-800 font-medium">Questions</a>
                  <a href="/admin/tests/create?subject=<%= encodeURIComponent(subject) %>" class="text-xs text-emerald-600 hover:text-emerald-800 font-medium">Create Test</a>
                  <% if ((subjectStats[subject] || 0) === 0) { %>
                  <form action="/admin/subjects/delete" method="POST" onsubmit="return confirm('Delete &quot;<%= subject %>&quot;?')">
                    <input type="hidden" name="name" value="<%= subject %>">
                    <button type="submit" class="text-xs text-rose-500 hover:text-rose-700 font-medium">Delete</button>
                  </form>
                  <% } else { %>
                  <span class="text-xs text-slate-300">Delete</span>
                  <% } %>
                </div>
              </li>
              <% }) %>
            </ul>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
</body>
</html>
