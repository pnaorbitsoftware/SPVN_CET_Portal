<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-admin') %>
  <main class="ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-20 bg-white border-b border-gray-200 px-8 py-4">
      <h1 class="text-xl font-bold text-gray-900">Manage Teachers</h1>
    </header>
    <div class="p-8">
      <%- include('../partials/flash') %>
      <div class="mb-6">
        <button onclick="document.getElementById('addModal').classList.remove('hidden')"
          class="flex items-center gap-2 bg-emerald-700 text-white px-5 py-2.5 rounded-xl font-medium hover:bg-emerald-800 transition-colors shadow-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add Teacher
        </button>
      </div>
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-50">
          <h3 class="font-semibold text-gray-900">All Teachers (<%= teachers.length %>)</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-600 uppercase text-xs tracking-wider">
              <tr>
                <th class="px-6 py-3 text-left">#</th>
                <th class="px-6 py-3 text-left">Name</th>
                <th class="px-6 py-3 text-left">Email</th>
                <th class="px-6 py-3 text-left">Subject</th>
                <th class="px-6 py-3 text-left">Status</th>
                <th class="px-6 py-3 text-left">Joined</th>
                <th class="px-6 py-3 text-left">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
              <% teachers.forEach((t, i) => { %>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-6 py-4 text-gray-400"><%= i + 1 %></td>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-700 font-bold text-xs">
                      <%= t.name.charAt(0).toUpperCase() %>
                    </div>
                    <span class="font-medium text-gray-900"><%= t.name %></span>
                  </div>
                </td>
                <td class="px-6 py-4 text-gray-500"><%= t.email %></td>
                <td class="px-6 py-4 text-gray-600"><%= t.subject || '—' %></td>
                <td class="px-6 py-4">
                  <span class="<%= t.isActive ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %> text-xs px-2.5 py-1 rounded-full font-medium">
                    <%= t.isActive ? 'Active' : 'Inactive' %>
                  </span>
                </td>
                <td class="px-6 py-4 text-gray-400"><%= new Date(t.createdAt).toLocaleDateString('en-IN') %></td>
                <td class="px-6 py-4">
                  <form action="/admin/teachers/<%= t.id %>?_method=DELETE" method="POST"
                    onsubmit="return confirm('Deactivate this teacher?')">
                    <input type="hidden" name="_method" value="DELETE">
                    <button type="submit" class="text-xs text-red-500 hover:text-red-700 font-medium">Deactivate</button>
                  </form>
                </td>
              </tr>
              <% }) %>
              <% if (teachers.length === 0) { %>
              <tr><td colspan="7" class="px-6 py-12 text-center text-gray-400">No teachers yet. Add your first teacher!</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Add Teacher Modal -->
<div id="addModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md">
    <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
      <h3 class="font-bold text-lg text-gray-900">Add New Teacher</h3>
      <button onclick="document.getElementById('addModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-xl">✕</button>
    </div>
    <form action="/admin/teachers" method="POST" class="p-6 space-y-4">
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Full Name *</label>
        <input type="text" name="name" required class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" placeholder="Teacher full name" />
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address *</label>
        <input type="email" name="email" required class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" placeholder="teacher@xyzcollege.edu.in" />
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Subject Specialization</label>
        <select name="subject" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
          <option value="">Select subject</option>
          <% ['Physics','Chemistry','Mathematics','Biology','English','General Knowledge'].forEach(s => { %>
          <option value="<%= s %>"><%= s %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Phone</label>
        <input type="text" name="phone" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" placeholder="Phone number" />
      </div>
      <div class="bg-emerald-50 rounded-xl p-3 text-xs text-emerald-700">
        💡 Default password will be auto-generated as <strong>Teacher@Name1234</strong>
      </div>
      <div class="flex gap-3">
        <button type="submit" class="flex-1 bg-emerald-700 text-white font-semibold py-3 rounded-xl hover:bg-emerald-800 transition-colors">Create Teacher</button>
        <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="flex-1 border border-gray-200 text-gray-700 font-semibold py-3 rounded-xl hover:bg-gray-50 transition-colors">Cancel</button>
      </div>
    </form>
  </div>
</div>
</body>
</html>
