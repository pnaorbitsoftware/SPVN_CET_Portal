<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-admin') %>
  <main class="ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-20 bg-white border-b border-gray-200 px-8 py-4 flex items-center justify-between">
      <div>
        <h1 class="text-xl font-bold text-gray-900">Admin Dashboard</h1>
        <p class="text-sm text-gray-500"><%= process.env.COLLEGE_NAME %> · AY <%= process.env.ACADEMIC_YEAR %></p>
      </div>
      <span class="text-sm text-gray-500"><%= new Date().toLocaleDateString('en-IN', {weekday:'long',year:'numeric',month:'long',day:'numeric'}) %></span>
    </header>
    <div class="p-8">
      <%- include('../partials/flash') %>

      <!-- Stats -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <% [
          {label:'Total Students', value: stats.studentCount,  icon:'👨‍🎓', color:'blue',   link:'/admin/students'},
          {label:'Total Tests',    value: stats.testCount,     icon:'📝',   color:'purple', link:'/admin/tests'},
          {label:'Questions',      value: stats.questionCount, icon:'❓',   color:'green',  link:'/admin/questions'},
          {label:'Active Groups',  value: stats.groupCount,    icon:'👥',   color:'orange', link:'/admin/groups'},
        ].forEach(card => { %>
        <a href="<%= card.link %>" class="card-hover bg-white rounded-2xl p-6 border border-gray-100 shadow-sm block">
          <div class="flex items-center justify-between mb-4">
            <span class="text-3xl"><%= card.icon %></span>
            <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-<%= card.color %>-100 text-<%= card.color %>-700">View</span>
          </div>
          <p class="text-3xl font-bold text-gray-900"><%= card.value %></p>
          <p class="text-sm text-gray-500 mt-1"><%= card.label %></p>
        </a>
        <% }) %>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Recent Results -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="flex items-center justify-between px-6 py-4 border-b border-gray-50">
            <h3 class="font-semibold text-gray-900">Recent Results</h3>
            <a href="/admin/results" class="text-sm text-primary-600 hover:underline">View all</a>
          </div>
          <div class="divide-y divide-gray-50">
            <% if (!recentResults || recentResults.length === 0) { %>
            <p class="px-6 py-8 text-sm text-gray-400 text-center">No results yet.</p>
            <% } else { recentResults.forEach(r => { %>
            <div class="flex items-center gap-4 px-6 py-3.5 hover:bg-gray-50 transition-colors">
              <div class="w-9 h-9 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 font-bold text-sm flex-shrink-0">
                <%= r.student ? r.student.name.charAt(0) : '?' %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate"><%= r.student?.name %></p>
                <p class="text-xs text-gray-500 truncate"><%= r.test?.title %></p>
              </div>
              <div class="text-right">
                <p class="text-sm font-bold text-gray-900"><%= r.score %>/<%= r.totalMarks %></p>
                <p class="text-xs text-gray-400"><%= new Date(r.createdAt).toLocaleDateString('en-IN') %></p>
              </div>
            </div>
            <% }) } %>
          </div>
        </div>

        <!-- Recent Students -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="flex items-center justify-between px-6 py-4 border-b border-gray-50">
            <h3 class="font-semibold text-gray-900">Recently Added Students</h3>
            <a href="/admin/students" class="text-sm text-primary-600 hover:underline">View all</a>
          </div>
          <div class="divide-y divide-gray-50">
            <% if (!recentUsers || recentUsers.length === 0) { %>
            <p class="px-6 py-8 text-sm text-gray-400 text-center">No students yet.</p>
            <% } else { recentUsers.forEach(u => { %>
            <div class="flex items-center gap-4 px-6 py-3.5 hover:bg-gray-50 transition-colors">
              <div class="w-9 h-9 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 font-bold text-sm flex-shrink-0">
                <%= u.name.charAt(0).toUpperCase() %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate"><%= u.name %></p>
                <p class="text-xs text-gray-500"><%= u.rollNo || u.email || '—' %></p>
              </div>
              <span class="text-xs px-2.5 py-1 rounded-full font-medium bg-indigo-100 text-indigo-700">Student</span>
            </div>
            <% }) } %>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="mt-6 bg-gradient-to-r from-primary-800 to-indigo-800 rounded-2xl p-6 text-white">
        <h3 class="font-bold text-lg mb-4">Quick Actions</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
          <% [
            {href:'/admin/subjects',   label:'Manage Subjects', icon:'📚'},
            {href:'/admin/students',   label:'Add Student',     icon:'👨‍🎓'},
            {href:'/admin/tests/create',label:'Create Test',    icon:'📝'},
            {href:'/admin/results',    label:'View Reports',    icon:'📊'},
          ].forEach(a => { %>
          <a href="<%= a.href %>" class="bg-white/10 hover:bg-white/20 rounded-xl p-4 text-center transition-colors backdrop-blur-sm">
            <div class="text-2xl mb-1"><%= a.icon %></div>
            <p class="text-sm font-medium"><%= a.label %></p>
          </a>
          <% }) %>
        </div>
      </div>
    </div>
  </main>
</div>
</body>
</html>
