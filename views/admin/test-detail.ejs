<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-admin') %>
  <main class="lg:ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-10 bg-white/90 backdrop-blur border-b border-slate-200 px-5 lg:px-8 py-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/admin/tests" class="text-slate-400 hover:text-slate-600">←</a>
          <div>
            <h1 class="text-lg font-bold text-slate-900"><%= test.title %></h1>
            <p class="text-sm text-slate-500"><%= test.duration %> mins · <%= test.totalMarks %> marks<% if(test.course){%> · <%= test.course %><% } %><% if(test.subject){%> / <%= test.subject %><% } %></p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-xs px-3 py-1.5 rounded-full font-semibold
            <%= test.status==='published'?'bg-green-100 text-green-700':test.status==='draft'?'bg-slate-100 text-slate-600':'bg-blue-100 text-blue-700' %>">
            <%= test.status.toUpperCase() %>
          </span>
          <% if(test.status==='draft') { %>
          <form action="/admin/tests/<%= test.id %>/publish" method="POST">
            <button class="bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-green-700">Publish</button>
          </form>
          <% } %>
          <a href="/results/leaderboard/<%= test.id %>" class="bg-navy-950 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-navy-800">Leaderboard</a>
        </div>
      </div>
    </header>
    <div class="p-5 lg:p-8">
      <%- include('../partials/flash') %>
      <!-- Stats -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <% [{icon:'❓',label:'Questions',val:test.questions.length},{icon:'⏱',label:'Duration',val:test.duration+' min'},{icon:'👨‍🎓',label:'Attempts',val:results.length},{icon:'📊',label:'Avg Score',val:results.length?(results.reduce((s,r)=>s+r.score,0)/results.length).toFixed(1)+'/'+test.totalMarks:'N/A'}].forEach(c=>{ %>
        <div class="bg-white rounded-xl border border-slate-200 p-4 shadow-sm">
          <p class="text-xl mb-2"><%= c.icon %></p>
          <p class="text-xl font-bold text-slate-900"><%= c.val %></p>
          <p class="text-xs text-slate-500 mt-0.5"><%= c.label %></p>
        </div>
        <% }) %>
      </div>

      <!-- Anti-cheat settings badge row -->
      <div class="flex flex-wrap gap-3 mb-6">
        <div class="flex items-center gap-2 bg-white border border-slate-200 rounded-xl px-4 py-2.5 text-sm shadow-sm">
          <span class="text-base">🔒</span>
          <span class="text-slate-600 font-medium">Auto-Submit on Violation:</span>
          <% if (test.autoSubmitOnViolation) { %>
          <span class="bg-red-100 text-red-700 font-semibold px-2 py-0.5 rounded-full text-xs">ON — after <%= test.maxTabSwitches || 3 %> tab switches</span>
          <% } else { %>
          <span class="bg-slate-100 text-slate-500 font-semibold px-2 py-0.5 rounded-full text-xs">OFF (log only)</span>
          <% } %>
        </div>
        <div class="flex items-center gap-2 bg-white border border-slate-200 rounded-xl px-4 py-2.5 text-sm shadow-sm">
          <span class="text-base"><%= test.blockCopyPaste !== false ? '🚫' : '✅' %></span>
          <span class="text-slate-600"><%= test.blockCopyPaste !== false ? 'Copy/Paste Blocked' : 'Copy/Paste Allowed' %></span>
        </div>
        <div class="flex items-center gap-2 bg-white border border-slate-200 rounded-xl px-4 py-2.5 text-sm shadow-sm">
          <span class="text-base"><%= test.requireFullscreen ? '🖥' : '📱' %></span>
          <span class="text-slate-600"><%= test.requireFullscreen ? 'Fullscreen Required' : 'Fullscreen Optional' %></span>
        </div>
        <div class="flex items-center gap-2 bg-white border border-slate-200 rounded-xl px-4 py-2.5 text-sm shadow-sm">
          <span class="text-base">⚠</span>
          <span class="text-slate-600">Max Tab Switches: <strong class="text-red-600"><%= test.maxTabSwitches || 3 %></strong></span>
        </div>
        <div class="flex items-center gap-2 bg-white border border-slate-200 rounded-xl px-4 py-2.5 text-sm shadow-sm">
          <span class="text-base">👁</span>
          <span class="text-slate-600">Max Focus Losses: <strong class="text-orange-600"><%= test.maxFocusLosses || 5 %></strong></span>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Questions list -->
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-5 py-4 border-b bg-slate-50"><h3 class="font-semibold text-slate-900 text-sm">Questions (<%= test.questions.length %>)</h3></div>
          <div class="divide-y divide-slate-100 max-h-96 overflow-y-auto">
            <% test.questions.forEach((q,i) => { %>
            <div class="px-5 py-3 hover:bg-slate-50">
              <p class="text-xs text-slate-800 leading-snug"><%= i+1 %>. <%= q.question.length>80?q.question.substring(0,80)+'...':q.question %></p>
              <div class="flex gap-2 mt-1">
                <span class="text-xs bg-green-100 text-green-700 px-1.5 py-0.5 rounded">Ans: <%= q.correctAnswer %></span>
                <span class="text-xs text-slate-400"><%= q.subject %></span>
              </div>
            </div>
            <% }) %>
          </div>
        </div>

        <!-- Results -->
        <div class="lg:col-span-2 bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-6 py-4 border-b flex items-center justify-between">
            <h3 class="font-semibold text-slate-900">Student Results</h3>
            <a href="/admin/results/export" class="text-xs text-navy-600 hover:underline font-medium">Export Excel</a>
          </div>
          <% if (!results.length) { %>
          <p class="px-6 py-12 text-center text-slate-400">No submissions yet.</p>
          <% } else { %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-slate-50 text-xs text-slate-500 uppercase tracking-wider">
                <tr><th class="px-5 py-3 text-left">Rank</th><th class="px-5 py-3 text-left">Student</th><th class="px-5 py-3 text-left">Score</th><th class="px-5 py-3 text-left">%</th><th class="px-5 py-3 text-left">Action</th></tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <% results.forEach((r,i) => { const pct=((r.score/r.totalMarks)*100).toFixed(1) %>
                <tr class="hover:bg-slate-50">
                  <td class="px-5 py-3"><%= i===0?'🥇':i===1?'🥈':i===2?'🥉':'#'+(i+1) %></td>
                  <td class="px-5 py-3"><p class="font-medium"><%= r.student?.name %></p><p class="text-xs text-slate-400"><%= r.student?.rollNo %></p></td>
                  <td class="px-5 py-3 font-bold"><%= r.score %>/<%= r.totalMarks %></td>
                  <td class="px-5 py-3 font-semibold <%= pct>=60?'text-green-600':pct>=40?'text-yellow-600':'text-red-500' %>"><%= pct %>%</td>
                  <td class="px-5 py-3"><a href="/results/<%= r.id %>" class="text-navy-600 hover:underline text-xs font-medium">View</a></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>
</div>
</body></html>
