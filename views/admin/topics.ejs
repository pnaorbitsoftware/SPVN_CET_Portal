<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-admin') %>
  <main class="lg:ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-10 bg-white/90 backdrop-blur border-b border-slate-200 px-5 lg:px-8 py-4 flex items-center gap-4">
      <button onclick="openSidebar()" class="lg:hidden text-slate-500 hover:text-slate-800"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg></button>
      <div class="flex-1"><h1 class="text-lg font-bold text-slate-900">Content Management</h1><p class="text-xs text-slate-400">Course → Subject → Topic → Subtopic hierarchy</p></div>
      <button onclick="document.getElementById('addTopicModal').classList.remove('hidden')"
        class="flex items-center gap-1.5 bg-navy-950 text-white px-4 py-2.5 rounded-xl text-sm font-medium hover:bg-navy-900 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        Add Topic
      </button>
    </header>
    <div class="p-5 lg:p-8">
      <%- include('../partials/flash') %>

      <!-- Filter bar -->
      <form method="GET" action="/admin/topics" class="flex flex-wrap gap-3 mb-6">
        <select name="course" onchange="this.form.submit()" class="border border-slate-200 rounded-xl px-4 py-2.5 text-sm bg-white min-w-[140px]">
          <option value="">All Courses</option>
          <% COURSES.forEach(c => { %><option value="<%= c %>" <%= filterCourse===c?'selected':'' %>><%= c %></option><% }) %>
        </select>
        <select name="subject" onchange="this.form.submit()" class="border border-slate-200 rounded-xl px-4 py-2.5 text-sm bg-white min-w-[160px]">
          <option value="">All Subjects</option>
          <% SUBJECTS.forEach(s => { %><option value="<%= s %>" <%= filterSubject===s?'selected':'' %>><%= s %></option><% }) %>
        </select>
        <% if (filterCourse || filterSubject) { %>
        <a href="/admin/topics" class="border border-slate-200 rounded-xl px-4 py-2.5 text-sm text-slate-600 hover:bg-slate-50">Clear</a>
        <% } %>
      </form>

      <!-- Course overview cards -->
      <% if (!filterCourse && !filterSubject) { %>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <% COURSES.forEach(course => { %>
        <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-5">
          <div class="w-10 h-10 bg-navy-100 rounded-xl flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
          <h3 class="font-bold text-slate-900 mb-2"><%= course %></h3>
          <div class="flex flex-wrap gap-1.5 mb-3">
            <% (SUBJECTS_BY_COURSE || {JEE:['Physics','Chemistry','Mathematics'],CET:['Physics','Chemistry','Mathematics','Biology'],NEET:['Physics','Chemistry','Biology']})[course].forEach(subj => { %>
            <a href="/admin/topics?course=<%= course %>&subject=<%= encodeURIComponent(subj) %>"
              class="text-[11px] font-medium bg-slate-100 hover:bg-navy-100 text-slate-600 hover:text-navy-700 px-2.5 py-1 rounded-lg transition-colors"><%= subj %></a>
            <% }) %>
          </div>
          <a href="/admin/topics?course=<%= course %>" class="text-xs text-navy-600 hover:underline font-medium">View all topics →</a>
        </div>
        <% }) %>
      </div>
      <% } %>

      <!-- Topics table -->
      <div class="bg-white rounded-2xl border border-slate-100 shadow-card overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-50">
          <h3 class="font-semibold text-slate-900 text-sm">
            Topics <% if(filterCourse || filterSubject) { %> — <span class="text-navy-600"><%= [filterCourse, filterSubject].filter(Boolean).join(' / ') %></span><% } %>
            (<%= topics.length %>)
          </h3>
        </div>
        <% if (topics.length === 0) { %>
        <div class="py-16 text-center">
          <svg class="w-12 h-12 text-slate-200 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          <p class="text-sm text-slate-400">No topics yet. Add your first topic.</p>
        </div>
        <% } else { %>
        <ul class="divide-y divide-slate-50">
          <% topics.forEach(topic => { %>
          <li class="px-6 py-4 hover:bg-slate-50 transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2.5 mb-1.5">
                  <span class="text-[11px] font-semibold bg-navy-100 text-navy-700 px-2.5 py-0.5 rounded-full"><%= topic.course %></span>
                  <span class="text-[11px] font-semibold bg-slate-100 text-slate-600 px-2.5 py-0.5 rounded-full"><%= topic.subject %></span>
                </div>
                <p class="font-semibold text-slate-900 text-sm"><%= topic.name %></p>
                <% if (topic.subtopics && topic.subtopics.length > 0) { %>
                <div class="flex flex-wrap gap-1.5 mt-2">
                  <% topic.subtopics.forEach(sub => { %>
                  <span class="text-[11px] bg-amber-50 text-amber-700 border border-amber-200 px-2 py-0.5 rounded-md"><%= sub %></span>
                  <% }) %>
                </div>
                <% } %>
              </div>
              <div class="flex items-center gap-3 shrink-0">
                <button onclick="openEdit('<%= topic.id %>', '<%= topic.name.replace(/'/g, `\\'`) %>', '<%= (topic.subtopics||[]).join('\\n').replace(/'/g, `\\'`) %>')"
                  class="text-xs text-navy-600 hover:text-navy-800 font-medium">Edit</button>
                <form action="/admin/topics/<%= topic.id %>/delete" method="POST" onsubmit="return confirm('Delete this topic?')">
                  <button type="submit" class="text-xs text-rose-500 hover:text-rose-700 font-medium">Delete</button>
                </form>
              </div>
            </div>
          </li>
          <% }) %>
        </ul>
        <% } %>
      </div>
    </div>
  </main>
</div>

<!-- Add Topic Modal -->
<div id="addTopicModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4">
  <div class="bg-white rounded-t-3xl sm:rounded-2xl shadow-2xl w-full sm:max-w-lg">
    <div class="flex items-center justify-between px-6 py-5 border-b border-slate-100">
      <h3 class="font-bold text-slate-900">Add New Topic</h3>
      <button onclick="document.getElementById('addTopicModal').classList.add('hidden')" class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 hover:bg-slate-200"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
    </div>
    <form action="/admin/topics" method="POST" class="p-6 space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Course *</label>
          <select name="course" required id="topicCourse" onchange="loadSubjectsForCourse(this.value)" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm bg-white">
            <option value="">Select course</option>
            <% COURSES.forEach(c => { %><option value="<%= c %>"><%= c %></option><% }) %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Subject *</label>
          <select name="subject" required id="topicSubject" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm bg-white">
            <option value="">Select course first</option>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Topic Name *</label>
        <input type="text" name="name" required class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm" placeholder="e.g. Kinematics"/>
      </div>
      <div>
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Subtopics <span class="text-slate-400 normal-case">(one per line)</span></label>
        <textarea name="subtopics" rows="4" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm" placeholder="e.g.&#10;Uniform Motion&#10;Projectile Motion&#10;Relative Velocity"></textarea>
      </div>
      <div class="flex gap-3 pt-1">
        <button type="submit" class="flex-1 bg-navy-950 text-white font-semibold py-3 rounded-xl hover:bg-navy-900 transition-colors">Add Topic</button>
        <button type="button" onclick="document.getElementById('addTopicModal').classList.add('hidden')" class="flex-1 border border-slate-200 text-slate-700 font-semibold py-3 rounded-xl hover:bg-slate-50 transition-colors">Cancel</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Topic Modal -->
<div id="editTopicModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4">
  <div class="bg-white rounded-t-3xl sm:rounded-2xl shadow-2xl w-full sm:max-w-lg">
    <div class="flex items-center justify-between px-6 py-5 border-b border-slate-100">
      <h3 class="font-bold text-slate-900">Edit Topic</h3>
      <button onclick="document.getElementById('editTopicModal').classList.add('hidden')" class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 hover:bg-slate-200"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
    </div>
    <form id="editTopicForm" action="" method="POST" class="p-6 space-y-4">
      <div>
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Topic Name *</label>
        <input type="text" name="name" id="editTopicName" required class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm"/>
      </div>
      <div>
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Subtopics <span class="text-slate-400 normal-case">(one per line)</span></label>
        <textarea name="subtopics" id="editTopicSubtopics" rows="5" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm"></textarea>
      </div>
      <div class="flex gap-3 pt-1">
        <button type="submit" class="flex-1 bg-navy-950 text-white font-semibold py-3 rounded-xl hover:bg-navy-900 transition-colors">Save Changes</button>
        <button type="button" onclick="document.getElementById('editTopicModal').classList.add('hidden')" class="flex-1 border border-slate-200 text-slate-700 font-semibold py-3 rounded-xl hover:bg-slate-50 transition-colors">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
function openEdit(id, name, subtopics) {
  document.getElementById('editTopicName').value = name;
  document.getElementById('editTopicSubtopics').value = subtopics;
  document.getElementById('editTopicForm').action = '/admin/topics/' + id;
  document.getElementById('editTopicModal').classList.remove('hidden');
}
async function loadSubjectsForCourse(course) {
  const sel = document.getElementById('topicSubject');
  sel.innerHTML = '<option value="">Loading...</option>';
  if (!course) { sel.innerHTML = '<option value="">Select course first</option>'; return; }
  try {
    const subjects = await fetch('/admin/ajax/subjects/' + course).then(r => r.json());
    sel.innerHTML = '<option value="">Select subject</option>' + subjects.map(s => `<option value="${s}">${s}</option>`).join('');
  } catch { sel.innerHTML = '<option value="">Error loading</option>'; }
}
</script>
</body>
</html>
