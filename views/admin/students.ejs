<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-admin') %>
  <main class="lg:ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-10 bg-white/90 backdrop-blur border-b border-slate-200 px-5 lg:px-8 py-4 flex items-center gap-4">
      <button onclick="openSidebar()" class="lg:hidden text-slate-500 hover:text-slate-800">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <div class="flex-1">
        <h1 class="text-lg font-bold text-slate-900">Students</h1>
        <p class="text-xs text-slate-400"><%= students.length %> total enrolled</p>
      </div>
      <div class="flex items-center gap-2.5">
        <button onclick="document.getElementById('importModal').classList.remove('hidden')"
          class="flex items-center gap-1.5 border border-slate-200 text-slate-700 px-4 py-2.5 rounded-xl text-sm font-medium hover:bg-slate-50 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
          <span class="hidden sm:inline">Import</span>
        </button>
        <button onclick="document.getElementById('addModal').classList.remove('hidden')"
          class="flex items-center gap-1.5 bg-navy-950 text-white px-4 py-2.5 rounded-xl text-sm font-medium hover:bg-navy-900 transition-colors shadow-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
          <span class="hidden sm:inline">Add Student</span>
        </button>
      </div>
    </header>

    <div class="p-5 lg:p-8">
      <%- include('../partials/flash') %>
      <div class="bg-white rounded-2xl border border-slate-100 shadow-card overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-50 flex items-center gap-4">
          <div class="relative flex-1 max-w-xs">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35"/></svg>
            <input type="text" placeholder="Search students…" onkeyup="filterTable(this.value)"
              class="w-full border border-slate-200 rounded-xl pl-9 pr-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-200 focus:border-navy-400"/>
          </div>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm" id="studentsTable">
            <thead class="bg-slate-50">
              <tr>
                <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">#</th>
                <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Student</th>
                <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Roll No</th>
                <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider hidden md:table-cell">Email</th>
                <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Status</th>
                <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider hidden lg:table-cell">Joined</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              <% students.forEach((s, i) => { %>
              <tr class="hover:bg-slate-50 transition-colors student-row">
                <td class="px-6 py-4 text-slate-400 text-xs"><%= i + 1 %></td>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-navy-100 flex items-center justify-center text-navy-700 font-bold text-xs shrink-0">
                      <%= s.name.charAt(0).toUpperCase() %>
                    </div>
                    <span class="font-medium text-slate-900"><%= s.name %></span>
                  </div>
                </td>
                <td class="px-6 py-4 font-mono text-slate-600 text-xs"><%= s.rollNo %></td>
                <td class="px-6 py-4 text-slate-500 hidden md:table-cell"><%= s.email || '—' %></td>
                <td class="px-6 py-4">
                  <span class="<%= s.isFirstLogin ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700' %> text-[11px] font-semibold px-2.5 py-1 rounded-full">
                    <%= s.isFirstLogin ? 'First Login' : 'Active' %>
                  </span>
                </td>
                <td class="px-6 py-4 text-slate-400 text-xs hidden lg:table-cell"><%= new Date(s.createdAt).toLocaleDateString('en-IN') %></td>
              </tr>
              <% }) %>
              <% if (students.length === 0) { %>
              <tr><td colspan="6" class="px-6 py-16 text-center text-slate-400">
                <svg class="w-12 h-12 mx-auto mb-3 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20H3v-1a6 6 0 0114 0v1zm7 0h-3v-1a4.5 4.5 0 00-3.21-4.3M15 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                No students yet. Add your first student.
              </td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Add Student Modal -->
<div id="addModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4">
  <div class="bg-white rounded-t-3xl sm:rounded-2xl shadow-2xl w-full sm:max-w-lg">
    <div class="flex items-center justify-between px-6 py-5 border-b border-slate-100">
      <h3 class="font-bold text-slate-900">Add New Student</h3>
      <button onclick="document.getElementById('addModal').classList.add('hidden')" class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 hover:bg-slate-200">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form action="/admin/students" method="POST" class="p-6 space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div class="col-span-2">
          <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Full Name *</label>
          <input type="text" name="name" required class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm" placeholder="Student full name"/>
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Roll Number *</label>
          <input type="text" name="rollNo" required class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm" placeholder="2024CE001"/>
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Phone</label>
          <input type="text" name="phone" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm" placeholder="Phone number"/>
        </div>
        <div class="col-span-2">
          <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Email</label>
          <input type="email" name="email" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm" placeholder="student@example.com"/>
        </div>
        <div class="col-span-2">
          <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Assign to Group</label>
          <select name="groupId" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm bg-white">
            <option value="">— No Group —</option>
            <% groups.forEach(g => { %><option value="<%= g.id %>"><%= g.name %></option><% }) %>
          </select>
        </div>
      </div>
      <div class="bg-navy-50 border border-navy-100 rounded-xl px-4 py-3 flex items-start gap-2.5">
        <svg class="w-4 h-4 text-navy-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <p class="text-xs text-navy-700">Default password: <strong>CET@</strong> + last 4 digits of roll number</p>
      </div>
      <div class="flex gap-3 pt-1">
        <button type="submit" class="flex-1 bg-navy-950 text-white font-semibold py-3 rounded-xl hover:bg-navy-900 transition-colors">Create Student</button>
        <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="flex-1 border border-slate-200 text-slate-700 font-semibold py-3 rounded-xl hover:bg-slate-50 transition-colors">Cancel</button>
      </div>
    </form>
  </div>
</div>

<!-- Bulk Import Modal -->
<div id="importModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4">
  <div class="bg-white rounded-t-3xl sm:rounded-2xl shadow-2xl w-full sm:max-w-md">
    <div class="flex items-center justify-between px-6 py-5 border-b border-slate-100">
      <h3 class="font-bold text-slate-900">Bulk Import Students</h3>
      <button onclick="document.getElementById('importModal').classList.add('hidden')" class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 hover:bg-slate-200">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form action="/admin/students/bulk-import" method="POST" enctype="multipart/form-data" class="p-6 space-y-4">
      <label class="block border-2 border-dashed border-slate-200 hover:border-navy-300 rounded-xl p-8 text-center cursor-pointer transition-colors group">
        <svg class="w-10 h-10 text-slate-300 group-hover:text-navy-400 mx-auto mb-3 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
        <p class="text-sm font-medium text-slate-600">Choose CSV or Excel file</p>
        <p class="text-xs text-slate-400 mt-1">Supports .csv, .xlsx, .xls</p>
        <input type="file" name="csvFile" accept=".csv,.xlsx,.xls" required class="sr-only"/>
      </label>
      <div class="bg-slate-50 rounded-xl px-4 py-3">
        <p class="text-xs font-semibold text-slate-600 mb-1">Required columns:</p>
        <p class="text-xs font-mono text-slate-500">name, rollNo, email (optional)</p>
      </div>
      <div class="flex gap-3">
        <button type="submit" class="flex-1 bg-navy-950 text-white font-semibold py-3 rounded-xl hover:bg-navy-900 transition-colors">Import</button>
        <button type="button" onclick="document.getElementById('importModal').classList.add('hidden')" class="flex-1 border border-slate-200 text-slate-700 font-semibold py-3 rounded-xl hover:bg-slate-50 transition-colors">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
function filterTable(q) {
  document.querySelectorAll('.student-row').forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(q.toLowerCase()) ? '' : 'none';
  });
}
</script>
</body>
</html>
