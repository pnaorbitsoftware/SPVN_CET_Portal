<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-admin') %>
  <main class="lg:ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-10 bg-white/90 backdrop-blur border-b border-slate-200 px-5 lg:px-8 py-4 flex items-center justify-between">
      <div><h1 class="text-lg font-bold text-slate-900">Tests</h1><p class="text-sm text-slate-500"><%= tests.length %> tests total</p></div>
      <a href="/admin/tests/create" class="flex items-center gap-2 bg-navy-950 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-navy-800 transition-colors">+ Create Test</a>
    </header>
    <div class="p-5 lg:p-8">
      <%- include('../partials/flash') %>
      <!-- Filters -->
      <form method="GET" class="flex flex-wrap gap-3 mb-6">
        <select name="course" class="border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500">
          <option value="">All Courses</option>
          <% COURSES.forEach(c => { %><option value="<%= c %>" <%= filterCourse===c?'selected':'' %>><%= c %></option><% }) %>
        </select>
        <select name="subject" class="border border-slate-200 rounded-lg px-3 py-2 text-sm">
          <option value="">All Subjects</option>
          <% SUBJECTS.forEach(s => { %><option value="<%= s %>" <%= filterSubject===s?'selected':'' %>><%= s %></option><% }) %>
        </select>
        <button type="submit" class="bg-slate-100 hover:bg-slate-200 px-4 py-2 rounded-lg text-sm font-medium">Filter</button>
        <a href="/admin/tests" class="px-4 py-2 rounded-lg text-sm text-slate-500 hover:bg-slate-50">Clear</a>
      </form>

      <% if (!tests.length) { %>
      <div class="text-center py-20 text-slate-400">
        <div class="text-6xl mb-4">📝</div>
        <p class="text-lg font-semibold mb-2">No tests yet</p>
        <a href="/admin/tests/create" class="bg-navy-950 text-white px-6 py-3 rounded-xl font-semibold hover:bg-navy-800 transition-colors inline-block">Create First Test →</a>
      </div>
      <% } else { %>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
        <% tests.forEach(test => { %>
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 flex flex-col hover:shadow-md transition-shadow">
          <div class="flex items-start justify-between mb-3">
            <div class="w-10 h-10 bg-indigo-100 rounded-xl flex items-center justify-center text-xl shrink-0">📝</div>
            <span class="text-xs px-2.5 py-1 rounded-full font-medium
              <%= test.status==='published'?'bg-green-100 text-green-700':test.status==='draft'?'bg-slate-100 text-slate-600':'bg-blue-100 text-blue-700' %>">
              <%= test.status %>
            </span>
          </div>
          <h3 class="font-bold text-slate-900 mb-1 flex-1"><%= test.title %></h3>
          <div class="flex flex-wrap gap-2 mb-3">
            <% if (test.course) { %><span class="text-xs bg-purple-100 text-purple-700 px-2 py-0.5 rounded"><%= test.course %></span><% } %>
            <% if (test.subject) { %><span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded"><%= test.subject %></span><% } %>
          </div>
          <div class="grid grid-cols-2 gap-2 text-xs text-slate-500 bg-slate-50 rounded-lg p-3 mb-4">
            <span>⏱ <%= test.duration %> mins</span>
            <span>📊 <%= test.totalMarks %> marks</span>
            <span>➖ <%= test.negativeMarking %> neg</span>
            <span>👥 <%= test.groups.map(g=>g.name).join(', ')||'No groups' %></span>
          </div>
          <div class="flex gap-2">
            <a href="/admin/tests/<%= test.id %>" class="flex-1 text-center text-sm font-semibold border border-slate-200 py-2 rounded-lg hover:bg-slate-50">View</a>
            <% if (test.status==='draft') { %>
            <form action="/admin/tests/<%= test.id %>/publish" method="POST" class="flex-1">
              <button class="w-full text-sm font-semibold bg-green-600 text-white py-2 rounded-lg hover:bg-green-700">Publish</button>
            </form>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>
  </main>
</div>
</body></html>
