<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-admin') %>
  <main class="lg:ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-10 bg-white/90 backdrop-blur border-b border-slate-200 px-5 lg:px-8 py-4 flex items-center gap-4">
      <button onclick="openSidebar()" class="lg:hidden text-slate-500 hover:text-slate-800"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg></button>
      <div class="flex-1"><h1 class="text-lg font-bold text-slate-900">Student Documents</h1><p class="text-xs text-slate-400"><%= docs.length %> uploaded documents</p></div>
    </header>
    <div class="p-5 lg:p-8">
      <%- include('../partials/flash') %>
      <div class="bg-white rounded-2xl border border-slate-100 shadow-card overflow-hidden">
        <% if (docs.length === 0) { %>
        <div class="py-20 text-center">
          <svg class="w-14 h-14 text-slate-200 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <p class="font-medium text-slate-500">No documents uploaded yet.</p>
        </div>
        <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-slate-50"><tr>
              <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Student</th>
              <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">File</th>
              <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider hidden md:table-cell">Description</th>
              <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider hidden md:table-cell">Size</th>
              <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Date</th>
              <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Actions</th>
            </tr></thead>
            <tbody class="divide-y divide-slate-50">
              <% docs.forEach(doc => { %>
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-6 py-4">
                  <p class="font-medium text-slate-900 text-sm"><%= doc.student?.name %></p>
                  <p class="text-xs text-slate-400 font-mono"><%= doc.student?.rollNo %></p>
                </td>
                <td class="px-6 py-4">
                  <p class="text-sm text-slate-700 font-medium truncate max-w-[180px]"><%= doc.originalName %></p>
                  <p class="text-xs text-slate-400"><%= doc.fileType %></p>
                </td>
                <td class="px-6 py-4 text-slate-500 text-xs hidden md:table-cell"><%= doc.description || '—' %></td>
                <td class="px-6 py-4 text-slate-400 text-xs hidden md:table-cell"><%= doc.fileSize ? Math.round(doc.fileSize/1024) + ' KB' : '—' %></td>
                <td class="px-6 py-4 text-slate-400 text-xs"><%= new Date(doc.createdAt).toLocaleDateString('en-IN') %></td>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <a href="<%= doc.filePath %>" target="_blank" class="text-xs text-navy-600 hover:text-navy-800 font-medium">Download</a>
                    <form action="/admin/documents/<%= doc.id %>/delete" method="POST" onsubmit="return confirm('Delete document?')">
                      <button type="submit" class="text-xs text-rose-500 hover:text-rose-700 font-medium">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </main>
</div>
</body>
</html>
