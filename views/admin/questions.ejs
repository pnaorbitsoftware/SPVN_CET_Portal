<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-admin') %>
  <main class="lg:ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-10 bg-white/90 backdrop-blur border-b border-slate-200 px-5 lg:px-8 py-4 flex items-center justify-between">
      <div><h1 class="text-lg font-bold text-slate-900">Question Bank</h1><p class="text-sm text-slate-500"><%= total %> questions total</p></div>
      <div class="flex gap-2">
        <button onclick="document.getElementById('addQModal').classList.remove('hidden')" class="flex items-center gap-2 bg-navy-950 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-navy-800 transition-colors">+ Add Question</button>
        <button onclick="document.getElementById('importModal').classList.remove('hidden')" class="flex items-center gap-2 border border-slate-200 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-slate-50 transition-colors">📥 Import CSV</button>
      </div>
    </header>
    <div class="p-5 lg:p-8">
      <%- include('../partials/flash') %>
      <!-- Filters -->
      <form method="GET" class="flex flex-wrap gap-3 mb-6">
        <select name="subject" class="border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500">
          <option value="">All Subjects</option>
          <% SUBJECTS.forEach(s => { %><option value="<%= s %>" <%= filters.subject===s?'selected':'' %>><%= s %></option><% }) %>
        </select>
        <select name="difficulty" class="border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500">
          <option value="">All Difficulty</option>
          <% ['Easy','Medium','Hard'].forEach(d => { %><option value="<%= d %>" <%= filters.difficulty===d?'selected':'' %>><%= d %></option><% }) %>
        </select>
        <button type="submit" class="bg-slate-100 hover:bg-slate-200 px-4 py-2 rounded-lg text-sm font-medium">Filter</button>
        <a href="/admin/questions" class="px-4 py-2 rounded-lg text-sm text-slate-500 hover:bg-slate-50">Clear</a>
      </form>

      <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="divide-y divide-slate-100">
          <% if (!questions.length) { %>
          <p class="px-6 py-12 text-center text-slate-400">No questions yet. Add your first question!</p>
          <% } %>
          <% questions.forEach((q, i) => { %>
          <div class="px-6 py-4 hover:bg-slate-50 transition-colors">
            <div class="flex items-start gap-4">
              <span class="text-xs font-mono bg-slate-100 text-slate-500 px-2 py-1 rounded mt-0.5 shrink-0"><%= ((currentPage-1)*25)+i+1 %></span>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-slate-900 mb-2"><%= q.question %></p>
                <% if (q.questionImage) { %><img src="<%= q.questionImage %>" class="max-h-28 rounded-lg border mb-2 object-contain"/><% } %>
                <div class="grid grid-cols-2 gap-1 text-xs text-slate-600 mb-2">
                  <span>A. <%= q.optionA %></span><span>B. <%= q.optionB %></span>
                  <span>C. <%= q.optionC %></span><span>D. <%= q.optionD %></span>
                </div>
                <div class="flex flex-wrap gap-2">
                  <span class="bg-green-100 text-green-700 text-xs px-2 py-0.5 rounded font-semibold">✓ Ans: <%= q.correctAnswer %></span>
                  <span class="bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded"><%= q.subject %></span>
                  <span class="<%= q.difficulty==='Easy'?'bg-green-100 text-green-700':q.difficulty==='Hard'?'bg-red-100 text-red-700':'bg-yellow-100 text-yellow-700' %> text-xs px-2 py-0.5 rounded"><%= q.difficulty %></span>
                  <% if (q.topic) { %><span class="bg-slate-100 text-slate-600 text-xs px-2 py-0.5 rounded"><%= q.topic %></span><% } %>
                  <span class="text-xs text-slate-400"><%= q.marks %> mk</span>
                </div>
              </div>
              <form action="/admin/questions/<%= q.id %>/delete" method="POST" onsubmit="return confirm('Delete?')">
                <button type="submit" class="text-xs text-red-400 hover:text-red-600 font-medium shrink-0 mt-1">Delete</button>
              </form>
            </div>
          </div>
          <% }) %>
        </div>
        <% if (totalPages > 1) { %>
        <div class="flex justify-center gap-1 px-6 py-4 border-t border-slate-100">
          <% for(let p=1;p<=totalPages;p++) { %>
          <a href="?page=<%= p %>&subject=<%= filters.subject||'' %>&difficulty=<%= filters.difficulty||'' %>"
            class="w-8 h-8 flex items-center justify-center rounded-lg text-sm font-medium <%= p===currentPage?'bg-navy-950 text-white':'bg-slate-100 text-slate-600 hover:bg-slate-200' %>"><%= p %></a>
          <% } %>
        </div>
        <% } %>
      </div>
    </div>
  </main>
</div>

<!-- Add Question Modal -->
<div id="addQModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4 overflow-y-auto">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl my-8">
    <div class="flex items-center justify-between px-6 py-5 border-b">
      <h3 class="font-bold text-lg text-slate-900">Add Question</h3>
      <button onclick="document.getElementById('addQModal').classList.add('hidden')" class="text-slate-400 hover:text-slate-600 text-xl">✕</button>
    </div>
    <form action="/admin/questions" method="POST" enctype="multipart/form-data" class="p-6 space-y-4">
      <div><label class="block text-sm font-semibold mb-1.5">Question *</label>
        <textarea name="question" rows="2" required class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500" placeholder="Enter question text"></textarea>
      </div>
      <div><label class="block text-sm font-semibold mb-1.5">Question Image <span class="text-slate-400 font-normal">(optional — upload or paste URL)</span></label>
        <div class="flex gap-2">
          <input type="file" name="questionImage" accept="image/*" onchange="prev(this,'qp')" class="flex-1 text-sm border border-slate-200 rounded-lg px-3 py-2 bg-white"/>
          <input type="text" name="questionImageUrl" placeholder="Or paste image URL" class="flex-1 text-sm border border-slate-200 rounded-lg px-3 py-2"/>
        </div>
        <img id="qp" class="hidden mt-2 max-h-28 rounded-lg border object-contain"/>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <% ['A','B','C','D'].forEach(o => { %><div><label class="block text-sm font-semibold mb-1">Option <%= o %> *</label><input type="text" name="option<%= o %>" required class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500" placeholder="Option <%= o %>"/></div><% }) %>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <div><label class="block text-sm font-semibold mb-1">Correct *</label>
          <select name="correctAnswer" required class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500">
            <% ['A','B','C','D'].forEach(o => { %><option value="<%= o %>"><%= o %></option><% }) %>
          </select></div>
        <div><label class="block text-sm font-semibold mb-1">Subject *</label>
          <select name="subject" required class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500">
            <% SUBJECTS.forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %>
          </select></div>
        <div><label class="block text-sm font-semibold mb-1">Difficulty</label>
          <select name="difficulty" class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500">
            <% ['Easy','Medium','Hard'].forEach(d => { %><option><%= d %></option><% }) %>
          </select></div>
        <div><label class="block text-sm font-semibold mb-1">Marks</label>
          <input type="number" name="marks" value="1" step="0.5" min="0.5" class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500"/></div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div><label class="block text-sm font-semibold mb-1">Topic</label><input type="text" name="topic" class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm" placeholder="e.g. Kinematics"/></div>
        <div><label class="block text-sm font-semibold mb-1">Explanation</label><input type="text" name="explanation" class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm" placeholder="Brief explanation"/></div>
      </div>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="flex-1 bg-navy-950 text-white font-semibold py-3 rounded-xl hover:bg-navy-800 transition-colors">Add Question</button>
        <button type="button" onclick="document.getElementById('addQModal').classList.add('hidden')" class="flex-1 border border-slate-200 text-slate-700 font-semibold py-3 rounded-xl hover:bg-slate-50">Cancel</button>
      </div>
    </form>
  </div>
</div>

<!-- Import Modal -->
<div id="importModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md">
    <div class="flex items-center justify-between px-6 py-5 border-b">
      <h3 class="font-bold text-lg">Import Questions</h3>
      <button onclick="document.getElementById('importModal').classList.add('hidden')" class="text-slate-400 text-xl">✕</button>
    </div>
    <form action="/admin/questions/bulk-import" method="POST" enctype="multipart/form-data" class="p-6 space-y-4">
      <div class="border-2 border-dashed border-slate-200 rounded-xl p-6 text-center">
        <label class="cursor-pointer"><span class="text-navy-600 font-medium hover:underline text-sm">Choose CSV / Excel file</span><input type="file" name="csvFile" accept=".csv,.xlsx,.xls" required class="sr-only"/></label>
        <p class="text-xs text-slate-400 mt-1">question, optionA-D, correctAnswer, subject, difficulty, marks, topic</p>
      </div>
      <div class="flex gap-3">
        <button type="submit" class="flex-1 bg-navy-950 text-white font-semibold py-3 rounded-xl hover:bg-navy-800">Import</button>
        <button type="button" onclick="document.getElementById('importModal').classList.add('hidden')" class="flex-1 border border-slate-200 text-slate-700 font-semibold py-3 rounded-xl">Cancel</button>
      </div>
    </form>
  </div>
</div>
<script>function prev(i,id){const r=new FileReader();r.onload=e=>{const p=document.getElementById(id);p.src=e.target.result;p.classList.remove('hidden')};r.readAsDataURL(i.files[0]);}</script>
</body></html>
