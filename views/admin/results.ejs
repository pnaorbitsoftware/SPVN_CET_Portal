<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-admin') %>
  <main class="lg:ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-10 bg-white/90 backdrop-blur border-b border-slate-200 px-5 lg:px-8 py-4 flex items-center gap-4">
      <button onclick="openSidebar()" class="lg:hidden text-slate-500 hover:text-slate-800"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg></button>
      <div class="flex-1"><h1 class="text-lg font-bold text-slate-900">All Results</h1><p class="text-xs text-slate-400"><%= results.length %> total submissions</p></div>
      <a href="/admin/results/export" class="flex items-center gap-1.5 border border-slate-200 text-slate-700 px-4 py-2.5 rounded-xl text-sm font-medium hover:bg-slate-50 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Export Excel
      </a>
    </header>
    <div class="p-5 lg:p-8">
      <%- include('../partials/flash') %>
      <div class="bg-white rounded-2xl border border-slate-100 shadow-card overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-50 flex items-center gap-4">
          <div class="relative flex-1 max-w-xs">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35"/></svg>
            <input type="text" placeholder="Search results…" onkeyup="filterTable(this.value)"
              class="w-full border border-slate-200 rounded-xl pl-9 pr-4 py-2 text-sm"/>
          </div>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm" id="resultsTable">
            <thead class="bg-slate-50">
              <tr>
                <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Student</th>
                <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider hidden sm:table-cell">Roll No</th>
                <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Test</th>
                <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Score</th>
                <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider hidden md:table-cell">%</th>
                <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider hidden md:table-cell">Rank</th>
                <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider hidden lg:table-cell">Status</th>
                <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider hidden lg:table-cell">Date</th>
                <th class="px-6 py-3 text-left text-[11px] font-semibold text-slate-400 uppercase tracking-wider">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              <% results.forEach(r => { const pct = r.totalMarks>0 ? ((r.score/r.totalMarks)*100).toFixed(1) : 0; %>
              <tr class="hover:bg-slate-50 transition-colors result-row">
                <td class="px-6 py-4 font-medium text-slate-900"><%= r.student?.name %></td>
                <td class="px-6 py-4 font-mono text-slate-500 text-xs hidden sm:table-cell"><%= r.student?.rollNo %></td>
                <td class="px-6 py-4 text-slate-600 max-w-[180px] truncate"><%= r.test?.title %></td>
                <td class="px-6 py-4 font-bold text-slate-900"><%= r.score %>/<%= r.totalMarks %></td>
                <td class="px-6 py-4 hidden md:table-cell"><span class="font-semibold <%= pct>=60?'text-emerald-600':pct>=40?'text-amber-600':'text-rose-500' %>"><%= pct %>%</span></td>
                <td class="px-6 py-4 text-slate-600 hidden md:table-cell">#<%= r.rank||'—' %></td>
                <td class="px-6 py-4 hidden lg:table-cell">
                  <span class="text-[11px] px-2.5 py-1 rounded-full font-semibold <%= r.status==='submitted'?'bg-emerald-100 text-emerald-700':r.status==='auto_submitted'?'bg-amber-100 text-amber-700':'bg-slate-100 text-slate-600' %>">
                    <%= r.status.replace('_',' ') %>
                  </span>
                </td>
                <td class="px-6 py-4 text-slate-400 text-xs hidden lg:table-cell"><%= r.submittedAt?new Date(r.submittedAt).toLocaleDateString('en-IN'):'—' %></td>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <a href="/results/<%= r.id %>" class="text-xs text-navy-600 hover:text-navy-800 font-medium">View</a>
                    <a href="/results/<%= r.id %>/pdf" class="text-xs text-rose-500 hover:text-rose-700 font-medium">PDF</a>
                  </div>
                </td>
              </tr>
              <% }) %>
              <% if (!results.length) { %>
              <tr><td colspan="9" class="px-6 py-16 text-center text-slate-400">
                <svg class="w-12 h-12 text-slate-200 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                No results yet.
              </td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>
<script>
function filterTable(q) {
  document.querySelectorAll('.result-row').forEach(r => { r.style.display = r.textContent.toLowerCase().includes(q.toLowerCase()) ? '' : 'none'; });
}
</script>
</body></html>
