<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-admin') %>
  <main class="ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-20 bg-white border-b border-gray-200 px-8 py-4">
      <h1 class="text-xl font-bold text-gray-900">All Results</h1>
    </header>
    <div class="p-8">
      <%- include('../partials/flash') %>
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b flex items-center justify-between">
          <h3 class="font-semibold text-gray-900">Results (<%= results.length %>)</h3>
          <input type="text" placeholder="Search..." onkeyup="filterTable(this.value,'resultsTable')"
            class="border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 w-48" />
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm" id="resultsTable">
            <thead class="bg-gray-50 text-gray-600 uppercase text-xs tracking-wider">
              <tr>
                <th class="px-6 py-3 text-left">Student</th>
                <th class="px-6 py-3 text-left">Roll No</th>
                <th class="px-6 py-3 text-left">Test</th>
                <th class="px-6 py-3 text-left">Score</th>
                <th class="px-6 py-3 text-left">%</th>
                <th class="px-6 py-3 text-left">Rank</th>
                <th class="px-6 py-3 text-left">Status</th>
                <th class="px-6 py-3 text-left">Date</th>
                <th class="px-6 py-3 text-left">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
              <% results.forEach(r => { %>
              <% const pct = r.totalMarks > 0 ? ((r.score/r.totalMarks)*100).toFixed(1) : 0; %>
              <tr class="hover:bg-gray-50 transition-colors result-row">
                <td class="px-6 py-4 font-medium text-gray-900"><%= r.student?.name %></td>
                <td class="px-6 py-4 font-mono text-gray-500 text-xs"><%= r.student?.rollNo %></td>
                <td class="px-6 py-4 text-gray-600 max-w-[200px] truncate"><%= r.test?.title %></td>
                <td class="px-6 py-4 font-bold text-gray-900"><%= r.score %>/<%= r.totalMarks %></td>
                <td class="px-6 py-4">
                  <span class="font-semibold <%= pct >= 60 ? 'text-green-600' : pct >= 40 ? 'text-yellow-600' : 'text-red-500' %>"><%= pct %>%</span>
                </td>
                <td class="px-6 py-4 text-gray-600"><%= r.rank || '—' %></td>
                <td class="px-6 py-4">
                  <span class="text-xs px-2.5 py-1 rounded-full font-medium
                    <%= r.status === 'submitted' ? 'bg-green-100 text-green-700' : r.status === 'auto_submitted' ? 'bg-yellow-100 text-yellow-700' : 'bg-gray-100 text-gray-600' %>">
                    <%= r.status.replace('_',' ') %>
                  </span>
                </td>
                <td class="px-6 py-4 text-gray-400 text-xs"><%= r.submittedAt ? new Date(r.submittedAt).toLocaleDateString('en-IN') : '—' %></td>
                <td class="px-6 py-4">
                  <a href="/results/<%= r.id %>" class="text-primary-600 hover:underline text-xs font-medium mr-2">View</a>
                  <a href="/results/<%= r.id %>/pdf" class="text-red-500 hover:underline text-xs font-medium">PDF</a>
                </td>
              </tr>
              <% }) %>
              <% if (results.length === 0) { %>
              <tr><td colspan="9" class="px-6 py-12 text-center text-gray-400">No results yet.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>
<script>
function filterTable(q, id) {
  document.querySelectorAll(`#${id} .result-row`).forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(q.toLowerCase()) ? '' : 'none';
  });
}
</script>
</body>
</html>
