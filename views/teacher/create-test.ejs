<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-teacher') %>
  <main class="ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-20 bg-white border-b border-gray-200 px-8 py-4">
      <h1 class="text-xl font-bold text-gray-900">Create New Test</h1>
    </header>
    <div class="p-8 max-w-4xl mx-auto">
      <%- include('../partials/flash') %>
      <form action="/teacher/tests" method="POST" class="space-y-6">

        <!-- Basic Info -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
          <h3 class="font-bold text-gray-900 mb-4 flex items-center gap-2">📝 Test Details</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div class="md:col-span-2"><label class="block text-sm font-semibold text-gray-700 mb-1.5">Test Title *</label><input type="text" name="title" required class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" placeholder="e.g. CET Mock Test 1 - Physics & Chemistry" /></div>
            <div class="md:col-span-2"><label class="block text-sm font-semibold text-gray-700 mb-1.5">Description</label><textarea name="description" rows="2" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" placeholder="Brief test description"></textarea></div>
            <div><label class="block text-sm font-semibold text-gray-700 mb-1.5">Duration (minutes) *</label><input type="number" name="duration" value="180" min="10" required class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" /></div>
            <div><label class="block text-sm font-semibold text-gray-700 mb-1.5">Negative Marking</label><input type="number" name="negativeMarking" value="0.25" step="0.25" min="0" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" /></div>
            <div><label class="block text-sm font-semibold text-gray-700 mb-1.5">Start Time (optional)</label><input type="datetime-local" name="startTime" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" /></div>
            <div><label class="block text-sm font-semibold text-gray-700 mb-1.5">End Time (optional)</label><input type="datetime-local" name="endTime" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" /></div>
            <div class="md:col-span-2"><label class="block text-sm font-semibold text-gray-700 mb-1.5">Instructions for Students</label><textarea name="instructions" rows="3" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" placeholder="Enter exam instructions..."></textarea></div>
          </div>
          <div class="flex gap-6 mt-4">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="shuffleQuestions" value="on" checked class="w-4 h-4 rounded border-gray-300 text-emerald-600" />
              <span class="text-sm text-gray-700">Shuffle Questions</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="shuffleOptions" value="on" class="w-4 h-4 rounded border-gray-300 text-emerald-600" />
              <span class="text-sm text-gray-700">Shuffle Options</span>
            </label>
          </div>
        </div>

        <!-- Assign to Groups -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
          <h3 class="font-bold text-gray-900 mb-4">👥 Assign to Groups</h3>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
            <% groups.forEach(g => { %>
            <label class="flex items-center gap-2 p-3 border border-gray-200 rounded-xl cursor-pointer hover:bg-emerald-50 hover:border-emerald-300 transition-colors">
              <input type="checkbox" name="groupIds" value="<%= g.id %>" class="w-4 h-4 rounded border-gray-300 text-emerald-600" />
              <span class="text-sm font-medium text-gray-700"><%= g.name %></span>
            </label>
            <% }) %>
            <% if (groups.length === 0) { %>
            <p class="text-sm text-gray-400 col-span-3">No groups available. Ask admin to create groups first.</p>
            <% } %>
          </div>
        </div>

        <!-- Select Questions -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-bold text-gray-900">❓ Select Questions</h3>
            <div class="flex items-center gap-3">
              <span id="selectedCount" class="text-sm font-semibold text-emerald-700 bg-emerald-50 px-3 py-1 rounded-full">0 selected</span>
              <input type="text" placeholder="Filter questions..." onkeyup="filterQuestions(this.value)" class="border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 w-48" />
            </div>
          </div>

          <div class="flex gap-3 mb-3 flex-wrap" id="subjectFilters">
            <button type="button" onclick="filterBySubject('')" class="subject-filter active text-xs px-3 py-1.5 rounded-lg font-medium bg-emerald-600 text-white transition-colors">All</button>
            <% ['Physics','Chemistry','Mathematics','Biology','English','General Knowledge'].forEach(s => { %>
            <button type="button" onclick="filterBySubject('<%= s %>')" class="subject-filter text-xs px-3 py-1.5 rounded-lg font-medium bg-gray-100 text-gray-600 hover:bg-emerald-100 hover:text-emerald-700 transition-colors"><%= s %></button>
            <% }) %>
          </div>

          <div class="border border-gray-200 rounded-xl overflow-hidden max-h-80 overflow-y-auto" id="questionsContainer">
            <% if (questions.length === 0) { %>
            <p class="p-6 text-sm text-gray-400 text-center">No questions in your question bank. <a href="/teacher/questions" class="text-emerald-600 hover:underline">Add questions first →</a></p>
            <% } %>
            <% questions.forEach((q, i) => { %>
            <label class="q-item flex items-start gap-3 p-4 border-b border-gray-100 cursor-pointer hover:bg-gray-50 transition-colors" data-subject="<%= q.subject %>" data-text="<%= q.question.toLowerCase() %>">
              <input type="checkbox" name="questionIds" value="<%= q.id %>" onchange="updateCount()" class="mt-0.5 w-4 h-4 rounded border-gray-300 text-emerald-600 flex-shrink-0" />
              <div class="flex-1 min-w-0">
                <p class="text-sm text-gray-800 leading-snug"><%= q.question.length > 120 ? q.question.substring(0,120)+'...' : q.question %></p>
                <div class="flex items-center gap-2 mt-1">
                  <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded"><%= q.subject %></span>
                  <span class="text-xs <%= q.difficulty==='Easy'?'bg-green-100 text-green-700':q.difficulty==='Hard'?'bg-red-100 text-red-700':'bg-yellow-100 text-yellow-700' %> px-2 py-0.5 rounded"><%= q.difficulty %></span>
                  <span class="text-xs text-gray-400"><%= q.marks %> mk</span>
                </div>
              </div>
            </label>
            <% }) %>
          </div>
        </div>

        <div class="flex gap-4">
          <button type="submit" class="flex-1 bg-emerald-700 text-white font-bold py-4 rounded-2xl hover:bg-emerald-800 transition-colors text-lg shadow-lg">
            Create Test
          </button>
          <a href="/teacher/tests" class="px-8 py-4 border-2 border-gray-200 text-gray-700 font-semibold rounded-2xl hover:bg-gray-50 transition-colors">Cancel</a>
        </div>
      </form>
    </div>
  </main>
</div>

<script>
let currentSubjectFilter = '';

function updateCount() {
  const count = document.querySelectorAll('input[name="questionIds"]:checked').length;
  document.getElementById('selectedCount').textContent = count + ' selected';
}

function filterQuestions(query) {
  document.querySelectorAll('.q-item').forEach(item => {
    const textMatch = item.dataset.text.includes(query.toLowerCase());
    const subjectMatch = !currentSubjectFilter || item.dataset.subject === currentSubjectFilter;
    item.style.display = textMatch && subjectMatch ? '' : 'none';
  });
}

function filterBySubject(subject) {
  currentSubjectFilter = subject;
  document.querySelectorAll('.subject-filter').forEach(btn => btn.classList.remove('active','bg-emerald-600','text-white'));
  event.target.classList.add('active','bg-emerald-600','text-white');
  document.querySelectorAll('.q-item').forEach(item => {
    item.style.display = !subject || item.dataset.subject === subject ? '' : 'none';
  });
}
</script>
</body>
</html>
