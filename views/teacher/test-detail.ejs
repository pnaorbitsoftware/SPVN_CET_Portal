<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-teacher') %>
  <main class="ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-20 bg-white border-b border-gray-200 px-8 py-4">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-xl font-bold text-gray-900"><%= test.title %></h1>
          <p class="text-sm text-gray-500"><%= test.duration %> mins · <%= test.totalMarks %> marks</p>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-xs px-3 py-1.5 rounded-full font-semibold
            <%= test.status==='published'?'bg-green-100 text-green-700':test.status==='draft'?'bg-gray-100 text-gray-600':'bg-blue-100 text-blue-700' %>">
            <%= test.status.toUpperCase() %>
          </span>
          <% if (test.status === 'draft') { %>
          <form action="/teacher/tests/<%= test.id %>/publish" method="POST">
            <button type="submit" class="bg-green-600 text-white px-5 py-2 rounded-xl text-sm font-semibold hover:bg-green-700 transition-colors">Publish Test</button>
          </form>
          <% } %>
          <% if (results.length > 0) { %>
          <a href="/results/leaderboard/<%= test.id %>" class="bg-primary-800 text-white px-5 py-2 rounded-xl text-sm font-semibold hover:bg-primary-900 transition-colors">Leaderboard</a>
          <% } %>
        </div>
      </div>
    </header>
    <div class="p-8">
      <%- include('../partials/flash') %>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <% [
          {label:'Questions', value: test.questions.length, icon:'❓'},
          {label:'Duration',  value: test.duration + ' min', icon:'⏱'},
          {label:'Attempts',  value: results.length,       icon:'👨‍🎓'},
          {label:'Avg Score', value: results.length ? (results.reduce((s,r)=>s+r.score,0)/results.length).toFixed(1)+'/'+test.totalMarks : 'N/A', icon:'📊'},
        ].forEach(c => { %>
        <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm">
          <p class="text-xl mb-2"><%= c.icon %></p>
          <p class="text-2xl font-bold text-gray-900"><%= c.value %></p>
          <p class="text-xs text-gray-500 mt-0.5"><%= c.label %></p>
        </div>
        <% }) %>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Questions -->
        <div class="lg:col-span-1 bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="px-5 py-4 border-b bg-gray-50"><h3 class="font-semibold text-gray-900 text-sm">Questions (<%= test.questions.length %>)</h3></div>
          <div class="divide-y divide-gray-50 max-h-96 overflow-y-auto">
            <% test.questions.forEach((q, i) => { %>
            <div class="px-5 py-3 hover:bg-gray-50">
              <p class="text-xs text-gray-800 leading-snug"><%= i+1 %>. <%= q.question.length > 80 ? q.question.substring(0,80)+'...' : q.question %></p>
              <div class="flex gap-2 mt-1">
                <span class="text-xs bg-green-100 text-green-700 px-1.5 py-0.5 rounded">Ans: <%= q.correctAnswer %></span>
                <span class="text-xs text-gray-400"><%= q.subject %></span>
              </div>
            </div>
            <% }) %>
          </div>
        </div>

        <!-- Results -->
        <div class="lg:col-span-2 bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="px-6 py-4 border-b"><h3 class="font-semibold text-gray-900">Student Results</h3></div>
          <% if (results.length === 0) { %>
          <p class="px-6 py-12 text-center text-gray-400">No submissions yet.</p>
          <% } else { %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-50 text-xs text-gray-500 uppercase tracking-wider">
                <tr>
                  <th class="px-5 py-3 text-left">Rank</th>
                  <th class="px-5 py-3 text-left">Student</th>
                  <th class="px-5 py-3 text-left">Score</th>
                  <th class="px-5 py-3 text-left">%</th>
                  <th class="px-5 py-3 text-left">Correct</th>
                  <th class="px-5 py-3 text-left">Action</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                <% results.forEach((r, i) => { %>
                <tr class="hover:bg-gray-50">
                  <td class="px-5 py-3">
                    <% if (i === 0) { %><span class="text-lg">🥇</span><% } else if (i===1) { %><span class="text-lg">🥈</span><% } else if (i===2) { %><span class="text-lg">🥉</span><% } else { %><span class="text-sm text-gray-500">#<%= i+1 %></span><% } %>
                  </td>
                  <td class="px-5 py-3"><p class="font-medium text-gray-900"><%= r.student?.name %></p><p class="text-xs text-gray-400"><%= r.student?.rollNo %></p></td>
                  <td class="px-5 py-3 font-bold text-gray-900"><%= r.score %>/<%= r.totalMarks %></td>
                  <td class="px-5 py-3"><span class="font-semibold <%= (r.score/r.totalMarks*100)>=60?'text-green-600':(r.score/r.totalMarks*100)>=40?'text-yellow-600':'text-red-500' %>"><%= (r.score/r.totalMarks*100).toFixed(1) %>%</span></td>
                  <td class="px-5 py-3 text-sm text-gray-600"><%= r.correctAnswers %>✅ <%= r.wrongAnswers %>❌ <%= r.skippedAnswers %>⏭</td>
                  <td class="px-5 py-3"><a href="/results/<%= r.id %>" class="text-emerald-600 hover:underline text-xs font-medium">View</a></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>
</div>
</body>
</html>
