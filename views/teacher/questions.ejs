<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-teacher') %>
  <main class="ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-20 bg-white border-b border-gray-200 px-8 py-4">
      <h1 class="text-xl font-bold text-gray-900">Question Bank</h1>
    </header>
    <div class="p-8">
      <%- include('../partials/flash') %>

      <!-- Action bar -->
      <div class="flex flex-wrap gap-3 mb-6">
        <button onclick="document.getElementById('addQModal').classList.remove('hidden')"
          class="flex items-center gap-2 bg-emerald-700 text-white px-5 py-2.5 rounded-xl font-medium hover:bg-emerald-800 transition-colors">
          + Add Question
        </button>
        <button onclick="document.getElementById('importQModal').classList.remove('hidden')"
          class="flex items-center gap-2 bg-blue-600 text-white px-5 py-2.5 rounded-xl font-medium hover:bg-blue-700 transition-colors">
          📥 Bulk Import
        </button>
        <!-- Filters -->
        <form method="GET" action="/teacher/questions" class="flex gap-2 ml-auto">
          <select name="subject" class="border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
            <option value="">All Subjects</option>
            <% ['Physics','Chemistry','Mathematics','Biology','English','General Knowledge'].forEach(s => { %>
            <option value="<%= s %>" <%= filters.subject === s ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          </select>
          <select name="difficulty" class="border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
            <option value="">All Difficulty</option>
            <% ['Easy','Medium','Hard'].forEach(d => { %>
            <option value="<%= d %>" <%= filters.difficulty === d ? 'selected' : '' %>><%= d %></option>
            <% }) %>
          </select>
          <button type="submit" class="bg-gray-100 hover:bg-gray-200 px-4 py-2 rounded-lg text-sm font-medium transition-colors">Filter</button>
        </form>
      </div>

      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b flex items-center justify-between">
          <h3 class="font-semibold text-gray-900">Questions (<%= total %>)</h3>
          <p class="text-sm text-gray-500">Page <%= currentPage %> of <%= totalPages %></p>
        </div>
        <div class="divide-y divide-gray-50">
          <% questions.forEach((q, i) => { %>
          <div class="px-6 py-4 hover:bg-gray-50 transition-colors">
            <div class="flex items-start gap-4">
              <span class="text-xs font-mono bg-gray-100 text-gray-500 px-2 py-1 rounded mt-0.5 flex-shrink-0"><%= ((currentPage-1)*20)+i+1 %></span>
              <div class="flex-1">
                <p class="text-sm font-medium text-gray-900 mb-2"><%= q.question %></p>
                <div class="grid grid-cols-2 gap-1 text-xs text-gray-600 mb-2">
                  <span class="flex items-center gap-1">🅐 <%= q.optionA %></span>
                  <span class="flex items-center gap-1">🅑 <%= q.optionB %></span>
                  <span class="flex items-center gap-1">🅒 <%= q.optionC %></span>
                  <span class="flex items-center gap-1">🅓 <%= q.optionD %></span>
                </div>
                <div class="flex items-center gap-3 flex-wrap">
                  <span class="bg-green-100 text-green-700 text-xs px-2 py-0.5 rounded font-semibold">Ans: <%= q.correctAnswer %></span>
                  <span class="bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded"><%= q.subject %></span>
                  <span class="<%= q.difficulty==='Easy'?'bg-green-100 text-green-700':q.difficulty==='Hard'?'bg-red-100 text-red-700':'bg-yellow-100 text-yellow-700' %> text-xs px-2 py-0.5 rounded"><%= q.difficulty %></span>
                  <span class="text-xs text-gray-400"><%= q.marks %> mark(s)</span>
                </div>
              </div>
              <form action="/teacher/questions/<%= q.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this question?')">
                <input type="hidden" name="_method" value="DELETE">
                <button type="submit" class="text-xs text-red-400 hover:text-red-600 font-medium flex-shrink-0">Delete</button>
              </form>
            </div>
          </div>
          <% }) %>
          <% if (questions.length === 0) { %>
          <p class="px-6 py-12 text-center text-gray-400">No questions found. Add your first question!</p>
          <% } %>
        </div>
        <!-- Pagination -->
        <% if (totalPages > 1) { %>
        <div class="flex justify-center gap-2 px-6 py-4 border-t border-gray-50">
          <% for(let p=1; p<=totalPages; p++) { %>
          <a href="?page=<%= p %>&subject=<%= filters.subject||'' %>&difficulty=<%= filters.difficulty||'' %>"
            class="w-8 h-8 flex items-center justify-center rounded-lg text-sm font-medium transition-colors
              <%= p === currentPage ? 'bg-emerald-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
            <%= p %>
          </a>
          <% } %>
        </div>
        <% } %>
      </div>
    </div>
  </main>
</div>

<!-- Add Question Modal -->
<div id="addQModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4 overflow-y-auto">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl my-8">
    <div class="flex items-center justify-between px-6 py-5 border-b"><h3 class="font-bold text-lg">Add Question</h3><button onclick="document.getElementById('addQModal').classList.add('hidden')" class="text-gray-400 text-xl">✕</button></div>
    <form action="/teacher/questions" method="POST" enctype="multipart/form-data" class="p-6 space-y-4">
      <!-- Question text + image -->
      <div><label class="block text-sm font-semibold mb-1.5">Question *</label><textarea name="question" rows="2" required class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" placeholder="Enter the question text"></textarea></div>

      <!-- Question Image Upload -->
      <div class="border border-dashed border-gray-300 rounded-xl p-4 bg-gray-50">
        <label class="block text-sm font-semibold mb-2">📷 Question Image <span class="text-gray-400 font-normal">(optional — upload or paste imgbb/image.io URL)</span></label>
        <div class="flex gap-3">
          <input type="file" name="questionImage" accept="image/*" onchange="previewImage(this,'qImgPreview')"
            class="flex-1 text-sm border border-gray-200 rounded-lg px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500" />
          <input type="text" name="questionImageUrl" placeholder="Or paste image URL..."
            class="flex-1 text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
        </div>
        <img id="qImgPreview" class="hidden mt-2 max-h-32 rounded-lg border border-gray-200 object-contain" />
      </div>

      <!-- Options -->
      <div class="grid grid-cols-2 gap-4">
        <% ['A','B','C','D'].forEach(opt => { %>
        <div>
          <label class="block text-sm font-semibold mb-1.5">Option <%= opt %> *</label>
          <input type="text" name="option<%= opt %>" required class="w-full border border-gray-200 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" placeholder="Option <%= opt %>" />
        </div>
        <% }) %>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <div><label class="block text-sm font-semibold mb-1.5">Correct *</label>
          <select name="correctAnswer" required class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
            <% ['A','B','C','D'].forEach(o => { %><option value="<%= o %>">Option <%= o %></option><% }) %>
          </select>
        </div>
        <div><label class="block text-sm font-semibold mb-1.5">Subject *</label>
          <select name="subject" required class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
            <% ['Physics','Chemistry','Mathematics','Biology','English','General Knowledge'].forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %>
          </select>
        </div>
        <div><label class="block text-sm font-semibold mb-1.5">Difficulty</label>
          <select name="difficulty" class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
            <% ['Easy','Medium','Hard'].forEach(d => { %><option value="<%= d %>"><%= d %></option><% }) %>
          </select>
        </div>
        <div><label class="block text-sm font-semibold mb-1.5">Marks</label>
          <input type="number" name="marks" value="1" step="0.5" min="0.5" class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" />
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div><label class="block text-sm font-semibold mb-1.5">Topic / Sub-topic</label>
          <input type="text" name="topic" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" placeholder="e.g. Kinematics, Organic Chem" /></div>
        <div><label class="block text-sm font-semibold mb-1.5">Explanation</label>
          <input type="text" name="explanation" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" placeholder="Brief explanation" /></div>
      </div>

      <div class="bg-blue-50 rounded-xl p-3 text-xs text-blue-700">
        💡 <strong>Image hosting:</strong> Upload directly OR paste a URL from <a href="https://imgbb.com" target="_blank" class="underline">imgbb.com</a> or <a href="https://image.io" target="_blank" class="underline">image.io</a>. Add <code>IMGBB_API_KEY</code> in .env for auto-upload.
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="flex-1 bg-emerald-700 text-white font-semibold py-3 rounded-xl hover:bg-emerald-800 transition-colors">Add Question</button>
        <button type="button" onclick="document.getElementById('addQModal').classList.add('hidden')" class="flex-1 border border-gray-200 text-gray-700 font-semibold py-3 rounded-xl hover:bg-gray-50">Cancel</button>
      </div>
    </form>
  </div>
</div>

<!-- Bulk Import Modal -->
<div id="importQModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md">
    <div class="flex items-center justify-between px-6 py-5 border-b"><h3 class="font-bold text-lg">Bulk Import Questions</h3><button onclick="document.getElementById('importQModal').classList.add('hidden')" class="text-gray-400 text-xl">✕</button></div>
    <form action="/teacher/questions/bulk-import" method="POST" enctype="multipart/form-data" class="p-6 space-y-4">
      <div class="border-2 border-dashed border-gray-200 rounded-xl p-6 text-center">
        <p class="text-sm text-gray-500 mb-2">Upload CSV or Excel file</p>
        <label class="cursor-pointer text-blue-600 font-medium hover:underline text-sm">
          Choose file <input type="file" name="csvFile" accept=".csv,.xlsx,.xls" required class="sr-only"/>
        </label>
      </div>
      <div class="bg-gray-50 rounded-xl p-3 text-xs text-gray-600">
        <p class="font-semibold mb-1">Required columns:</p>
        <p class="font-mono">question, optionA, optionB, optionC, optionD, correctAnswer, subject, difficulty, marks</p>
      </div>
      <div class="flex gap-3"><button type="submit" class="flex-1 bg-blue-600 text-white font-semibold py-3 rounded-xl hover:bg-blue-700">Import</button><button type="button" onclick="document.getElementById('importQModal').classList.add('hidden')" class="flex-1 border border-gray-200 text-gray-700 font-semibold py-3 rounded-xl hover:bg-gray-50">Cancel</button></div>
    </form>
  </div>
</div>
</body>
</html>
