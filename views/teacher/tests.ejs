<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include('../partials/sidebar-teacher') %>
  <main class="ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-20 bg-white border-b border-gray-200 px-8 py-4">
      <div class="flex items-center justify-between">
        <h1 class="text-xl font-bold text-gray-900">My Tests</h1>
        <a href="/teacher/tests/create" class="flex items-center gap-2 bg-emerald-700 text-white px-5 py-2.5 rounded-xl font-medium hover:bg-emerald-800 transition-colors">
          + Create Test
        </a>
      </div>
    </header>
    <div class="p-8">
      <%- include('../partials/flash') %>
      <% if (tests.length === 0) { %>
      <div class="text-center py-20 text-gray-400">
        <div class="text-6xl mb-4">📝</div>
        <p class="text-xl font-semibold mb-2">No tests yet</p>
        <p class="mb-6">Create your first test to get started</p>
        <a href="/teacher/tests/create" class="bg-emerald-700 text-white px-6 py-3 rounded-xl font-semibold hover:bg-emerald-800 transition-colors">Create Test →</a>
      </div>
      <% } else { %>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        <% tests.forEach(test => { %>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 card-hover flex flex-col">
          <div class="flex items-start justify-between mb-3">
            <div class="w-10 h-10 bg-emerald-100 rounded-xl flex items-center justify-center text-xl flex-shrink-0">📝</div>
            <span class="text-xs px-2.5 py-1 rounded-full font-medium
              <%= test.status==='published'?'bg-green-100 text-green-700':test.status==='draft'?'bg-gray-100 text-gray-600':test.status==='closed'?'bg-red-100 text-red-600':'bg-blue-100 text-blue-700' %>">
              <%= test.status %>
            </span>
          </div>
          <h3 class="font-bold text-gray-900 mb-1"><%= test.title %></h3>
          <p class="text-sm text-gray-500 mb-4 flex-1"><%= test.description || 'No description' %></p>
          <div class="grid grid-cols-2 gap-2 text-xs text-gray-600 mb-4 bg-gray-50 rounded-xl p-3">
            <span>⏱ <%= test.duration %> mins</span>
            <span>📊 <%= test.totalMarks %> marks</span>
            <span>➖ <%= test.negativeMarking %> neg.</span>
            <span>👥 <%= test.groups.map(g=>g.name).join(', ') || 'No groups' %></span>
          </div>
          <div class="flex gap-2">
            <a href="/teacher/tests/<%= test.id %>" class="flex-1 text-center text-sm font-semibold border border-gray-200 py-2 rounded-xl hover:bg-gray-50 transition-colors">View</a>
            <% if (test.status === 'draft') { %>
            <form action="/teacher/tests/<%= test.id %>/publish" method="POST" class="flex-1">
              <button type="submit" class="w-full text-sm font-semibold bg-green-600 text-white py-2 rounded-xl hover:bg-green-700 transition-colors">Publish</button>
            </form>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
