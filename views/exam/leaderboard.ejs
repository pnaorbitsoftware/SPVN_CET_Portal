<%- include('../partials/head') %>
<div class="min-h-screen bg-slate-50 py-8 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="bg-white rounded-2xl shadow-card-lg border border-slate-100 overflow-hidden">
      <div class="bg-navy-950 p-8 text-white text-center">
        <svg class="w-12 h-12 text-amber-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z'/></svg>
        <h1 class="text-2xl font-bold mb-1">Leaderboard</h1>
        <p class="text-white/60 text-sm"><%= test.title %></p>
      </div>
      <div class="divide-y divide-slate-50">
        <% results.forEach((r, i) => {
          const pct = r.totalMarks>0 ? ((r.score/r.totalMarks)*100).toFixed(1) : 0;
          const isMe = r.studentId === (currentUser && currentUser.id);
          const medalBg = i===0 ? 'bg-amber-400' : i===1 ? 'bg-slate-300' : i===2 ? 'bg-amber-600' : 'bg-slate-100';
          const medalText = i===0 ? 'text-amber-900' : i===1 ? 'text-slate-700' : i===2 ? 'text-amber-100' : 'text-slate-500';
        %>
        <div class="flex items-center gap-4 px-6 py-4 <%= isMe ? 'bg-navy-50 border-l-4 border-navy-500' : 'hover:bg-slate-50' %> transition-colors">
          <div class="w-9 h-9 rounded-xl <%= medalBg %> flex items-center justify-center font-bold text-sm shrink-0 <%= medalText %>">
            <%= i+1 %>
          </div>
          <div class="w-9 h-9 rounded-full bg-navy-100 flex items-center justify-center font-bold text-navy-700 text-sm shrink-0">
            <%= r.student?.name?.charAt(0)?.toUpperCase() %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-slate-900 text-sm truncate"><%= r.student?.name %> <%= isMe ? '(You)' : '' %></p>
            <p class="text-xs text-slate-400 font-mono"><%= r.student?.rollNo %></p>
          </div>
          <div class="text-right shrink-0">
            <p class="font-bold text-slate-900 text-sm"><%= r.score %>/<%= r.totalMarks %></p>
            <p class="text-xs text-<%= pct>=60?'emerald':pct>=40?'amber':'rose' %>-600 font-semibold"><%= pct %>%</p>
          </div>
        </div>
        <% }) %>
        <% if (!results.length) { %>
        <div class="py-16 text-center text-slate-400">
          <svg class="w-12 h-12 text-slate-200 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          No results yet.
        </div>
        <% } %>
      </div>
      <div class="px-6 py-5 border-t border-slate-100 text-center">
        <a href="/student/tests" class="inline-flex items-center gap-2 bg-navy-950 text-white px-6 py-2.5 rounded-xl font-semibold hover:bg-navy-900 transition-colors text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          Back to Tests
        </a>
      </div>
    </div>
  </div>
</div>
</body></html>
