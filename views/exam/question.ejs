<%- include('../partials/head') %>
<style>
  body{overflow:hidden}
  .opt-box{border:2px solid #e2e8f0;border-radius:12px;padding:16px;transition:border-color .15s,background .15s;cursor:pointer}
  .opt-box:hover{border-color:#8199f8;background:#f8faff}
  .opt-box.selected{border-color:#131330;background:#f0f4ff}
  .palette-btn{width:34px;height:34px;font-size:11px;font-weight:700;border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .15s}
  #timer.warning{background:rgba(253,230,138,.3);color:#d97706}
  #timer.urgent{background:rgba(254,202,202,.4);color:#dc2626;animation:pulse 1s infinite}
  @keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.04)}}
  .timer-warning{animation:pulse 1s infinite}
</style>

<div class="h-screen flex flex-col bg-slate-100" id="examContainer">

  <!-- Topbar -->
  <div class="bg-navy-950 text-white px-4 py-2.5 flex items-center justify-between flex-shrink-0 select-none">
    <div class="flex items-center gap-3 min-w-0">
      <span class="font-bold text-sm hidden sm:block text-white/80 shrink-0"><%= collegeShort %></span>
      <span class="text-white/30 hidden sm:block">|</span>
      <span class="text-sm font-medium truncate"><%= test.title %></span>
    </div>
    <div class="flex items-center gap-3 shrink-0">
      <div id="violationBar" class="<%= violations>0?'flex':'hidden' %> items-center gap-1.5 bg-rose-600 rounded-lg px-3 py-1.5 text-xs font-bold">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        <span id="violationCount"><%= violations %></span> Violation<span id="violPlural"><%= violations!==1?'s':'' %></span>
      </div>
      <button onclick="toggleFullscreen()" class="text-white/60 hover:text-white text-xs hidden sm:flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/></svg>
        Fullscreen
      </button>
      <div id="timer" class="flex items-center gap-2 bg-white/15 border border-white/20 rounded-lg px-3 py-1.5 font-mono font-bold text-sm">
        <svg class="w-4 h-4 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span id="timerDisplay">--:--:--</span>
      </div>
      <span class="text-xs text-white/50 hidden md:block"><%= currentUser.rollNo %></span>
    </div>
  </div>

  <!-- Warn banner -->
  <div id="warnBanner" class="hidden bg-rose-600 text-white text-center text-sm font-semibold py-2 px-4 flex-shrink-0"></div>

  <div class="flex flex-1 overflow-hidden">
    <!-- Question panel -->
    <div class="flex-1 flex flex-col overflow-hidden bg-white">

      <!-- Question header -->
      <div class="flex items-center justify-between px-5 py-3 border-b border-slate-100 bg-slate-50 flex-shrink-0">
        <div class="flex items-center gap-2.5">
          <span class="bg-navy-950 text-white text-xs font-bold px-3 py-1 rounded-full">Q <%= questionNumber %> / <%= totalQuestions %></span>
          <span class="text-xs text-slate-400 hidden sm:block"><%= question.subject %><% if(question.topic){%> &rsaquo; <%= question.topic %><% } %> &middot; <%= question.difficulty %> &middot; <%= question.marks %> mark(s)</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-xs text-slate-400 hidden sm:block">This Q: <span id="qTimer" class="font-mono font-semibold text-slate-600">0s</span></span>
          <button id="markReviewBtn" onclick="toggleMark()"
            class="text-xs font-semibold px-3 py-1.5 rounded-lg border transition-colors <%= isMarked?'bg-violet-600 text-white border-violet-600':'border-slate-200 text-slate-600 hover:border-violet-300' %>">
            <%= isMarked?'Marked':'Mark for Review' %>
          </button>
          <button onclick="clearAnswer()" class="text-xs font-semibold px-3 py-1.5 rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50">Clear</button>
        </div>
      </div>

      <!-- Question content -->
      <div class="flex-1 overflow-y-auto px-5 lg:px-8 py-5">
        <p class="text-base font-medium text-slate-900 leading-relaxed mb-4"><%= question.question %></p>
        <% if (question.questionImage) { %>
        <img src="<%= question.questionImage %>" alt="Question" class="max-w-full max-h-52 rounded-xl border border-slate-200 object-contain mb-4"/>
        <% } %>

        <div class="space-y-3" id="optionsContainer">
          <% options.forEach(opt => { %>
          <div class="opt-box <%= selectedAnswer===opt.key?'selected':'' %>" onclick="selectOption('<%= opt.key %>', this)">
            <div class="flex items-start gap-3">
              <span class="opt-key w-7 h-7 rounded-full border-2 flex items-center justify-center text-xs font-bold shrink-0 mt-0.5
                <%= selectedAnswer===opt.key?'bg-navy-950 border-navy-950 text-white':'border-slate-300 text-slate-500' %>">
                <%= opt.key %>
              </span>
              <span class="text-sm text-slate-800 leading-relaxed pt-0.5"><%= opt.value %></span>
            </div>
            <% if (opt.image) { %>
            <img src="<%= opt.image %>" alt="Option <%= opt.key %>" class="max-w-full max-h-36 rounded-xl border border-slate-200 object-contain mt-2 ml-10"/>
            <% } %>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Navigation -->
      <div class="border-t border-slate-100 px-5 py-4 flex items-center justify-between bg-white flex-shrink-0">
        <% if (questionNumber > 1) { %>
        <a href="/exam/<%= test.id %>/question/<%= questionNumber-1 %>" onclick="saveAndNav(event, this.href)"
          class="flex items-center gap-2 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold px-5 py-2.5 rounded-xl transition-colors text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>Prev
        </a>
        <% } else { %><div></div><% } %>

        <button onclick="submitConfirm()" class="bg-rose-600 hover:bg-rose-700 text-white font-semibold px-5 py-2.5 rounded-xl transition-colors text-sm">Submit Exam</button>

        <% if (questionNumber < totalQuestions) { %>
        <a href="/exam/<%= test.id %>/question/<%= questionNumber+1 %>" onclick="saveAndNav(event, this.href)"
          class="flex items-center gap-2 bg-navy-950 hover:bg-navy-900 text-white font-semibold px-5 py-2.5 rounded-xl transition-colors text-sm">
          Save &amp; Next <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
        <% } else { %>
        <button onclick="submitConfirm()" class="flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold px-5 py-2.5 rounded-xl transition-colors text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>Finish
        </button>
        <% } %>
      </div>
    </div>

    <!-- Palette panel -->
    <div id="paletteSidebar" class="fixed md:relative inset-y-0 right-0 w-72 md:w-56 bg-white border-l border-slate-200 flex flex-col flex-shrink-0 overflow-hidden z-40 transform translate-x-full md:translate-x-0 transition-transform duration-300 shadow-2xl md:shadow-none">
      <div class="px-4 py-3 border-b border-slate-100 bg-slate-50">
        <p class="text-xs font-bold text-slate-700 uppercase tracking-wider mb-2">Question Palette</p>
        <div class="grid grid-cols-2 gap-1 text-[10px] text-slate-500">
          <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-emerald-500 inline-block"></span>Answered</span>
          <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-rose-500 inline-block"></span>Not Ans.</span>
          <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-violet-500 inline-block"></span>Marked</span>
          <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-slate-300 inline-block"></span>Not Visited</span>
        </div>
      </div>
      <div class="flex-1 overflow-y-auto p-3">
        <div class="flex flex-wrap gap-1.5">
          <% paletteStatus.forEach(p => {
            const bg = p.status==='answered'?'background:#10b981;color:#fff':p.status==='marked'?'background:#8b5cf6;color:#fff':p.status==='answered-marked'?'background:#6d28d9;color:#fff':p.status==='not-answered'?'background:#f43f5e;color:#fff':'background:#e2e8f0;color:#475569';
          %>
          <a href="/exam/<%= test.id %>/question/<%= p.num %>" onclick="saveAndNav(event, this.href)"
            class="palette-btn <%= p.num===questionNumber?'ring-2 ring-offset-1 ring-navy-950 scale-110':'' %>"
            style="<%= bg %>">
            <%= p.num %>
          </a>
          <% }) %>
        </div>
      </div>
      <div class="border-t border-slate-100 p-4 text-xs text-slate-600 space-y-1.5">
        <% const answered=paletteStatus.filter(p=>['answered','answered-marked'].includes(p.status)).length %>
        <% const marked=paletteStatus.filter(p=>['marked','answered-marked'].includes(p.status)).length %>
        <div class="flex justify-between"><span>Answered</span><span class="font-bold text-emerald-600"><%= answered %></span></div>
        <div class="flex justify-between"><span>Unanswered</span><span class="font-bold text-rose-500"><%= totalQuestions-answered %></span></div>
        <div class="flex justify-between"><span>Marked</span><span class="font-bold text-violet-600"><%= marked %></span></div>
        <div class="flex justify-between border-t border-slate-100 pt-1.5"><span>Total</span><span class="font-bold"><%= totalQuestions %></span></div>
      </div>
    </div>
  </div>
</div>

<!-- Submit confirm modal -->
<div id="submitModal" class="hidden fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-card-lg w-full max-w-md p-8 text-center">
    <div class="w-14 h-14 bg-rose-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
      <svg class="w-7 h-7 text-rose-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
    </div>
    <h3 class="text-xl font-bold text-slate-900 mb-2">Submit Exam?</h3>
    <p class="text-slate-500 text-sm mb-5">Once submitted, you cannot change your answers.</p>
    <div class="grid grid-cols-3 gap-3 bg-slate-50 rounded-xl p-4 mb-5 text-sm">
      <div><p class="text-2xl font-bold text-emerald-600"><%= paletteStatus.filter(p=>['answered','answered-marked'].includes(p.status)).length %></p><p class="text-xs text-slate-500">Answered</p></div>
      <div><p class="text-2xl font-bold text-rose-500"><%= totalQuestions-paletteStatus.filter(p=>['answered','answered-marked'].includes(p.status)).length %></p><p class="text-xs text-slate-500">Unanswered</p></div>
      <div><p class="text-2xl font-bold text-violet-600"><%= paletteStatus.filter(p=>['marked','answered-marked'].includes(p.status)).length %></p><p class="text-xs text-slate-500">Marked</p></div>
    </div>
    <div class="flex gap-3">
      <form action="/exam/<%= test.id %>/submit" method="POST" class="flex-1" onsubmit="allowLeave()">
        <button type="submit" class="w-full bg-rose-600 text-white font-bold py-3 rounded-xl hover:bg-rose-700 transition-colors">Yes, Submit</button>
      </form>
      <button onclick="document.getElementById('submitModal').classList.add('hidden')" class="flex-1 border-2 border-slate-200 text-slate-700 font-semibold py-3 rounded-xl hover:bg-slate-50 transition-colors">Cancel</button>
    </div>
  </div>
</div>

<!-- Tab-switch auto-submit overlay -->
<div id="tabSwitchOverlay" class="hidden fixed inset-0 z-[999] bg-black/90 flex items-center justify-center p-6">
  <div class="bg-white rounded-3xl max-w-sm w-full p-8 text-center shadow-card-lg">
    <div class="w-16 h-16 bg-rose-100 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-rose-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
    </div>
    <h2 class="text-xl font-bold text-slate-900 mb-2">Tab Switch Detected</h2>
    <p class="text-slate-600 text-sm mb-6 leading-relaxed">You have left the exam window. This is a violation.<br><strong class="text-rose-600">Auto-submitting in:</strong></p>
    <div class="text-6xl font-bold text-rose-600 mb-6 timer-warning" id="tabCountdown">3</div>
    <p class="text-xs text-slate-400">This incident has been logged.</p>
  </div>
</div>

<!-- Single auto-submit form (only one!) -->
<form id="autoSubmitForm" action="/exam/<%= test.id %>/submit" method="POST" class="hidden">
  <input type="hidden" name="auto" value="true"/>
</form>

<script>
// ── Core vars ──────────────────────────────────────────────────────────────
const TEST_ID     = '<%= test.id %>';
const QUESTION_ID = '<%= question.id %>';
let currentAnswer = '<%= selectedAnswer || "" %>';
let markedForReview = <%- isMarked ? 'true' : 'false' %>;
let qElapsed = 0;
let navInProgress = false;

// ── Per-test anti-cheat settings (from admin) ────────────────────────────
const SETTINGS = {
  autoSubmitOnViolation: <%- test.autoSubmitOnViolation ? 'true' : 'false' %>,
  maxTabSwitches:  <%= test.maxTabSwitches  || 3 %>,
  maxFocusLosses:  <%= test.maxFocusLosses  || 5 %>,
  blockCopyPaste:  <%- test.blockCopyPaste  !== false ? 'true' : 'false' %>,
  requireFullscreen: <%- test.requireFullscreen ? 'true' : 'false' %>,
};
let tabSwitchCount  = <%= (result && result.cheatingFlags && result.cheatingFlags.tabSwitches)  || 0 %>;
let focusLossCount  = <%= (result && result.cheatingFlags && result.cheatingFlags.focusLosses)  || 0 %>;

// ── Timer ──────────────────────────────────────────────────────────────────
const fmt = s => `${String(Math.floor(s/3600)).padStart(2,'0')}:${String(Math.floor((s%3600)/60)).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`;
let remaining = <%= remaining %>;
const timerEl = document.getElementById('timer');
const timerDisplay = document.getElementById('timerDisplay');
timerDisplay.textContent = fmt(remaining);

const countdown = setInterval(() => {
  remaining--;
  timerDisplay.textContent = fmt(Math.max(0, remaining));
  // Reset timer classes cleanly before setting new ones
  timerEl.classList.remove('warning', 'urgent');
  if (remaining <= 60)       timerEl.classList.add('urgent');
  else if (remaining <= 300) timerEl.classList.add('warning');
  if (remaining <= 0) { clearInterval(countdown); allowLeave(); document.getElementById('autoSubmitForm').submit(); }
}, 1000);

// Per-question timer
const qTimerEl = document.getElementById('qTimer');
setInterval(() => {
  qElapsed++;
  qTimerEl.textContent = qElapsed > 60 ? `${Math.floor(qElapsed/60)}m ${qElapsed%60}s` : `${qElapsed}s`;
}, 1000);

// ── Select option (click on box) ───────────────────────────────────────────
function selectOption(key, boxEl) {
  // Clear all boxes
  document.querySelectorAll('.opt-box').forEach(b => {
    b.classList.remove('selected');
    const keySpan = b.querySelector('.opt-key');
    if (keySpan) { keySpan.className = keySpan.className.replace('bg-navy-950 border-navy-950 text-white','').trim() + ' border-slate-300 text-slate-500'; }
  });
  // Select clicked
  boxEl.classList.add('selected');
  const keySpan = boxEl.querySelector('.opt-key');
  if (keySpan) { keySpan.className = keySpan.className.replace('border-slate-300 text-slate-500','').trim() + ' bg-navy-950 border-navy-950 text-white'; }
  currentAnswer = key;
  saveToServer(key);
}

// ── Clear answer ───────────────────────────────────────────────────────────
function clearAnswer() {
  document.querySelectorAll('.opt-box').forEach(b => {
    b.classList.remove('selected');
    const ks = b.querySelector('.opt-key');
    if (ks) { ks.className = ks.className.replace('bg-navy-950 border-navy-950 text-white','').trim() + ' border-slate-300 text-slate-500'; }
  });
  currentAnswer = '';
  saveToServer('');
}

// ── Mark for review ────────────────────────────────────────────────────────
function toggleMark() {
  markedForReview = !markedForReview;
  const btn = document.getElementById('markReviewBtn');
  if (markedForReview) {
    btn.className = 'text-xs font-semibold px-3 py-1.5 rounded-lg border transition-colors bg-violet-600 text-white border-violet-600';
    btn.textContent = 'Marked';
  } else {
    btn.className = 'text-xs font-semibold px-3 py-1.5 rounded-lg border transition-colors border-slate-200 text-slate-600 hover:border-violet-300';
    btn.textContent = 'Mark for Review';
  }
  saveToServer(currentAnswer);
}

// ── Save to server (with offline fallback) ───────────────────────────────
function saveToServer(ans) {
  const payload = { questionId: QUESTION_ID, answer: ans, markForReview: markedForReview, timeSpent: qElapsed };
  const url = `/exam/${TEST_ID}/save-answer`;

  if (!navigator.onLine) {
    // Queue for background sync
    if (typeof window.queueOfflineAnswer === 'function') {
      window.queueOfflineAnswer(url, payload);
    }
    console.warn('[Exam] Offline — answer queued for sync');
    return Promise.resolve();
  }

  return fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload),
  }).then(r => r.json()).catch(() => {
    // Network failed mid-request — queue it
    if (typeof window.queueOfflineAnswer === 'function') {
      window.queueOfflineAnswer(url, payload);
    }
  });
}

// ── Navigate with save (wait for save before nav) ──────────────────────────
function saveAndNav(e, href) {
  e.preventDefault();
  if (navInProgress) return;
  navInProgress = true;
  saveToServer(currentAnswer).finally(() => { allowLeave(); window.location.href = href; });
}

// ── Submit confirm ─────────────────────────────────────────────────────────
function submitConfirm() { document.getElementById('submitModal').classList.remove('hidden'); }

// ── Fullscreen ─────────────────────────────────────────────────────────────
function toggleFullscreen() {
  if (!document.fullscreenElement) document.documentElement.requestFullscreen?.().catch(()=>{});
  else document.exitFullscreen?.();
}
window.addEventListener('load', () => setTimeout(() => document.documentElement.requestFullscreen?.().catch(()=>{}), 600));
document.addEventListener('fullscreenchange', () => {
  if (!document.fullscreenElement && SETTINGS.requireFullscreen) {
    reportViolation('fullscreenExit');
    showWarnBanner('⚠ Fullscreen exited! Click the fullscreen button to re-enter.', 'danger');
  }
});

// ── Violation report ───────────────────────────────────────────────────────
function reportViolation(type, onAutoSubmit) {
  return fetch(`/exam/${TEST_ID}/report-violation`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ type }),
  }).then(r => r.json()).then(d => {
    if (d.violations !== undefined) {
      document.getElementById('violationCount').textContent = d.violations;
      document.getElementById('violPlural').textContent = d.violations !== 1 ? 's' : '';
      document.getElementById('violationBar').classList.remove('hidden');
      document.getElementById('violationBar').classList.add('flex');
    }
    // Update local counts
    if (type === 'tabSwitch') tabSwitchCount = d.tabSwitches || tabSwitchCount + 1;
    if (type === 'focusLoss') focusLossCount++;

    // Show remaining warnings
    if (SETTINGS.autoSubmitOnViolation && type === 'tabSwitch') {
      const remaining = Math.max(0, SETTINGS.maxTabSwitches - tabSwitchCount);
      if (remaining > 0) {
        showWarnBanner(`⚠ Tab switch warning! ${remaining} more allowed before auto-submit.`, d.warningLevel === 'danger' ? 'danger' : 'warning');
      }
    }
    // Auto-submit if server says so
    if (d.autoSubmit) {
      showAutoSubmitOverlay(d.warningMsg || 'Exam auto-submitted due to violations.');
    }
    return d;
  }).catch(() => {});
}

function showWarnBanner(msg, level = 'warning') {
  const b = document.getElementById('warnBanner');
  b.textContent = msg;
  b.className = b.className.replace(/bg-\S+/g, '');
  b.classList.add(level === 'danger' ? 'bg-red-700' : 'bg-amber-600');
  b.classList.remove('hidden');
  setTimeout(() => b.classList.add('hidden'), 6000);
}

function showAutoSubmitOverlay(msg) {
  const overlay = document.getElementById('tabSwitchOverlay');
  const msgEl = document.getElementById('tabSwitchMsg');
  if (msgEl) msgEl.textContent = msg;
  overlay.classList.remove('hidden');
  let count = 5;
  document.getElementById('tabCountdown').textContent = count;
  const t = setInterval(() => {
    count--;
    document.getElementById('tabCountdown').textContent = count;
    if (count <= 0) {
      clearInterval(t);
      saveToServer(currentAnswer).finally(() => { allowLeave(); document.getElementById('autoSubmitForm').submit(); });
    }
  }, 1000);
}

// ── Anti-cheat: tab switch detection ────────────────────────────────────
document.addEventListener('visibilitychange', () => {
  if (document.visibilityState === 'hidden') {
    reportViolation('tabSwitch');
  }
});
let blurTimer;
window.addEventListener('blur', () => {
  blurTimer = setTimeout(() => {
    if (!document.hasFocus()) reportViolation('focusLoss');
  }, 800);
});
window.addEventListener('focus', () => clearTimeout(blurTimer));

// Block copy/paste if enabled by admin
if (SETTINGS.blockCopyPaste) {
  document.addEventListener('contextmenu', e => e.preventDefault());
  document.addEventListener('copy',  e => e.preventDefault());
  document.addEventListener('cut',   e => e.preventDefault());
  document.addEventListener('paste', e => e.preventDefault());
  document.addEventListener('keydown', e => {
    if (e.key==='F12' || (e.ctrlKey&&e.shiftKey&&e.key==='I') || (e.ctrlKey&&e.key==='u') || (e.ctrlKey&&e.key==='s')) e.preventDefault();
  });
}

// Fullscreen: only force if admin enabled requireFullscreen
if (SETTINGS.requireFullscreen) {
  window.addEventListener('load', () => setTimeout(() => document.documentElement.requestFullscreen?.().catch(()=>{}), 600));
}
window.addEventListener('focus', () => clearTimeout(blurTimer));

// ── Security ───────────────────────────────────────────────────────────────
document.addEventListener('contextmenu', e => e.preventDefault());
document.addEventListener('copy',  e => e.preventDefault());
document.addEventListener('cut',   e => e.preventDefault());
document.addEventListener('keydown', e => {
  if (e.key==='F12' || (e.ctrlKey&&e.shiftKey&&['I','J','C'].includes(e.key)) || (e.ctrlKey&&['u','s','a'].includes(e.key))) e.preventDefault();
});
function _beforeUnload(e) { e.preventDefault(); e.returnValue = ''; }
window.addEventListener('beforeunload', _beforeUnload);
function allowLeave() { window.removeEventListener('beforeunload', _beforeUnload); }
</script>
<div id="paletteOverlay" class="hidden fixed inset-0 bg-black/40 z-30 md:hidden" onclick="togglePalette()"></div>
