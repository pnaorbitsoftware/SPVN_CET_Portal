<%- include('../partials/head') %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<div class="min-h-screen bg-slate-50 py-8 px-4">
  <div class="max-w-4xl mx-auto space-y-6">

    <!-- Score Hero -->
    <div class="bg-white rounded-2xl shadow-card-lg border border-slate-100 overflow-hidden">
      <div class="<%= percentage>=60 ? 'bg-gradient-to-r from-emerald-600 to-emerald-500' : percentage>=40 ? 'bg-gradient-to-r from-amber-500 to-amber-400' : 'bg-gradient-to-r from-rose-600 to-rose-500' %> p-8 text-white text-center">
        <p class="text-white/70 text-sm mb-1"><%= result.test.title %></p>
        <div class="text-7xl font-bold mb-2"><%= percentage %>%</div>
        <p class="text-2xl font-semibold"><%= result.score %> / <%= result.totalMarks %> Marks</p>
        <div class="flex items-center justify-center gap-2 mt-2">
          <% if (result.status === 'auto_submitted') { %>
          <svg class="w-4 h-4 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <span class="text-white/70 text-sm">Auto-submitted</span>
          <% } else { %>
          <svg class="w-4 h-4 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="text-white/70 text-sm">Submitted</span>
          <% } %>
        </div>
      </div>

      <!-- Stats row -->
      <div class="grid grid-cols-3 sm:grid-cols-5 divide-x divide-slate-100 border-b border-slate-100">
        <% [
          {label:'Rank',       value: '#'+(result.rank||'—'),                         icon:'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z', c:'amber'},
          {label:'Correct',    value: result.correctAnswers,                           icon:'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',  c:'emerald'},
          {label:'Wrong',      value: result.wrongAnswers,                             icon:'M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z', c:'rose'},
          {label:'Skipped',    value: result.skippedAnswers,                           icon:'M13 9l3 3m0 0l-3 3m3-3H8m13 0a9 9 0 11-18 0 9 9 0 0118 0z', c:'slate'},
          {label:'Percentile', value: (result.percentile||0).toFixed(1)+'%',          icon:'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', c:'navy'},
        ].forEach(s => { %>
        <div class="p-4 text-center">
          <svg class="w-5 h-5 text-<%= s.c==='navy'?'navy-500':s.c+'-500' %> mx-auto mb-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="<%= s.icon %>"/></svg>
          <p class="text-xl font-bold text-slate-900"><%= s.value %></p>
          <p class="text-xs text-slate-400 mt-0.5"><%= s.label %></p>
        </div>
        <% }) %>
      </div>

      <!-- Time & violations row -->
      <div class="flex items-center justify-between px-6 py-4 text-sm text-slate-500">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Time taken: <strong class="text-slate-700"><%= Math.floor((result.timeTaken||0)/60) %>m <%= (result.timeTaken||0)%60 %>s</strong>
        </span>
        <% if (result.violationCount > 0) { %>
        <span class="flex items-center gap-2 text-rose-600 font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <%= result.violationCount %> tab-switch violation(s)
        </span>
        <% } %>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Subject-wise Breakdown -->
      <% if (result.subjectScores && Object.keys(result.subjectScores).length > 0) { %>
      <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-6">
        <h3 class="font-bold text-slate-900 mb-4 text-sm flex items-center gap-2">
          <svg class="w-5 h-5 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          Subject-wise Breakdown
        </h3>
        <canvas id="subjectChart" height="180" class="mb-4"></canvas>
        <div class="space-y-3">
          <% Object.entries(result.subjectScores).forEach(([subj, data]) => {
            const pct = data.total>0 ? ((data.marks||0)/data.total*100).toFixed(0) : 0;
            const clr = pct>=60?'emerald':pct>=40?'amber':'rose';
          %>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium text-slate-700"><%= subj %></span>
              <span class="font-bold text-<%= clr %>-600"><%= data.marks||0 %>/<%= data.total||0 %> (<%= pct %>%)</span>
            </div>
            <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
              <div class="h-2 rounded-full bg-<%= clr %>-500 transition-all duration-700" style="width:<%= pct %>%"></div>
            </div>
            <div class="flex gap-3 mt-1 text-xs text-slate-400">
              <span class="text-emerald-600 font-medium"><%= data.correct %> correct</span>
              <span class="text-rose-500 font-medium"><%= data.wrong %> wrong</span>
              <span><%= data.skipped %> skipped</span>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- Performance vs Topper -->
      <% if (topperResult && topperResult.subjectScores) { %>
      <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-6">
        <h3 class="font-bold text-slate-900 mb-4 text-sm flex items-center gap-2">
          <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z'/></svg>
          Your Score vs Topper
        </h3>
        <canvas id="comparisonChart" height="220"></canvas>
        <div class="flex items-center justify-center gap-6 mt-3 text-xs text-slate-500">
          <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-navy-500 inline-block"></span>You</span>
          <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-amber-400 inline-block"></span>Topper</span>
        </div>
      </div>
      <% } %>

      <!-- Performance Trend -->
      <% if (trend && trend.length > 1) { %>
      <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-6 lg:col-span-2">
        <h3 class="font-bold text-slate-900 mb-4 text-sm flex items-center gap-2">
          <svg class="w-5 h-5 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
          Your Performance Trend
        </h3>
        <canvas id="trendChart" height="100"></canvas>
      </div>
      <% } %>
    </div>

    <!-- Question Review -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-card overflow-hidden">
      <div class="px-6 py-4 border-b border-slate-50 flex items-center justify-between">
        <h3 class="font-bold text-slate-900 text-sm">Question-by-Question Review</h3>
        <div class="flex gap-2">
          <a href="/results/<%= result.id %>/pdf"
            class="flex items-center gap-1.5 text-xs font-semibold border border-slate-200 text-slate-600 px-3 py-2 rounded-lg hover:bg-slate-50 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            Download PDF
          </a>
          <a href="/results/leaderboard/<%= result.testId %>"
            class="flex items-center gap-1.5 text-xs font-semibold bg-navy-950 text-white px-3 py-2 rounded-lg hover:bg-navy-900 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z'/></svg>
            Leaderboard
          </a>
        </div>
      </div>
      <div class="divide-y divide-slate-50">
        <% result.test.questions.forEach((q, idx) => {
          const given   = result.answers?.[q.id]?.answer;
          const correct = q.correctAnswer;
          const isRight  = given === correct;
          const isSkip   = !given;
          const status   = isSkip ? 'skipped' : isRight ? 'correct' : 'wrong';
          const statusClr= isSkip?'slate':isRight?'emerald':'rose';
        %>
        <div class="px-6 py-4">
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold shrink-0 bg-<%= statusClr %>-<%= isSkip?'300':'500' %>">
              <%= idx+1 %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-slate-900 leading-relaxed mb-2"><%= q.question %></p>
              <div class="flex flex-wrap gap-2 mb-2">
                <% ['A','B','C','D'].forEach(opt => {
                  const val = q['option'+opt];
                  const isCorrectOpt = opt === correct;
                  const isGivenOpt   = opt === given;
                  let cls = 'bg-slate-50 text-slate-600 border-slate-200';
                  if (isCorrectOpt) cls = 'bg-emerald-50 text-emerald-800 border-emerald-300 font-semibold';
                  if (isGivenOpt && !isRight) cls = 'bg-rose-50 text-rose-800 border-rose-300 line-through';
                %>
                <span class="border rounded-lg px-3 py-1.5 text-xs <%= cls %>"><strong><%= opt %>.</strong> <%= val %></span>
                <% }) %>
              </div>
              <div class="flex flex-wrap items-center gap-3 text-xs text-slate-400">
                <span class="font-semibold text-<%= statusClr %>-600 capitalize"><%= status %></span>
                <% if (!isSkip) { %><span>Your: <strong><%= given %></strong></span><% } %>
                <span>Correct: <strong class="text-emerald-600"><%= correct %></strong></span>
                <% if (q.subject) { %><span class="bg-slate-100 px-2 py-0.5 rounded-full"><%= q.subject %></span><% } %>
                <% if (q.difficulty) { %><span class="bg-slate-100 px-2 py-0.5 rounded-full"><%= q.difficulty %></span><% } %>
              </div>
              <% if (q.explanation) { %>
              <div class="mt-2 bg-amber-50 border border-amber-200 rounded-lg px-3 py-2 text-xs text-amber-800 leading-relaxed">
                <strong>Explanation:</strong> <%= q.explanation %>
              </div>
              <% } %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <div class="flex justify-center pb-4">
      <a href="/student/tests" class="flex items-center gap-2 bg-navy-950 text-white px-6 py-3 rounded-xl font-semibold hover:bg-navy-900 transition-colors text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Back to Tests
      </a>
    </div>
  </div>
</div>

<script>
<% if (result.subjectScores && Object.keys(result.subjectScores).length > 0) { %>
const subjectLabels = <%- JSON.stringify(Object.keys(result.subjectScores)) %>;
const subjectMarks  = <%- JSON.stringify(Object.values(result.subjectScores).map(d=>d.marks||0)) %>;
const subjectTotals = <%- JSON.stringify(Object.values(result.subjectScores).map(d=>d.total||0)) %>;
new Chart(document.getElementById('subjectChart'), {
  type: 'bar',
  data: {
    labels: subjectLabels,
    datasets: [
      { label:'Your Marks', data: subjectMarks, backgroundColor:'rgba(19,19,48,0.85)', borderRadius:6 },
      { label:'Total Marks', data: subjectTotals, backgroundColor:'rgba(226,232,240,0.8)', borderRadius:6 },
    ],
  },
  options: { plugins:{legend:{display:false}}, scales:{y:{beginAtZero:true}}, responsive:true, maintainAspectRatio:true },
});
<% } %>

<% if (topperResult && topperResult.subjectScores && result.subjectScores) { %>
const cmpLabels  = <%- JSON.stringify(Object.keys(result.subjectScores)) %>;
const cmpYou     = <%- JSON.stringify(Object.values(result.subjectScores).map(d=>d.total>0?Math.round((d.marks||0)/d.total*100):0)) %>;
const cmpTopper  = <%- JSON.stringify(Object.keys(result.subjectScores).map(k => { const d=topperResult.subjectScores?.[k]; return d&&d.total>0?Math.round((d.marks||0)/d.total*100):0; })) %>;
new Chart(document.getElementById('comparisonChart'), {
  type: 'radar',
  data: {
    labels: cmpLabels,
    datasets: [
      { label:'You',    data: cmpYou,    borderColor:'#131330', backgroundColor:'rgba(19,19,48,0.15)', pointBackgroundColor:'#131330', borderWidth:2 },
      { label:'Topper', data: cmpTopper, borderColor:'#f59e0b', backgroundColor:'rgba(245,158,11,0.10)', pointBackgroundColor:'#f59e0b', borderWidth:2 },
    ],
  },
  options: { plugins:{legend:{display:false}}, scales:{r:{beginAtZero:true,max:100,ticks:{stepSize:25}}}, responsive:true },
});
<% } %>

<% if (trend && trend.length > 1) { %>
new Chart(document.getElementById('trendChart'), {
  type: 'line',
  data: {
    labels: <%- JSON.stringify(trend.map(r=>r.test?.title?.substring(0,15)||'Test')) %>,
    datasets: [{
      label:'Score %',
      data: <%- JSON.stringify(trend.map(r=>r.totalMarks>0?parseFloat(((r.score/r.totalMarks)*100).toFixed(1)):0)) %>,
      borderColor:'#131330', backgroundColor:'rgba(19,19,48,0.08)',
      tension:0.4, fill:true, pointBackgroundColor:'#131330', pointRadius:5, borderWidth:2,
    }],
  },
  options: { plugins:{legend:{display:false}}, scales:{y:{beginAtZero:true,max:100}}, responsive:true, maintainAspectRatio:true },
});
<% } %>
</script>
</body></html>
