<%- include('../partials/head') %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<div class="min-h-screen bg-slate-50 py-10 px-4">
  <div class="max-w-4xl mx-auto space-y-6">

    <!-- Score Hero -->
    <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
      <div class="bg-gradient-to-r <%= percentage>=60?'from-green-600 to-emerald-600':percentage>=40?'from-yellow-500 to-amber-500':'from-red-600 to-rose-600' %> p-8 text-white text-center">
        <p class="text-white/70 text-sm mb-1"><%= result.test.title %></p>
        <div class="text-7xl font-bold mb-2"><%= percentage %>%</div>
        <p class="text-2xl font-semibold"><%= result.score %> / <%= result.totalMarks %> Marks</p>
        <p class="text-white/70 mt-1 text-sm"><%= result.status==='auto_submitted'?'Auto-submitted':'Submitted' %></p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-5 divide-x divide-gray-100 border-b">
        <% [
          {icon:'🥇',label:'Rank',value:'#'+(result.rank||'—')},
          {icon:'correct',label:'Correct',value:result.correctAnswers},
          {icon:'wrong',label:'Wrong',value:result.wrongAnswers},
          {icon:'skip',label:'Skipped',value:result.skippedAnswers},
          {icon:'pct',label:'Percentile',value:(result.percentile||0).toFixed(1)+'%'},
        ].forEach(s => { %>
        <div class="p-4 text-center">
          <p class="text-xl mb-1"><%= s.icon %></p>
          <p class="text-xl font-bold text-slate-900"><%= s.value %></p>
          <p class="text-xs text-slate-500"><%= s.label %></p>
        </div>
        <% }) %>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Subject-wise Breakdown -->
      <% if (result.subjectScores && Object.keys(result.subjectScores).length > 0) { %>
      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
        <h3 class="font-bold text-slate-900 mb-4">📚 Subject-wise Breakdown</h3>
        <canvas id="subjectChart" height="200"></canvas>
        <div class="mt-4 space-y-3">
          <% Object.entries(result.subjectScores).forEach(([subj, data]) => {
            const pct = data.total > 0 ? ((data.marks||0)/data.total*100).toFixed(0) : 0;
          %>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium text-slate-700"><%= subj %></span>
              <span class="font-bold <%= pct>=60?'text-green-600':pct>=40?'text-yellow-600':'text-red-500' %>"><%= data.marks||0 %>/<%= data.total||0 %> (<%= pct %>%)</span>
            </div>
            <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
              <div class="h-2 rounded-full <%= pct>=60?'bg-green-500':pct>=40?'bg-yellow-500':'bg-red-500' %>" style="width:<%= pct %>%"></div>
            </div>
            <div class="flex gap-3 text-xs text-slate-500 mt-1">
              <span><%= data.correct %> correct</span><span><%= data.wrong %> wrong</span><span><%= data.skipped %> skipped</span>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- Weak Topics -->
      <% if (result.topicScores && Object.keys(result.topicScores).length > 0) { %>
      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
        <h3 class="font-bold text-slate-900 mb-4">🎯 Topic Analysis</h3>
        <div class="space-y-3">
          <% const sortedTopics = Object.entries(result.topicScores).sort((a,b) => {
            const accA = a[1].correct/(a[1].correct+a[1].wrong+a[1].skipped||1);
            const accB = b[1].correct/(b[1].correct+b[1].wrong+b[1].skipped||1);
            return accA - accB; // weakest first
          }) %>
          <% sortedTopics.forEach(([topic, data]) => {
            const total = data.correct + data.wrong + data.skipped;
            const acc = total > 0 ? Math.round((data.correct/total)*100) : 0;
          %>
          <div class="flex items-center gap-3 p-3 rounded-xl border <%= acc < 50 ? 'bg-red-50 border-red-200' : acc < 75 ? 'bg-yellow-50 border-yellow-200' : 'bg-green-50 border-green-200' %>">
            <span class="text-lg"><%= acc<50?'🔴':acc<75?'🟡':'🟢' %></span>
            <div class="flex-1">
              <p class="text-sm font-semibold text-slate-800"><%= topic %></p>
              <p class="text-xs text-slate-500"><%= data.correct %> correct <%= data.wrong %> wrong <%= data.skipped %> skipped</p>
            </div>
            <span class="font-bold text-sm <%= acc<50?'text-red-600':acc<75?'text-yellow-600':'text-green-600' %>"><%= acc %>%</span>
          </div>
          <% }) %>
        </div>
        <% if (sortedTopics.filter(([,d])=>(d.correct/(d.correct+d.wrong+d.skipped||1))<0.5).length > 0) { %>
        <div class="mt-4 bg-red-50 border border-red-200 rounded-xl p-3">
          <p class="text-xs font-semibold text-red-700 mb-1">📌 Topics needing improvement:</p>
          <% sortedTopics.filter(([,d])=>{ const t=d.correct+d.wrong+d.skipped; return t>0&&(d.correct/t)<0.5; }).forEach(([topic]) => { %>
          <span class="inline-block bg-red-100 text-red-700 text-xs px-2 py-0.5 rounded-full mr-1 mb-1"><%= topic %></span>
          <% }) %>
        </div>
        <% } %>
      </div>
      <% } %>

      <!-- Topper Comparison -->
      <% if (topperResult && topperResult.score > 0 && result.rank !== 1) { %>
      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
        <h3 class="font-bold text-slate-900 mb-4">🏆 Your Score vs Topper</h3>
        <canvas id="comparisonChart" height="200"></canvas>
        <% if (topperResult.subjectScores && result.subjectScores) { %>
        <div class="mt-4 space-y-2">
          <% Object.entries(result.subjectScores).forEach(([subj, data]) => {
            const topperData = topperResult.subjectScores[subj];
            if (!topperData) return;
            const myPct = data.total>0?Math.round((data.marks||0)/data.total*100):0;
            const topPct = topperData.total>0?Math.round((topperData.marks||0)/topperData.total*100):0;
          %>
          <div class="text-xs">
            <div class="flex justify-between mb-0.5">
              <span class="text-slate-600 font-medium"><%= subj %></span>
              <span class="text-slate-500">You: <span class="font-bold text-indigo-600"><%= myPct %>%</span> · Topper: <span class="font-bold text-amber-600"><%= topPct %>%</span></span>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>
      <% } %>

      <!-- Performance Trend -->
      <% if (trend && trend.length > 1) { %>
      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
        <h3 class="font-bold text-slate-900 mb-4">📈 Performance Trend</h3>
        <canvas id="trendChart" height="200"></canvas>
      </div>
      <% } %>

      <!-- Question Time Analysis -->
      <% if (result.questionTimings && Object.keys(result.questionTimings).length > 0) { %>
      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
        <h3 class="font-bold text-slate-900 mb-4">⏱ Time per Question</h3>
        <canvas id="timeChart" height="200"></canvas>
        <p class="text-xs text-slate-500 mt-3 text-center">Time distribution across all questions (seconds)</p>
      </div>
      <% } %>

      <!-- Cheating/Violation Report -->
      <% if (result.cheatingFlags && (result.cheatingFlags.tabSwitches>0 || result.cheatingFlags.fullscreenExits>0 || result.cheatingFlags.focusLosses>0)) { %>
      <div class="bg-white rounded-2xl border border-red-200 shadow-sm p-6">
        <h3 class="font-bold text-red-700 mb-4">⚠ Exam Integrity Report</h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-2 border-b border-slate-50"><span class="text-slate-600">Tab Switches</span><span class="font-bold text-red-600"><%= result.cheatingFlags.tabSwitches||0 %></span></div>
          <div class="flex justify-between py-2 border-b border-slate-50"><span class="text-slate-600">Fullscreen Exits</span><span class="font-bold text-red-600"><%= result.cheatingFlags.fullscreenExits||0 %></span></div>
          <div class="flex justify-between py-2"><span class="text-slate-600">Focus Losses</span><span class="font-bold text-red-600"><%= result.cheatingFlags.focusLosses||0 %></span></div>
        </div>
      </div>
      <% } %>

    </div>

    <!-- Details & Actions -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 text-sm mb-4">
        <div><span class="text-slate-500">Student</span><p class="font-semibold"><%= result.student.name %></p></div>
        <div><span class="text-slate-500">Roll No</span><p class="font-semibold font-mono"><%= result.student.rollNo %></p></div>
        <div><span class="text-slate-500">Time Taken</span><p class="font-semibold"><%= Math.floor((result.timeTaken||0)/60) %>m <%= (result.timeTaken||0)%60 %>s</p></div>
        <div><span class="text-slate-500">Out of</span><p class="font-semibold"><%= totalAttempted %> students</p></div>
        <div><span class="text-slate-500">Submitted</span><p class="font-semibold"><%= result.submittedAt?new Date(result.submittedAt).toLocaleString('en-IN'):'—' %></p></div>
        <div><span class="text-slate-500">Violations</span><p class="font-semibold <%= result.violationCount>0?'text-red-600':'' %>"><%= result.violationCount||0 %></p></div>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/results/<%= result.id %>/pdf" class="flex items-center gap-2 bg-red-600 text-white px-5 py-2.5 rounded-xl font-semibold hover:bg-red-700 transition-colors text-sm">📄 Download PDF</a>
        <a href="/results/leaderboard/<%= result.testId %>" class="flex items-center gap-2 bg-primary-800 text-white px-5 py-2.5 rounded-xl font-semibold hover:bg-primary-900 transition-colors text-sm">🏆 Leaderboard</a>
        <% if (currentUser.role==='student') { %>
        <a href="/student/tests" class="flex items-center gap-2 bg-slate-100 text-slate-700 px-5 py-2.5 rounded-xl font-semibold hover:bg-slate-200 transition-colors text-sm">← Back to Tests</a>
        <% } %>
      </div>
    </div>

  </div>
</div>

<script>
// ── Subject-wise Bar Chart ────────────────────────────────────────────────────
<% if (result.subjectScores && Object.keys(result.subjectScores).length > 0) { %>
new Chart(document.getElementById('subjectChart'), {
  type: 'bar',
  data: {
    labels: <%- JSON.stringify(Object.keys(result.subjectScores)) %>,
    datasets: [
      { label: 'Your %', data: <%- JSON.stringify(Object.values(result.subjectScores).map(d=>d.total>0?parseFloat(((d.marks||0)/d.total*100).toFixed(1)):0)) %>, backgroundColor: 'rgba(79,70,229,0.7)', borderRadius: 6 },
      <% if (topperResult && topperResult.subjectScores && result.subjectScores) { %>
      { label: 'Topper %', data: <%- JSON.stringify(Object.keys(result.subjectScores).map(s=>{ const d=(topperResult.subjectScores||{})[s]; return d&&d.total>0?parseFloat((d.marks||0)/d.total*100).toFixed(1):0; })) %>, backgroundColor: 'rgba(245,158,11,0.7)', borderRadius: 6 },
      <% } %>
    ]
  },
  options: { responsive:true, plugins:{legend:{position:'top'}}, scales:{y:{beginAtZero:true,max:100,ticks:{callback:v=>v+'%'}}} }
});
<% } %>

// ── Trend Line Chart ──────────────────────────────────────────────────────────
<% if (trend && trend.length > 1) { %>
new Chart(document.getElementById('trendChart'), {
  type: 'line',
  data: {
    labels: <%- JSON.stringify(trend.map((t,i)=>`Test ${i+1}`)) %>,
    datasets: [{
      label: 'Score %',
      data: <%- JSON.stringify(trend.map(t=>t.totalMarks>0?parseFloat((t.score/t.totalMarks*100).toFixed(1)):0)) %>,
      borderColor: 'rgb(79,70,229)', backgroundColor: 'rgba(79,70,229,0.1)',
      tension: 0.4, fill: true, pointRadius: 5
    }]
  },
  options: { responsive:true, plugins:{legend:{display:false}}, scales:{y:{beginAtZero:true,max:100,ticks:{callback:v=>v+'%'}}} }
});
<% } %>

// ── Question Time Chart ───────────────────────────────────────────────────────
<% if (result.questionTimings && Object.keys(result.questionTimings).length > 0) { %>
const timings = <%- JSON.stringify(result.questionTimings) %>;
const qNums = Object.keys(timings).map((_,i)=>`Q${i+1}`);
const qTimes = Object.values(timings);
new Chart(document.getElementById('timeChart'), {
  type: 'bar',
  data: {
    labels: qNums,
    datasets: [{ label: 'Seconds', data: qTimes, backgroundColor: 'rgba(16,185,129,0.7)', borderRadius: 4 }]
  },
  options: { responsive:true, plugins:{legend:{display:false}}, scales:{y:{beginAtZero:true}} }
});
<% } %>

// ── Comparison Doughnut ───────────────────────────────────────────────────────
<% if (topperResult && topperResult.score > 0 && result.rank !== 1) { %>
new Chart(document.getElementById('comparisonChart'), {
  type: 'doughnut',
  data: {
    labels: ['Your Score', 'Topper Score', 'Remaining'],
    datasets: [{
      data: [<%= result.score %>, <%= topperResult.score %>, Math.max(0, <%= result.totalMarks %> - Math.max(<%= result.score %>, <%= topperResult.score %>))],
      backgroundColor: ['rgba(79,70,229,0.8)','rgba(245,158,11,0.8)','rgba(229,231,235,0.8)'],
      borderWidth: 0
    }]
  },
  options: { responsive:true, plugins:{ legend:{ position:'bottom' } }, cutout:'60%' }
});
<% } %>
</script>
</body></html>
