<%- include('../partials/head') %>
<div class="min-h-screen bg-slate-50 py-8 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="bg-white rounded-2xl shadow-card-lg border border-slate-200 overflow-hidden">
      <!-- Header -->
      <div class="bg-navy-950 p-8 text-white">
        <div class="flex items-center gap-2 mb-3">
          <span class="bg-white/15 text-xs font-semibold px-3 py-1 rounded-full border border-white/20">EXAM</span>
          <% if (test.course) { %><span class="bg-amber-500/20 text-amber-300 text-xs font-semibold px-3 py-1 rounded-full border border-amber-400/30"><%= test.course %></span><% } %>
          <% if (test.status==='published') { %><span class="bg-emerald-500/20 text-emerald-300 text-xs font-semibold px-3 py-1 rounded-full border border-emerald-400/30">Available</span><% } %>
        </div>
        <h1 class="text-2xl font-bold mb-1 leading-snug"><%= test.title %></h1>
        <p class="text-white/50 text-sm"><%= process.env.COLLEGE_NAME %></p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 divide-x divide-slate-100 border-b border-slate-100">
        <% [
          {label:'Questions', value: questionCount, icon:'M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'},
          {label:'Duration',  value: test.duration+' min', icon:'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'},
          {label:'Total Marks',value: test.totalMarks, icon:'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'},
          {label:'Negative',  value: '-'+test.negativeMarking, icon:'M18 12H6'},
        ].forEach(s => { %>
        <div class="p-5 text-center">
          <svg class="w-5 h-5 text-slate-400 mx-auto mb-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="<%= s.icon %>"/></svg>
          <p class="text-xl font-bold text-slate-900"><%= s.value %></p>
          <p class="text-xs text-slate-400 mt-0.5"><%= s.label %></p>
        </div>
        <% }) %>
      </div>

      <div class="p-8">
        <!-- Instructions -->
        <h2 class="font-bold text-slate-900 mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          Instructions
        </h2>
        <ul class="space-y-2.5 text-sm text-slate-600 mb-7">
          <% [
            {c:'emerald',icon:'M5 13l4 4L19 7',t:'Read each question carefully before answering.'},
            {c:'emerald',icon:'M5 13l4 4L19 7',t:'All questions are MCQ with 4 options. Only one is correct.'},
            {c:'amber',  icon:'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z', t:'Wrong answers deduct '+test.negativeMarking+' mark(s).'},
            {c:'emerald',icon:'M5 13l4 4L19 7',t:'You can mark questions for review and revisit them.'},
            {c:'rose',   icon:'M6 18L18 6M6 6l12 12',t:'Switching browser tabs will INSTANTLY auto-submit your exam.'},
            {c:'rose',   icon:'M6 18L18 6M6 6l12 12',t:'The exam auto-submits when the timer reaches zero.'},
            {c:'rose',   icon:'M6 18L18 6M6 6l12 12',t:'Do not refresh the page during the exam.'},
          ].concat(test.shuffleQuestions?[{c:'navy',icon:'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',t:'Questions will be shuffled randomly.'}]:[])
           .concat(test.instructions?[{c:'navy',icon:'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',t:test.instructions}]:[])
           .forEach(item => { %>
          <li class="flex items-start gap-2.5">
            <div class="w-5 h-5 rounded-full bg-<%= item.c %>-100 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-<%= item.c %>-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="<%= item.icon %>"/></svg>
            </div>
            <span><%= item.t %></span>
          </li>
          <% }) %>
        </ul>

        <!-- Palette legend -->
        <h3 class="font-semibold text-slate-800 mb-3 text-sm">Question Palette Legend</h3>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2.5 text-xs mb-8">
          <% [['bg-slate-300 text-slate-700','Not Visited'],['bg-emerald-500 text-white','Answered'],['bg-rose-500 text-white','Not Answered'],['bg-violet-500 text-white','Marked for Review']].forEach(([cls,label]) => { %>
          <div class="flex items-center gap-2 bg-slate-50 rounded-xl p-3">
            <span class="w-7 h-7 rounded-lg <%= cls %> flex items-center justify-center text-[10px] font-bold shrink-0">1</span>
            <span class="text-slate-600"><%= label %></span>
          </div>
          <% }) %>
        </div>

        <% if (inProgress) { %>
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6 flex items-start gap-2.5 text-sm text-amber-800">
          <svg class="w-5 h-5 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          You have an in-progress attempt. Clicking <strong>Resume</strong> will continue from where you left off.
        </div>
        <% } %>

        <div class="flex gap-3">
          <form action="/exam/<%= test.id %>/start" method="POST" class="flex-1">
            <button type="submit" class="w-full bg-navy-950 hover:bg-navy-900 text-white font-bold py-4 rounded-xl transition-colors text-base shadow-card-md flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <%= inProgress ? 'Resume Exam' : 'Start Exam' %>
            </button>
          </form>
          <a href="/student/tests" class="px-6 py-4 border-2 border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-colors text-sm flex items-center">Back</a>
        </div>
      </div>
    </div>
  </div>
</div>
</body></html>
