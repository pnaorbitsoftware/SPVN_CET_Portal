<%- include('../partials/head') %>
<div class="min-h-screen bg-gray-50 py-10 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
      <!-- Header -->
      <div class="bg-gradient-to-r from-primary-800 to-indigo-800 p-8 text-white">
        <div class="flex items-center gap-3 mb-2">
          <span class="bg-white/20 text-xs font-semibold px-3 py-1 rounded-full">📝 EXAM</span>
          <% if (test.status === 'published') { %><span class="bg-green-500/80 text-xs font-semibold px-3 py-1 rounded-full">AVAILABLE</span><% } %>
        </div>
        <h1 class="text-2xl font-bold mb-1"><%= test.title %></h1>
        <p class="text-white/70 text-sm"><%= process.env.COLLEGE_NAME %></p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-4 divide-x divide-gray-100 border-b border-gray-100">
        <% [
          {icon:'❓',label:'Questions',value:questionCount},
          {icon:'⏱',label:'Duration',value:test.duration+' min'},
          {icon:'📊',label:'Total Marks',value:test.totalMarks},
          {icon:'➖',label:'Negative',value:'-'+test.negativeMarking}
        ].forEach(s => { %>
        <div class="p-5 text-center">
          <p class="text-2xl mb-1"><%= s.icon %></p>
          <p class="text-xl font-bold text-gray-900"><%= s.value %></p>
          <p class="text-xs text-gray-500 mt-0.5"><%= s.label %></p>
        </div>
        <% }) %>
      </div>

      <div class="p-8">
        <!-- Instructions -->
        <h2 class="font-bold text-gray-900 mb-3">📋 Instructions</h2>
        <ul class="space-y-2 text-sm text-gray-600 mb-6">
          <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span>Read each question carefully before answering.</li>
          <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span>All questions are MCQ with 4 options. Only one is correct.</li>
          <li class="flex items-start gap-2"><span class="text-amber-500 mt-0.5">⚠</span>Each correct answer carries marks; wrong answers will deduct <strong><%= test.negativeMarking %></strong> marks.</li>
          <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span>You can mark questions for review and revisit them.</li>
          <li class="flex items-start gap-2"><span class="text-red-500 mt-0.5">✗</span>The exam auto-submits when the timer reaches zero.</li>
          <li class="flex items-start gap-2"><span class="text-red-500 mt-0.5">✗</span>Do not refresh the page during the exam.</li>
          <% if (test.shuffleQuestions) { %><li class="flex items-start gap-2"><span class="text-blue-500 mt-0.5">ℹ</span>Questions will be shuffled randomly.</li><% } %>
          <% if (test.instructions) { %><li class="flex items-start gap-2"><span class="text-blue-500 mt-0.5">ℹ</span><%= test.instructions %></li><% } %>
        </ul>

        <!-- Color legend -->
        <h3 class="font-semibold text-gray-800 mb-3 text-sm">Question Palette Legend</h3>
        <div class="grid grid-cols-2 gap-2 text-xs mb-8">
          <% [
            ['bg-gray-300','Not Visited'],
            ['bg-green-500','Answered'],
            ['bg-red-500','Not Answered'],
            ['bg-purple-500','Marked for Review'],
          ].forEach(([cls,label]) => { %>
          <div class="flex items-center gap-2">
            <span class="w-6 h-6 rounded <%= cls %> flex-shrink-0"></span>
            <span class="text-gray-600"><%= label %></span>
          </div>
          <% }) %>
        </div>

        <% if (inProgress) { %>
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6 text-sm text-amber-800">
          ⚠ You have an in-progress attempt for this test. Clicking <strong>Resume</strong> will continue from where you left off.
        </div>
        <% } %>

        <div class="flex gap-4">
          <form action="/exam/<%= test.id %>/start" method="POST" class="flex-1">
            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-4 rounded-xl transition-colors text-lg shadow-lg">
              <%= inProgress ? '▶ Resume Exam' : '🚀 Start Exam' %>
            </button>
          </form>
          <a href="/student/tests" class="px-6 py-4 border-2 border-gray-200 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 transition-colors">Back</a>
        </div>
      </div>
    </div>
  </div>
</div>
</body></html>
