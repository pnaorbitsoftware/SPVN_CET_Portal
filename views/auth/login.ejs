<%- include('../partials/head') %>
<div class="min-h-screen flex">
  <!-- Left branding -->
  <div class="hidden lg:flex lg:w-1/2 bg-gradient-to-br from-slate-900 via-navy-900 to-indigo-900 flex-col justify-between p-12 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-72 h-72 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
    <div class="relative z-10">
      <div class="flex items-center gap-3 mb-10">
        <div class="w-12 h-12 bg-orange-500 rounded-xl flex items-center justify-center text-white font-bold text-xl"><%= (process.env.COLLEGE_SHORT_NAME||'XYZ').charAt(0) %></div>
        <div><p class="text-white font-bold text-lg leading-tight"><%= process.env.COLLEGE_SHORT_NAME %></p><p class="text-white/60 text-sm">Examination Portal</p></div>
      </div>
      <h1 class="text-4xl font-bold text-white leading-tight mb-4">Online CET<br/>Examination<br/>System</h1>
      <p class="text-white/70 text-lg max-w-sm">Secure, real-time examination platform for <%= process.env.COLLEGE_NAME %>.</p>
    </div>
    <div class="relative z-10 grid grid-cols-3 gap-4">
      <% [['🎓','Students','Secure Login'],['📝','Exams','Real-time'],['📊','Results','Instant']].forEach(([icon,label,sub]) => { %>
      <div class="bg-white/10 rounded-xl p-4 backdrop-blur-sm"><div class="text-2xl mb-1"><%= icon %></div><p class="text-white font-semibold text-sm"><%= label %></p><p class="text-white/60 text-xs"><%= sub %></p></div>
      <% }) %>
    </div>
    <p class="relative z-10 text-white/40 text-xs"><%= process.env.COLLEGE_ADDRESS %></p>
  </div>

  <!-- Right form -->
  <div class="flex-1 flex items-center justify-center p-8 bg-gray-50">
    <div class="w-full max-w-md">
      <div class="bg-white rounded-2xl shadow-xl p-8 border border-gray-100">
        <h2 class="text-2xl font-bold text-gray-900 mb-1">Welcome Back</h2>
        <p class="text-gray-500 text-sm mb-6">Sign in to your examination portal</p>
        <%- include('../partials/flash') %>
        <form action="/auth/login" method="POST" class="space-y-5">
          <!-- Role: Admin or Student only -->
          <div>
            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2.5">Sign in as</label>
            <div class="grid grid-cols-2 gap-2.5">
              <% [['student','Student','M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222'],['admin','Admin','M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z']].forEach(([val,label,path]) => { %>
              <label class="cursor-pointer">
                <input type="radio" name="role" value="<%= val %>" class="sr-only peer" <%= val==='student'?'checked':'' %> onchange="updateForm(this.value)">
                <div class="peer-checked:bg-slate-900 peer-checked:text-white peer-checked:border-slate-900 border-2 border-slate-200 rounded-xl p-3.5 flex items-center gap-2.5 transition-all hover:border-slate-400 text-slate-600">
                  <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="<%= path %>"/></svg>
                  <span class="text-sm font-semibold"><%= label %></span>
                </div>
              </label>
              <% }) %>
            </div>
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">Roll Number</label>
            <input type="text" name="identifier" required
              class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:bg-white transition-all"
              placeholder="Enter your roll number" class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:bg-white transition-all"/>
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">Password</label>
            <div class="relative">
              <input type="password" name="password" id="pwInput" required
                class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:bg-white pr-12 transition-all"
                placeholder="Enter your password"/>
              <button type="button" onclick="document.getElementById('pwInput').type=document.getElementById('pwInput').type==='password'?'text':'password'" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              </button>
            </div>
          </div>
          <button type="submit" class="w-full bg-slate-900 hover:bg-slate-700 text-white font-semibold py-3 px-6 rounded-xl transition-all shadow-md active:scale-95">
            Sign In →
          </button>
        </form>
        <div class="mt-5 pt-5 border-t border-slate-100 text-center">
          <a href="/auth/admin" class="text-slate-400 hover:text-slate-600 text-xs transition-colors flex items-center justify-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Admin Login
          </a>
        </div>
        <p class="text-center text-xs text-gray-400 mt-4"><%= process.env.COLLEGE_NAME %> · AY <%= process.env.ACADEMIC_YEAR %></p>
      </div>
    </div>
  </div>
</div>

</body></html>
