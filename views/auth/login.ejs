<%- include('../partials/head') %>

<div class="min-h-screen flex">
  <!-- Left branding panel -->
  <div class="hidden lg:flex lg:w-1/2 bg-gradient-to-br from-primary-800 via-primary-700 to-indigo-800 flex-col justify-between p-12 relative overflow-hidden">
    <!-- Decorative circles -->
    <div class="absolute top-0 right-0 w-72 h-72 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>

    <div class="relative z-10">
      <div class="flex items-center gap-3 mb-12">
        <div class="w-12 h-12 bg-accent-500 rounded-xl flex items-center justify-center text-white font-bold text-xl">
          <%= process.env.COLLEGE_SHORT_NAME.charAt(0) %>
        </div>
        <div>
          <p class="text-white font-bold text-lg leading-tight"><%= process.env.COLLEGE_SHORT_NAME %></p>
          <p class="text-white/60 text-sm">Examination Portal</p>
        </div>
      </div>
      <h1 class="text-4xl font-display text-white leading-tight mb-4">
        Online CET<br/>Examination<br/>System
      </h1>
      <p class="text-white/70 text-lg max-w-sm">
        Secure, real-time, and intelligent examination platform for <%= process.env.COLLEGE_NAME %>.
      </p>
    </div>

    <div class="relative z-10 grid grid-cols-3 gap-4">
      <% [['🎓','Students','Secure Login'],['📝','Tests','Real-time Exam'],['📊','Results','Instant Score']].forEach(([icon,label,sub]) => { %>
      <div class="bg-white/10 rounded-xl p-4 backdrop-blur-sm">
        <div class="text-2xl mb-1"><%= icon %></div>
        <p class="text-white font-semibold text-sm"><%= label %></p>
        <p class="text-white/60 text-xs"><%= sub %></p>
      </div>
      <% }) %>
    </div>

    <p class="relative z-10 text-white/40 text-xs"><%= process.env.COLLEGE_ADDRESS %></p>
  </div>

  <!-- Right login form -->
  <div class="flex-1 flex items-center justify-center p-8 bg-gray-50">
    <div class="w-full max-w-md">
      <div class="lg:hidden text-center mb-8">
        <div class="w-16 h-16 bg-primary-800 rounded-2xl flex items-center justify-center text-white font-bold text-2xl mx-auto mb-3">
          <%= process.env.COLLEGE_SHORT_NAME.charAt(0) %>
        </div>
        <h2 class="text-xl font-bold text-gray-900"><%= process.env.COLLEGE_NAME %></h2>
      </div>

      <div class="bg-white rounded-2xl shadow-xl p-8 border border-gray-100">
        <h2 class="text-2xl font-bold text-gray-900 mb-1">Welcome Back</h2>
        <p class="text-gray-500 text-sm mb-6">Sign in to your examination portal account</p>

        <%- include('../partials/flash') %>

        <form action="/auth/login" method="POST" class="space-y-5">
          <!-- Role selector -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Login As</label>
            <div class="grid grid-cols-2 gap-2" id="roleSelector">
              <% [['admin','Admin','🔑'],['student','Student','🎓']].forEach(([val,label,icon]) => { %>
              <label class="cursor-pointer">
                <input type="radio" name="role" value="<%= val %>" class="sr-only peer" <%= val === 'student' ? 'checked' : '' %>>
                <div class="peer-checked:bg-primary-800 peer-checked:text-white peer-checked:border-primary-800 border-2 border-gray-200 rounded-xl p-3 text-center transition-all hover:border-primary-300">
                  <div class="text-xl"><%= icon %></div>
                  <div class="text-xs font-semibold mt-1"><%= label %></div>
                </div>
              </label>
              <% }) %>
            </div>
          </div>

          <!-- Identifier -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5" id="identifierLabel">Roll Number</label>
            <input type="text" name="identifier" id="identifierInput"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
              placeholder="Enter your roll number" required />
          </div>

          <!-- Password -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Password</label>
            <div class="relative">
              <input type="password" name="password" id="passwordInput"
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent pr-12 transition-all"
                placeholder="Enter your password" required />
              <button type="button" onclick="togglePassword()" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                <svg id="eyeIcon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                </svg>
              </button>
            </div>
          </div>

          <button type="submit"
            class="w-full bg-primary-800 hover:bg-primary-900 text-white font-semibold py-3 px-6 rounded-xl transition-all duration-200 shadow-md hover:shadow-lg active:scale-95">
            Sign In →
          </button>
        </form>

        <p class="text-center text-xs text-gray-400 mt-6">
          <%= process.env.COLLEGE_NAME %> · Academic Year <%= process.env.ACADEMIC_YEAR %>
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  // Update label based on role
  const roleInputs = document.querySelectorAll('input[name="role"]');
  const identifierLabel = document.getElementById('identifierLabel');
  const identifierInput = document.getElementById('identifierInput');
  roleInputs.forEach(r => r.addEventListener('change', () => {
    if (r.value === 'student') {
      identifierLabel.textContent = 'Roll Number';
      identifierInput.placeholder = 'Enter your roll number';
    } else {
      identifierLabel.textContent = 'Email Address';
      identifierInput.placeholder = 'Enter your email address';
      identifierInput.type = 'email';
    }
    if (r.value !== 'student') identifierInput.type = 'email';
    else identifierInput.type = 'text';
  }));

  function togglePassword() {
    const input = document.getElementById('passwordInput');
    input.type = input.type === 'password' ? 'text' : 'password';
  }
</script>
</body>
</html>
