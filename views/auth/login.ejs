<%- include('../partials/head') %>

<div class="min-h-screen flex">
  <!-- Left branding panel -->
  <div class="hidden lg:flex lg:w-[45%] bg-navy-950 flex-col justify-between p-10 relative overflow-hidden">
    <div class="absolute inset-0 opacity-20" style="background-image:radial-gradient(circle at 20% 80%, #6171f1 0%, transparent 50%), radial-gradient(circle at 80% 20%, #f59e0b 0%, transparent 50%)"></div>
    <div class="relative z-10">
      <div class="flex items-center gap-3 mb-12">
        <div class="w-10 h-10 bg-amber-500 rounded-xl flex items-center justify-center font-bold text-navy-950 text-lg">
          <%= process.env.COLLEGE_SHORT_NAME ? process.env.COLLEGE_SHORT_NAME.charAt(0) : 'C' %>
        </div>
        <div>
          <p class="text-white font-semibold text-sm"><%= process.env.COLLEGE_SHORT_NAME %></p>
          <p class="text-white/40 text-xs">Examination Portal</p>
        </div>
      </div>
      <h1 class="text-4xl font-bold text-white leading-snug mb-4">
        Online CET<br/>Examination<br/><span class="text-amber-400">System</span>
      </h1>
      <p class="text-white/50 text-base leading-relaxed max-w-xs">
        Secure, real-time examination platform for <%= process.env.COLLEGE_NAME %>.
      </p>
    </div>

    <div class="relative z-10 grid grid-cols-3 gap-3">
      <% [
        ['Secure Login', 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z'],
        ['Live Exams',   'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2'],
        ['Instant Score','M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z'],
      ].forEach(([label, path]) => { %>
      <div class="bg-white/8 border border-white/10 rounded-xl p-4">
        <svg class="w-6 h-6 text-amber-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="<%= path %>"/>
        </svg>
        <p class="text-white text-xs font-medium"><%= label %></p>
      </div>
      <% }) %>
    </div>

    <p class="relative z-10 text-white/25 text-xs"><%= process.env.COLLEGE_ADDRESS %></p>
  </div>

  <!-- Right login form -->
  <div class="flex-1 flex items-center justify-center p-6 bg-slate-50">
    <div class="w-full max-w-sm">
      <!-- Mobile logo -->
      <div class="lg:hidden text-center mb-8">
        <div class="w-14 h-14 bg-navy-950 rounded-2xl flex items-center justify-center font-bold text-amber-400 text-2xl mx-auto mb-3">
          <%= process.env.COLLEGE_SHORT_NAME ? process.env.COLLEGE_SHORT_NAME.charAt(0) : 'C' %>
        </div>
        <h2 class="text-lg font-bold text-slate-900"><%= process.env.COLLEGE_NAME %></h2>
        <p class="text-sm text-slate-500">Examination Portal</p>
      </div>

      <div class="bg-white rounded-2xl shadow-card-lg border border-slate-200 p-8">
        <h2 class="text-2xl font-bold text-slate-900 mb-1">Welcome back</h2>
        <p class="text-slate-500 text-sm mb-7">Sign in to your account to continue</p>

        <%- include('../partials/flash') %>

        <form action="/auth/login" method="POST" class="space-y-5">
          <!-- Role selector -->
          <div>
            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2.5">Sign in as</label>
            <div class="grid grid-cols-2 gap-2.5">
              <% [['student','Student','M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222'],['admin','Admin','M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z']].forEach(([val,label,path]) => { %>
              <label class="cursor-pointer">
                <input type="radio" name="role" value="<%= val %>" class="sr-only peer" <%= val === 'student' ? 'checked' : '' %>>
                <div class="peer-checked:bg-navy-950 peer-checked:text-white peer-checked:border-navy-950 border-2 border-slate-200 rounded-xl p-3.5 flex items-center gap-2.5 transition-all hover:border-navy-300 text-slate-600">
                  <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="<%= path %>"/></svg>
                  <span class="text-sm font-semibold"><%= label %></span>
                </div>
              </label>
              <% }) %>
            </div>
          </div>

          <!-- Identifier -->
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5" id="identifierLabel">Roll Number</label>
            <input type="text" name="identifier" id="identifierInput" required
              class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm bg-slate-50 transition-all"
              placeholder="Enter your roll number"/>
          </div>

          <!-- Password -->
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">Password</label>
            <div class="relative">
              <input type="password" name="password" id="passwordInput" required
                class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm bg-slate-50 pr-12 transition-all"
                placeholder="Enter your password"/>
              <button type="button" onclick="togglePwd()" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors">
                <svg id="eyeShow" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                <svg id="eyeHide" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
              </button>
            </div>
          </div>

          <button type="submit"
            class="w-full bg-navy-950 hover:bg-navy-900 text-white font-semibold py-3.5 px-6 rounded-xl transition-all duration-200 shadow-md hover:shadow-lg active:scale-[.98] flex items-center justify-center gap-2 mt-1">
            Sign In
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </button>
        </form>

        <p class="text-center text-xs text-slate-400 mt-6">
          <%= process.env.COLLEGE_NAME %> &middot; AY <%= process.env.ACADEMIC_YEAR %>
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  const roleInputs = document.querySelectorAll('input[name="role"]');
  const lbl = document.getElementById('identifierLabel');
  const inp = document.getElementById('identifierInput');
  roleInputs.forEach(r => r.addEventListener('change', () => {
    if (r.value === 'student') { lbl.textContent='Roll Number'; inp.placeholder='Enter your roll number'; inp.type='text'; }
    else { lbl.textContent='Email Address'; inp.placeholder='admin@college.edu'; inp.type='email'; }
  }));
  function togglePwd() {
    const i = document.getElementById('passwordInput');
    const s = document.getElementById('eyeShow'), h = document.getElementById('eyeHide');
    i.type = i.type === 'password' ? 'text' : 'password';
    s.classList.toggle('hidden'); h.classList.toggle('hidden');
  }
</script>
</body>
</html>
