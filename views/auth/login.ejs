<%- include('../partials/head') %>
<div class="min-h-screen flex">

  <!-- Left Panel — College Branding -->
  <div class="hidden lg:flex lg:w-[55%] relative overflow-hidden flex-col justify-between p-14"
       style="background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);">
    <!-- Animated gradient orbs -->
    <div class="absolute top-20 right-20 w-80 h-80 rounded-full opacity-20"
         style="background: radial-gradient(circle, #6366f1, transparent); filter: blur(60px);"></div>
    <div class="absolute bottom-20 left-20 w-64 h-64 rounded-full opacity-15"
         style="background: radial-gradient(circle, #f59e0b, transparent); filter: blur(50px);"></div>
    <div class="absolute top-1/2 left-1/2 w-96 h-96 rounded-full opacity-10 -translate-x-1/2 -translate-y-1/2"
         style="background: radial-gradient(circle, #3b82f6, transparent); filter: blur(80px);"></div>

    <!-- Top logo -->
    <div class="relative z-10 flex items-center gap-4">
      <div class="w-12 h-12 rounded-2xl flex items-center justify-center font-black text-xl text-slate-900"
           style="background: linear-gradient(135deg, #f59e0b, #f97316);">
        <%= (process.env.COLLEGE_SHORT_NAME||'X').charAt(0) %>
      </div>
      <div>
        <p class="text-white font-bold text-base leading-tight"><%= process.env.COLLEGE_SHORT_NAME %></p>
        <p class="text-indigo-300 text-xs">Student Examination Portal</p>
      </div>
    </div>

    <!-- Hero content -->
    <div class="relative z-10">
      <div class="inline-flex items-center gap-2 bg-indigo-500/20 border border-indigo-500/30 rounded-full px-4 py-1.5 mb-6">
        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
        <span class="text-indigo-200 text-xs font-medium">Portal is Live</span>
      </div>
      <h1 class="text-5xl font-black text-white leading-[1.1] mb-5">
        CET Online<br/>
        <span style="background: linear-gradient(135deg, #f59e0b, #f97316); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Examination</span><br/>
        System
      </h1>
      <p class="text-slate-400 text-base leading-relaxed max-w-sm">
        Secure, real-time MCQ examinations for <%= process.env.COLLEGE_NAME %>.
      </p>
    </div>

    <!-- Stats row -->
    <div class="relative z-10 grid grid-cols-3 gap-4">
      <% [
        {icon:'🎓', label:'Students', sub:'Secure access'},
        {icon:'📝', label:'Live Exams', sub:'Real-time'},
        {icon:'🏆', label:'Results', sub:'Instant rank'},
      ].forEach(s => { %>
      <div class="rounded-2xl p-4 border border-white/10" style="background: rgba(255,255,255,0.05); backdrop-filter: blur(10px);">
        <div class="text-2xl mb-2"><%= s.icon %></div>
        <p class="text-white font-semibold text-sm"><%= s.label %></p>
        <p class="text-slate-400 text-xs mt-0.5"><%= s.sub %></p>
      </div>
      <% }) %>
    </div>

    <p class="relative z-10 text-slate-600 text-xs">© <%= new Date().getFullYear() %> <%= process.env.COLLEGE_NAME %></p>
  </div>

  <!-- Right Panel — Login Form -->
  <div class="flex-1 flex items-center justify-center bg-slate-50 p-6 lg:p-12">
    <div class="w-full max-w-[400px]">

      <!-- Mobile logo -->
      <div class="lg:hidden flex items-center gap-3 mb-8 justify-center">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center font-black text-slate-900 text-lg"
             style="background: linear-gradient(135deg, #f59e0b, #f97316);">
          <%= (process.env.COLLEGE_SHORT_NAME||'X').charAt(0) %>
        </div>
        <div>
          <p class="font-bold text-slate-900"><%= process.env.COLLEGE_SHORT_NAME %></p>
          <p class="text-slate-400 text-xs">Student Portal</p>
        </div>
      </div>

      <!-- Card -->
      <div class="bg-white rounded-3xl shadow-xl border border-slate-100 p-8">
        <!-- Header -->
        <div class="mb-7">
          <div class="w-12 h-12 rounded-2xl flex items-center justify-center mb-4"
               style="background: linear-gradient(135deg, #eef2ff, #e0e7ff);">
            <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0112 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
            </svg>
          </div>
          <h2 class="text-2xl font-black text-slate-900">Student Login</h2>
          <p class="text-slate-400 text-sm mt-1">Enter your roll number and password</p>
        </div>

        <%- include('../partials/flash') %>

        <form action="/auth/login" method="POST" class="space-y-4">
          <input type="hidden" name="role" value="student"/>

          <!-- Roll Number -->
          <div>
            <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider mb-2">Roll Number</label>
            <div class="relative">
              <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2"/>
                </svg>
              </div>
              <input type="text" name="identifier" required autofocus
                class="w-full pl-11 pr-4 py-3.5 border border-slate-200 rounded-2xl text-sm text-slate-900 bg-slate-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent focus:bg-white transition-all placeholder-slate-400"
                placeholder="e.g. 2024CE001"/>
            </div>
          </div>

          <!-- Password -->
          <div>
            <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider mb-2">Password</label>
            <div class="relative">
              <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
              </div>
              <input type="password" name="password" id="sPw" required
                class="w-full pl-11 pr-12 py-3.5 border border-slate-200 rounded-2xl text-sm text-slate-900 bg-slate-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent focus:bg-white transition-all placeholder-slate-400"
                placeholder="Enter your password"/>
              <button type="button" onclick="const i=document.getElementById('sPw');i.type=i.type==='password'?'text':'password'"
                class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Default password hint -->
          <div class="bg-indigo-50 rounded-2xl p-3.5 flex items-start gap-3">
            <svg class="w-4 h-4 text-indigo-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
            </svg>
            <p class="text-indigo-700 text-xs leading-relaxed">
              Default password: <span class="font-mono font-bold">CET@XXXX</span> (last 4 digits of your roll number). You will be asked to change it on first login.
            </p>
          </div>

          <!-- Submit -->
          <button type="submit"
            class="w-full text-white font-bold py-4 rounded-2xl transition-all active:scale-95 shadow-lg mt-2 flex items-center justify-center gap-2"
            style="background: linear-gradient(135deg, #4f46e5, #6366f1); box-shadow: 0 8px 24px rgba(99,102,241,0.35);">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
            </svg>
            Sign In to Portal
          </button>
        </form>

        <!-- Admin link -->
        <div class="mt-6 pt-5 border-t border-slate-100 text-center">
          <a href="/auth/admin" class="inline-flex items-center gap-1.5 text-xs text-slate-400 hover:text-slate-600 transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
            Are you an administrator?
          </a>
        </div>
      </div>

      <p class="text-center text-xs text-slate-400 mt-5">
        <%= process.env.COLLEGE_NAME %> · Academic Year <%= process.env.ACADEMIC_YEAR %>
      </p>
    </div>
  </div>
</div>
</body></html>
