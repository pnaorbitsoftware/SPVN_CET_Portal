<%- include('../partials/head') %>
<div class="flex h-screen overflow-hidden">
  <%- include(currentUser.role === 'admin' ? '../partials/sidebar-admin' : '../partials/sidebar-student') %>
  <main class="lg:ml-64 flex-1 overflow-y-auto">
    <header class="sticky top-0 z-10 bg-white/90 backdrop-blur border-b border-slate-200 px-5 lg:px-8 py-4 flex items-center gap-4">
      <button onclick="openSidebar()" class="lg:hidden text-slate-500 hover:text-slate-800">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <h1 class="text-lg font-bold text-slate-900">Change Password</h1>
    </header>
    <div class="p-5 lg:p-8 max-w-lg">
      <%- include('../partials/flash') %>
      <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-6 lg:p-8">
        <form action="/auth/change-password" method="POST" class="space-y-5">
          <% if (!currentUser.isFirstLogin) { %>
          <div>
            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Current Password</label>
            <input type="password" name="currentPassword" required class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm" placeholder="Current password"/>
          </div>
          <% } %>
          <div>
            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">New Password</label>
            <input type="password" name="newPassword" required minlength="6" class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm" placeholder="At least 6 characters"/>
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Confirm New Password</label>
            <input type="password" name="confirmPassword" required class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm" placeholder="Repeat new password"/>
          </div>
          <button type="submit" class="w-full bg-navy-950 text-white font-semibold py-3 rounded-xl hover:bg-navy-900 transition-colors">
            Update Password
          </button>
        </form>
      </div>
    </div>
  </main>
</div>
</body>
</html>
