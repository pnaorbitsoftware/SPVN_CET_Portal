<div id="sidebarOverlay" class="fixed inset-0 bg-black/50 z-20 lg:hidden" onclick="closeSidebar()"></div>

<aside id="mainSidebar" class="fixed inset-y-0 left-0 w-64 bg-navy-950 text-white flex flex-col z-30 shadow-2xl
  transform -translate-x-full lg:translate-x-0 transition-transform duration-250 ease-in-out">
  <div class="px-5 py-4 border-b border-white/8">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 bg-navy-600 rounded-lg flex items-center justify-center font-bold text-white text-base shrink-0">
        <%= process.env.COLLEGE_SHORT_NAME ? process.env.COLLEGE_SHORT_NAME.charAt(0) : 'S' %>
      </div>
      <div class="min-w-0">
        <p class="font-semibold text-sm leading-tight truncate"><%= process.env.COLLEGE_SHORT_NAME %></p>
        <p class="text-[11px] text-white/40 mt-0.5">Student Portal</p>
      </div>
      <button onclick="closeSidebar()" class="ml-auto lg:hidden text-white/40 hover:text-white">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <nav class="flex-1 px-3 py-4 overflow-y-auto space-y-0.5">
    <a href="/student/dashboard" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-white/70 hover:text-white transition-colors">
      <svg class="w-4.5 h-4.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
      Dashboard
    </a>
    <a href="/student/tests" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-white/70 hover:text-white transition-colors">
      <svg class="w-4.5 h-4.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
      My Tests
    </a>
    <a href="/student/results" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-white/70 hover:text-white transition-colors">
      <svg class="w-4.5 h-4.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      My Results
    </a>
    <a href="/student/notifications" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-white/70 hover:text-white transition-colors">
      <svg class="w-4.5 h-4.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
      Notifications
    </a>
    <a href="/auth/change-password" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-white/70 hover:text-white transition-colors">
      <svg class="w-4.5 h-4.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
      Change Password
    </a>
  </nav>

  <div class="px-4 py-4 border-t border-white/8">
    <div class="flex items-center gap-3 mb-3.5">
      <div class="w-8 h-8 rounded-full bg-navy-600 flex items-center justify-center font-semibold text-white text-sm shrink-0">
        <%= currentUser.name.charAt(0).toUpperCase() %>
      </div>
      <div class="min-w-0 flex-1">
        <p class="text-sm font-medium truncate leading-tight"><%= currentUser.name %></p>
        <p class="text-[11px] text-white/40 font-mono">Roll: <%= currentUser.rollNo %></p>
      </div>
    </div>
    <a href="/auth/logout" class="flex items-center gap-2 text-[13px] text-white/50 hover:text-white transition-colors group">
      <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      Sign out
    </a>
  </div>
</aside>

<script>
  function closeSidebar() {
    document.getElementById('mainSidebar').classList.remove('open');
    document.getElementById('sidebarOverlay').classList.remove('open');
  }
  function openSidebar() {
    document.getElementById('mainSidebar').classList.add('open');
    document.getElementById('sidebarOverlay').classList.add('open');
  }
  document.querySelectorAll('.sidebar-link').forEach(l => {
    if (window.location.pathname.startsWith(l.getAttribute('href'))) l.classList.add('active', 'text-white');
  });
</script>
