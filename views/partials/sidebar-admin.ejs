<%# views/partials/sidebar-admin.ejs %>
<aside class="fixed inset-y-0 left-0 w-64 bg-primary-800 text-white flex flex-col z-30 shadow-2xl">
  <div class="px-6 py-5 border-b border-white/10">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 bg-accent-500 rounded-lg flex items-center justify-center font-bold text-lg"><%= process.env.COLLEGE_SHORT_NAME.charAt(0) %></div>
      <div><p class="font-bold text-sm leading-tight"><%= process.env.COLLEGE_SHORT_NAME %></p><p class="text-xs text-white/60">Admin Panel</p></div>
    </div>
  </div>
  <nav class="flex-1 px-3 py-4 overflow-y-auto space-y-1">
    <p class="px-3 text-xs font-semibold text-white/40 uppercase tracking-wider mb-2">Main</p>
    <a href="/admin/dashboard" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-white/10 transition-colors text-sm">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h18M3 12h18M3 17h18"/></svg>Dashboard
    </a>
    <p class="px-3 text-xs font-semibold text-white/40 uppercase tracking-wider mt-4 mb-2">People</p>
    <a href="/admin/students" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-white/10 transition-colors text-sm">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197"/></svg>Students
    </a>
    <a href="/admin/groups" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-white/10 transition-colors text-sm">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg>Groups / Batches
    </a>
    <p class="px-3 text-xs font-semibold text-white/40 uppercase tracking-wider mt-4 mb-2">Exams</p>
    <a href="/admin/subjects" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-white/10 transition-colors text-sm">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>Subjects
    </a>
    <a href="/admin/questions" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-white/10 transition-colors text-sm">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Question Bank
    </a>
    <a href="/admin/tests" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-white/10 transition-colors text-sm">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>Tests
    </a>
    <p class="px-3 text-xs font-semibold text-white/40 uppercase tracking-wider mt-4 mb-2">Reports</p>
    <a href="/admin/results" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-white/10 transition-colors text-sm">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>All Results
    </a>
  </nav>
  <div class="px-4 py-4 border-t border-white/10">
    <div class="flex items-center gap-3 mb-3">
      <div class="w-9 h-9 rounded-full bg-accent-500 flex items-center justify-center font-bold text-sm"><%= currentUser.name.charAt(0).toUpperCase() %></div>
      <div class="overflow-hidden"><p class="text-sm font-semibold truncate"><%= currentUser.name %></p><p class="text-xs text-white/50">Administrator</p></div>
    </div>
    <a href="/auth/logout" class="flex items-center gap-2 text-sm text-white/70 hover:text-white transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>Logout
    </a>
  </div>
</aside>
<script>
  document.querySelectorAll('.sidebar-link').forEach(link => {
    if (window.location.pathname.startsWith(link.getAttribute('href'))) link.classList.add('bg-white/20');
  });
</script>
