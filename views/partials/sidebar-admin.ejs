<%# Mobile overlay %>
<div id="sidebarOverlay" class="hidden fixed inset-0 bg-black/50 z-20 lg:hidden" onclick="closeSidebar()"></div>

<aside id="mainSidebar" class="fixed inset-y-0 left-0 w-64 bg-navy-950 text-white flex flex-col z-30 shadow-2xl
  transition-transform duration-300 ease-in-out" style="transform: translateX(-100%);">

  <%# Logo %>
  <div class="px-5 py-4 border-b border-white/10">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 bg-amber-500 rounded-lg flex items-center justify-center font-bold text-navy-950 text-base leading-none shrink-0">
        <%= process.env.COLLEGE_SHORT_NAME ? process.env.COLLEGE_SHORT_NAME.charAt(0) : 'A' %>
      </div>
      <div class="min-w-0">
        <p class="font-semibold text-sm leading-tight truncate"><%= process.env.COLLEGE_SHORT_NAME %></p>
        <p class="text-[11px] text-white/40 mt-0.5">Admin Panel</p>
      </div>
      <button onclick="closeSidebar()" class="ml-auto lg:hidden text-white/40 hover:text-white">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <nav class="flex-1 px-3 py-4 overflow-y-auto space-y-0.5">
    <p class="px-3 text-[10px] font-semibold text-white/30 uppercase tracking-widest mb-2">Overview</p>
    <a href="/admin/dashboard" class="sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-white/70 hover:text-white transition-colors">
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
      Dashboard
    </a>

    <p class="px-3 text-[10px] font-semibold text-white/30 uppercase tracking-widest mt-5 mb-2">People</p>
    <a href="/admin/students" class="sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-white/70 hover:text-white transition-colors">
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20H3v-1a6 6 0 0114 0v1zm7 0h-3v-1a4.5 4.5 0 00-3.21-4.3M15 7a4 4 0 11-8 0 4 4 0 018 0zm5 2.5a3.5 3.5 0 11-7 0 3.5 3.5 0 017 0z"/></svg>
      Students
    </a>
    <a href="/admin/groups" class="sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-white/70 hover:text-white transition-colors">
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
      Groups &amp; Batches
    </a>

    <p class="px-3 text-[10px] font-semibold text-white/30 uppercase tracking-widest mt-5 mb-2">Exams</p>
    <a href="/admin/topics" class="sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-white/70 hover:text-white transition-colors">
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
      Subjects
    </a>
    <a href="/admin/questions" class="sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-white/70 hover:text-white transition-colors">
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      Question Bank
    </a>
    <a href="/admin/tests" class="sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-white/70 hover:text-white transition-colors">
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
      Tests
    </a>

    <a href="/admin/documents" class="sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-white/70 hover:text-white transition-colors">
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      Student Docs
    </a>
    <p class="px-3 text-[10px] font-semibold text-white/30 uppercase tracking-widest mt-5 mb-2">Reports</p>
    <a href="/admin/results" class="sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm text-white/70 hover:text-white transition-colors">
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      All Results
    </a>
  </nav>

  <%# User footer %>
  <div class="px-4 py-4 border-t border-white/10 mt-auto">
    <div class="flex items-center gap-3 mb-3.5">
      <div class="w-8 h-8 rounded-full bg-amber-500 flex items-center justify-center font-semibold text-navy-950 text-sm shrink-0">
        <%= currentUser.name.charAt(0).toUpperCase() %>
      </div>
      <div class="min-w-0 flex-1">
        <p class="text-sm font-medium truncate leading-tight"><%= currentUser.name %></p>
        <p class="text-[11px] text-white/40">Administrator</p>
      </div>
    </div>
    <a href="/auth/logout" class="flex items-center gap-2 text-[13px] text-white/50 hover:text-white transition-colors group">
      <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      Sign out
    </a>
  </div>
</aside>

<script>
  // On desktop (lg+), always show sidebar
  function initSidebar() {
    const sidebar = document.getElementById('mainSidebar');
    if (window.innerWidth >= 1024) {
      sidebar.style.transform = 'translateX(0)';
    } else {
      sidebar.style.transform = 'translateX(-100%)';
    }
  }
  function closeSidebar() {
    document.getElementById('mainSidebar').style.transform = 'translateX(-100%)';
    document.getElementById('sidebarOverlay').classList.remove('open');
  }
  function openSidebar() {
    document.getElementById('mainSidebar').style.transform = 'translateX(0)';
    document.getElementById('sidebarOverlay').classList.add('open');
  }
  // Handle resize
  window.addEventListener('resize', initSidebar);
  // Init on load
  initSidebar();

  document.querySelectorAll('.sidebar-link').forEach(l => {
    if (window.location.pathname.startsWith(l.getAttribute('href'))) l.classList.add('active', 'text-white');
  });
</script>
