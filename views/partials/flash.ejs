<%# Reusable flash alerts — no emojis, SVG icons only %>
<% if (locals.successMsg && successMsg.length) { %>
<div class="flash-in flex items-start gap-3 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3.5 rounded-xl mb-4" role="alert">
  <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
  <span class="text-sm font-medium flex-1"><%= successMsg[0] %></span>
  <button onclick="this.closest('[role=alert]').remove()" class="text-emerald-600 hover:text-emerald-800 ml-auto flex-shrink-0">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
</div>
<% } %>
<% if (locals.errorMsg && errorMsg.length) { %>
<div class="flash-in flex items-start gap-3 bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3.5 rounded-xl mb-4" role="alert">
  <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
  <span class="text-sm font-medium flex-1"><%= errorMsg[0] %></span>
  <button onclick="this.closest('[role=alert]').remove()" class="text-rose-600 hover:text-rose-800 ml-auto flex-shrink-0">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
</div>
<% } %>
<% if (locals.warningMsg && warningMsg.length) { %>
<div class="flash-in flex items-start gap-3 bg-amber-50 border border-amber-200 text-amber-800 px-4 py-3.5 rounded-xl mb-4" role="alert">
  <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
  <span class="text-sm font-medium flex-1"><%= warningMsg[0] %></span>
  <button onclick="this.closest('[role=alert]').remove()" class="text-amber-600 hover:text-amber-800 ml-auto flex-shrink-0">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
</div>
<% } %>
<% if (locals.infoMsg && infoMsg.length) { %>
<div class="flash-in flex items-start gap-3 bg-navy-50 border border-navy-200 text-navy-800 px-4 py-3.5 rounded-xl mb-4" role="alert">
  <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
  <span class="text-sm font-medium flex-1"><%= infoMsg[0] %></span>
  <button onclick="this.closest('[role=alert]').remove()" class="text-navy-600 hover:text-navy-800 ml-auto flex-shrink-0">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
</div>
<% } %>
