<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'CET Exam Portal' %> — <%= collegeShort %></title>
  <!-- PWA Manifest & Meta -->
  <link rel="manifest" href="/manifest.json"/>
  <meta name="theme-color" content="#131330"/>
  <meta name="mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
  <meta name="apple-mobile-web-app-title" content="CET Exam"/>
  <meta name="application-name" content="CET Exam"/>
  <meta name="msapplication-TileColor" content="#131330"/>
  <meta name="msapplication-TileImage" content="/icons/icon-144x144.png"/>
  <!-- Apple touch icons -->
  <link rel="apple-touch-icon" href="/icons/icon-152x152.png"/>
  <link rel="apple-touch-icon" sizes="192x192" href="/icons/icon-192x192.png"/>
  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/icons/icon-96x96.png"/>
  <link rel="icon" type="image/png" sizes="16x16" href="/icons/icon-72x72.png"/>

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            navy:   { 50:'#f0f4ff', 100:'#e0e9ff', 200:'#c7d7fe', 300:'#a5bbfd', 400:'#8199f8', 500:'#6171f1', 600:'#4f55e6', 700:'#4140cc', 800:'#3534a6', 900:'#1e1f5e', 950:'#131330' },
            amber:  { 400:'#fbbf24', 500:'#f59e0b', 600:'#d97706' },
            slate:  { 50:'#f8fafc', 100:'#f1f5f9', 200:'#e2e8f0', 300:'#cbd5e1', 400:'#94a3b8', 500:'#64748b', 600:'#475569', 700:'#334155', 800:'#1e293b', 900:'#0f172a' },
            emerald:{ 50:'#ecfdf5', 100:'#d1fae5', 500:'#10b981', 600:'#059669', 700:'#047857' },
            rose:   { 50:'#fff1f2', 100:'#ffe4e6', 500:'#f43f5e', 600:'#e11d48' },
          },
          fontFamily: {
            sans: ['"Outfit"', 'sans-serif'],
            mono: ['"JetBrains Mono"', 'monospace'],
          },
          boxShadow: {
            'card': '0 1px 3px 0 rgb(0 0 0 / 0.06), 0 1px 2px -1px rgb(0 0 0 / 0.06)',
            'card-md': '0 4px 12px -2px rgb(0 0 0 / 0.08), 0 2px 4px -2px rgb(0 0 0 / 0.05)',
            'card-lg': '0 10px 30px -5px rgb(0 0 0 / 0.1), 0 4px 6px -2px rgb(0 0 0 / 0.05)',
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <style>
    * { -webkit-font-smoothing: antialiased; }
    body { font-family: 'Outfit', sans-serif; }
    .sidebar-link { position: relative; }
    .sidebar-link.active { background: rgba(255,255,255,0.12); }
    .sidebar-link.active::before { content:''; position:absolute; left:0; top:50%; transform:translateY(-50%); width:3px; height:60%; background:#f59e0b; border-radius:0 2px 2px 0; }
    .sidebar-link:hover:not(.active) { background: rgba(255,255,255,0.07); }
    .card-lift { transition: transform 0.18s ease, box-shadow 0.18s ease; }
    .card-lift:hover { transform: translateY(-2px); box-shadow: 0 8px 24px -4px rgb(0 0 0 / 0.12); }
    .flash-in { animation: flashIn 0.3s ease; }
    @keyframes flashIn { from{opacity:0;transform:translateY(-6px)} to{opacity:1;transform:translateY(0)} }
    .q-not-visited   { background:#e2e8f0; color:#475569; }
    .q-not-answered  { background:#f43f5e; color:#fff; }
    .q-answered      { background:#10b981; color:#fff; }
    .q-marked        { background:#8b5cf6; color:#fff; }
    .timer-warning   { animation: pulse 1s infinite; }
    @keyframes pulse  { 0%,100%{opacity:1} 50%{opacity:.6} }
    /* Mobile overlay */
    #sidebarOverlay { display:none; }
    @media(max-width:1023px){
      #sidebarOverlay.open { display:block; }
      #mainSidebar.open    { transform:translateX(0); }
    }
    input:focus, select:focus, textarea:focus {
      outline: none;
      box-shadow: 0 0 0 3px rgba(97,113,241,0.15);
      border-color: #6171f1 !important;
    }
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
  </style>
</head>
<body class="h-full bg-slate-50 text-slate-800">
<script src="/pwa.js" defer></script>
