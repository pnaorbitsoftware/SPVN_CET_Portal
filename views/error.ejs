<%- include('./partials/head') %>
<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
  <div class="text-center max-w-md">
    <div class="text-8xl mb-6"><%= statusCode === 404 ? '🔍' : '⚠️' %></div>
    <h1 class="text-6xl font-bold text-gray-300 mb-4"><%= statusCode || 500 %></h1>
    <h2 class="text-2xl font-bold text-gray-900 mb-2"><%= title || 'Something went wrong' %></h2>
    <p class="text-gray-500 mb-8"><%= message || 'An unexpected error occurred.' %></p>
    <% if (typeof error !== 'undefined' && error.stack && process.env.NODE_ENV === 'development') { %>
    <pre class="text-left bg-red-50 border border-red-200 rounded-xl p-4 text-xs text-red-700 overflow-auto mb-6"><%= error.stack %></pre>
    <% } %>
    <a href="javascript:history.back()" class="inline-block bg-primary-800 text-white px-6 py-3 rounded-xl font-semibold hover:bg-primary-900 transition-colors mr-3">← Go Back</a>
    <a href="/" class="inline-block border border-gray-200 text-gray-700 px-6 py-3 rounded-xl font-semibold hover:bg-gray-50 transition-colors">Home</a>
  </div>
</div>
</body></html>
