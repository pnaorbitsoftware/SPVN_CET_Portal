<%- include('./partials/head') %>
<div class="min-h-screen bg-slate-50 flex items-center justify-center px-4">
  <div class="text-center max-w-md">
    <div class="w-20 h-20 bg-rose-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
      <svg class="w-10 h-10 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
        <% if (statusCode === 404) { %>
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        <% } else { %>
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        <% } %>
      </svg>
    </div>
    <h1 class="text-7xl font-bold text-slate-200 mb-2"><%= statusCode || 500 %></h1>
    <h2 class="text-2xl font-bold text-slate-900 mb-2"><%= title || 'Something went wrong' %></h2>
    <p class="text-slate-500 mb-8 leading-relaxed"><%= message || 'An unexpected error occurred.' %></p>
    <% if (typeof error !== 'undefined' && error.stack && process.env.NODE_ENV === 'development') { %>
    <pre class="text-left bg-rose-50 border border-rose-200 rounded-xl p-4 text-xs text-rose-700 overflow-auto mb-6 max-h-48"><%= error.stack %></pre>
    <% } %>
    <div class="flex items-center justify-center gap-3">
      <a href="javascript:history.back()" class="inline-flex items-center gap-2 bg-navy-950 text-white px-5 py-2.5 rounded-xl font-semibold hover:bg-navy-900 transition-colors text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Go Back
      </a>
      <a href="/" class="inline-flex items-center gap-2 border border-slate-200 text-slate-700 px-5 py-2.5 rounded-xl font-semibold hover:bg-slate-50 transition-colors text-sm">Home</a>
    </div>
  </div>
</div>
</body></html>
