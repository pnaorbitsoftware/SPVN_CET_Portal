# ============================================================
#  XYZ COLLEGE — CET ONLINE EXAMINATION SYSTEM
#  Copy this file to .env and fill in your values
# ============================================================

# --- College Details ---
COLLEGE_NAME="XYZ College of Engineering & Technology"
COLLEGE_SHORT_NAME="XYZCE"
COLLEGE_ADDRESS="123 Education Avenue, Knowledge City, Maharashtra - 411001"
COLLEGE_PHONE="+91-20-1234-5678"
COLLEGE_EMAIL="examcell@xyzcollege.edu.in"
COLLEGE_WEBSITE="https://www.xyzcollege.edu.in"
COLLEGE_LOGO="/images/logo.png"
EXAM_CELL_HEAD="Dr. Rajesh Kumar"
ACADEMIC_YEAR="2024-2025"

# --- Application ---
NODE_ENV=development
PORT=3000
APP_NAME="XYZ College CET Examination Portal"
APP_URL=http://localhost:3000

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=xyz_cet_exam
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_DIALECT=mysql

# --- Session ---
SESSION_SECRET=change_this_to_a_long_random_string
SESSION_MAX_AGE=86400000

# --- Password Policy ---
PASSWORD_PREFIX=CET@
ADMIN_DEFAULT_PASSWORD=Admin@XYZ2024
TEACHER_PASSWORD_PREFIX=Teacher@

# --- File Upload ---
UPLOAD_PATH=./public/uploads
MAX_FILE_SIZE=10485760

# --- Exam Settings ---
DEFAULT_EXAM_DURATION=180
NEGATIVE_MARKING_DEFAULT=0.25
QUESTIONS_PER_PAGE=1

# --- PDF Export ---
PDF_FOOTER="XYZ College of Engineering & Technology | Confidential"
