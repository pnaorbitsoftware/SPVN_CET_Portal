# ════════════════════════════════════════════════════════════════
#  CET EXAM PORTAL — Environment Configuration
#  Copy this file to .env and fill in every value before starting
# ════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=CET Exam Portal
NODE_ENV=development          # development | production
PORT=3000

# ── College Info ─────────────────────────────────────────────────────────────
COLLEGE_NAME=Your College Name
COLLEGE_SHORT_NAME=YCN         # Shown in sidebar header & PDFs
COLLEGE_ADDRESS=123 College Road, City, State - 000000
ACADEMIC_YEAR=2024-25

# ── Database (MySQL / MariaDB) ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cet_exam_db
DB_USER=root
DB_PASSWORD=your_db_password

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string_min_32_chars
SESSION_MAX_AGE=86400000       # 24 hours in ms

# ── Admin Account (auto-seeded on first startup) ──────────────────────────────
# These credentials are used ONLY if no admin account exists in the database.
# Change them immediately after first login.
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@college.edu
ADMIN_PASSWORD=Admin@1234      # Min 8 chars, change after first login

# ── Student Password Config ───────────────────────────────────────────────────
PASSWORD_PREFIX=CET@           # Default: CET@ + last 4 digits of roll number

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760         # 10 MB in bytes

# ── PDF Footer ────────────────────────────────────────────────────────────────
PDF_FOOTER=Generated by CET Exam Portal — Confidential

# --- SSL (set to true for hosted/cloud MySQL: Aiven, Railway, PlanetScale) ---
DB_SSL=false
